@model IEnumerable<OceanShellCraft.Models.SanPham>

@{
    ViewData["Title"] = "bộ sưu tập sản phẩm";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="display-5 mb-0">sản phẩm nghệ thuật</h2>

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-action="TaoMoi" class="glass-btn">
                    <i class="bi bi-plus-lg me-2"></i>thêm thủ công
                </a>
                <a asp-action="NhapExcel" class="glass-btn">
                    <i class="bi bi-file-earmark-excel me-2"></i>nhập excel
                </a>
            </div>
        }
    </div>

    <ul class="list-unstyled d-flex justify-content-center flex-wrap gap-4 mb-5 pb-3" style="border-bottom: 1px solid var(--border-light);">
        <li>
            <a href="@Url.Action("DanhSach", new { maDanhMuc = (int?)null })"
               class="text-decoration-none @(ViewBag.CurrentCategory == null ? "opacity-100" : "opacity-50")">
                tất cả
            </a>
        </li>
        @if (ViewBag.DanhMucs != null)
        {
            foreach (var dm in ViewBag.DanhMucs)
            {
                <li>
                    <a href="@Url.Action("DanhSach", new { maDanhMuc = dm.Id })"
                       class="text-decoration-none @(ViewBag.CurrentCategory == dm.Id ? "opacity-100" : "opacity-50")">
                        @dm.TenDanhMuc.ToLower()
                    </a>
                </li>
            }
        }
    </ul>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 opacity-50">
                <p>không có sản phẩm nào trong danh mục này.</p>
            </div>
        }

        @foreach (var sp in Model)
        {
            <div class="col-md-4">
                <div class="glass-card p-4 text-center h-100 d-flex flex-column">

                    <div class="d-flex align-items-center justify-content-center w-100 overflow-hidden mb-4" style="height: 250px;">
                        <img src="@(string.IsNullOrEmpty(sp.HinhAnh) ? "/images/default-shell.png" : sp.HinhAnh)"
                             alt="@sp.TenSanPham?.ToLower()"
                             class="rounded-4 img-fluid"
                             style="max-height: 100%; object-fit: cover; border: 1px solid var(--border-light);">
                    </div>

                    <div class="mt-auto">
                        <h4 class="fs-5 mb-2">@sp.TenSanPham?.ToLower()</h4>
                        <p class="opacity-50 small mb-2">@sp.ChatLieu?.ToLower()</p>
                        <p class="fs-5 mb-4">@sp.GiaTien.ToString("N0") vnđ</p>

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-controller="SanPham" asp-action="ChiTiet" asp-route-id="@sp.Id" class="glass-btn">
                                chi tiết
                            </a>

                            @if (User.Identity.IsAuthenticated)
                            {
                                <form asp-controller="GioHang" asp-action="ThemVaoGio" method="get" class="m-0">
                                    <input type="hidden" name="sanPhamId" value="@sp.Id" />
                                    <button type="submit" class="glass-btn border-0">thêm vào giỏ</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="TaiKhoan" asp-action="DangNhap" class="glass-btn">đăng nhập mua</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-3 mt-5 pt-3">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("DanhSach", new { maDanhMuc = ViewBag.CurrentCategory, page = i })"
                   class="glass-circle text-decoration-none @(i == ViewBag.CurrentPage ? "opacity-100" : "opacity-50")"
                   style="width: 40px; height: 40px;">
                    @i
                </a>
            }
        </div>
    }
</div>