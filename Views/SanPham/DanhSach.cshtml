@model IEnumerable<OceanShellCraft.Models.SanPham>

@{
    ViewData["Title"] = "Bộ Sưu Tập Sản Phẩm";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="luxury-title fs-1 mb-0">Sản Phẩm Nghệ Thuật</h2>

        @if (User.IsInRole("Admin"))
        {
            <div class="btn-group shadow-sm">
                <a asp-action="TaoMoi" class="btn btn-outline-warning">
                    <i class="fas fa-plus me-1"></i>Thêm Thủ Công
                </a>
                <a asp-action="NhapExcel" class="btn btn-warning">
                    <i class="fas fa-file-excel me-1"></i>Nhập Excel
                </a>
            </div>
        }
    </div>

    <ul class="luxury-filter-menu list-unstyled d-flex justify-content-center flex-wrap gap-4 border-bottom border-secondary-subtle pb-2 mb-5">
        <li>
            <a href="@Url.Action("DanhSach", new { maDanhMuc = (int?)null })"
               class="@(ViewBag.CurrentCategory == null ? "active" : "")">TẤT CẢ</a>
        </li>
        @if (ViewBag.DanhMucs != null)
        {
            foreach (var dm in ViewBag.DanhMucs)
            {
                <li>
                    <a href="@Url.Action("DanhSach", new { maDanhMuc = dm.Id })"
                       class="@(ViewBag.CurrentCategory == dm.Id ? "active" : "")">@dm.TenDanhMuc.ToUpper()</a>
                </li>
            }
        }
    </ul>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-white-50 py-5">
                <p>Không có sản phẩm nào trong danh mục này.</p>
            </div>
        }
        @foreach (var sp in Model)
        {
            <div class="col-md-4">
                <div class="luxury-grid-card p-3 p-md-4 text-center h-100 d-flex flex-column rounded-4">

                    <div class="card-img-container d-flex align-items-center justify-content-center w-100 overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(sp.HinhAnh) ? "/images/default-shell.png" : sp.HinhAnh)" alt="@sp.TenSanPham">
                    </div>

                    <div class="card-content mt-auto pt-4">
                        <h4 class="text-warning fw-bold fs-5 text-uppercase mb-2" style="letter-spacing: 0.5px;">@sp.TenSanPham</h4>
                        <p class="text-white-50 small mb-2">@sp.ChatLieu</p>
                        <p class="text-white fw-bold fs-5 mb-4">@sp.GiaTien.ToString("N0") VNĐ</p>

                        <div class="d-flex justify-content-center gap-4">
                            <a asp-controller="SanPham" asp-action="ChiTiet" asp-route-id="@sp.Id" class="btn-luxury-text">CHI TIẾT</a>

                            @if (User.Identity.IsAuthenticated)
                            {
                                <form asp-controller="GioHang" asp-action="ThemVaoGio" method="get">
                                    <input type="hidden" name="sanPhamId" value="@sp.Id" />
                                    <button type="submit" class="btn-luxury-text border-0 bg-transparent">THÊM VÀO GIỎ</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn-luxury-text">ĐĂNG NHẬP MUA</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="luxury-pagination d-flex justify-content-center align-items-center gap-3 mt-5 pt-3">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("DanhSach", new { maDanhMuc = ViewBag.CurrentCategory, page = i })"
                   class="d-flex align-items-center justify-content-center @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
            }
        </div>
    }
</div>