@model OceanShellCraft.Models.SanPham

@{
    ViewData["Title"] = Model.TenSanPham;
}

<div class="container mt-5 mb-5">
    <a asp-action="DanhSach" class="btn text-white mb-4 px-4 py-2" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(5px); border-radius: 30px; border: 1px solid rgba(255,255,255,0.2);">
        <i class="bi bi-arrow-left me-2"></i> Quay lại cửa hàng
    </a>

    <div class="bg-white rounded-5 overflow-hidden position-relative shadow-lg mb-4">
        <div class="row align-items-center">

            <div class="col-lg-6 p-5 pe-lg-0">
                <p class="text-muted mb-2 fw-bold text-uppercase small" style="letter-spacing: 1px;">
                    OceanShellCraft <i class="bi bi-gem text-info"></i>
                </p>

                <h1 class="display-4 fw-bolder text-dark mb-4" style="line-height: 1.15; letter-spacing: -1px;">
                    @Model.TenSanPham
                </h1>

                <h2 class="h3 fw-bold text-dark mb-4">@Model.GiaTien.ToString("N0") VNĐ</h2>

                <div class="d-flex align-items-center gap-3 mb-5">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="GioHang" asp-action="ThemVaoGio" method="get" class="m-0">
                            <input type="hidden" name="sanPhamId" value="@Model.Id" />
                            <button type="submit" class="btn btn-dark rounded-pill px-4 py-3 fw-bold shadow">
                                Thêm Giỏ Hàng <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </form>
                        <button class="btn btn-outline-dark rounded-pill px-4 py-3 fw-bold">Mua Ngay</button>
                    }
                    else
                    {
                        <a asp-controller="TaiKhoan" asp-action="DangNhap" class="btn btn-dark rounded-pill px-4 py-3 fw-bold shadow">
                            <i class="bi bi-lock-fill me-2"></i> Đăng nhập mua
                        </a>
                    }
                </div>

                <div class="d-flex gap-3 mb-4">
                    <div class="soft-icon-box" title="Đảm bảo chất lượng"><i class="fa-solid fa-award"></i></div>
                    <div class="soft-icon-box" title="Thủ công tinh xảo"><i class="fa-solid fa-hand-sparkles"></i></div>
                    <div class="soft-icon-box" title="Vật liệu tự nhiên"><i class="fa-solid fa-leaf"></i></div>
                    <div class="soft-icon-box" title="Giao hàng an toàn"><i class="fa-solid fa-box-open"></i></div>
                </div>
            </div>

            <div class="col-lg-6 position-relative text-center p-5">
                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/default-shell.png" : Model.HinhAnh)" alt="@Model.TenSanPham" class="hero-product-img w-100 object-fit-contain rounded-circle" />
            </div>
        </div>

        <div class="row p-5 pt-0 align-items-end">
            <div class="col-lg-6 d-flex flex-wrap gap-4">
                <div class="info-card bg-white rounded-4 border shadow-sm p-4 flex-fill">
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 50px; height: 50px;">
                        <i class="fa-solid fa-gem text-dark fs-4"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Chất liệu</h5>
                    <p class="text-muted small mb-0">@Model.ChatLieu</p>
                </div>

                <div class="info-card bg-white rounded-4 border shadow-sm p-4 flex-fill">
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 50px; height: 50px;">
                        <i class="fa-solid fa-ruler-combined text-dark fs-4"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Kích thước</h5>
                    <p class="text-muted small mb-0">@Model.KichThuoc</p>
                </div>
            </div>

            <div class="col-lg-6 ps-lg-5 mt-4 mt-lg-0">
                <h3 class="fw-bolder text-dark mb-3">Thông tin chi tiết</h3>
                <p class="text-muted" style="line-height: 1.8; font-size: 0.95rem;">
                    @Model.MoTa
                </p>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="admin-bar bg-light p-3 text-center border-top">
                <span class="text-danger fw-bold me-2">Quyền Quản Trị Viên:</span>
                <a href="#" class="btn btn-sm btn-outline-danger rounded-pill px-3">Sửa Sản Phẩm</a>
            </div>
        }
    </div>

    <div class="bg-white rounded-5 shadow-lg p-5">
        <h3 class="fw-bolder text-dark mb-4">Đánh giá từ khách hàng</h3>

        @if (Model.DanhGias != null && Model.DanhGias.Any())
        {
            <div class="review-list">
                @foreach (var danhGia in Model.DanhGias.OrderByDescending(d => d.NgayDanhGia))
                {
                    <div class="review-item border-bottom border-light pb-4 mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                <i class="bi bi-person-fill fs-4 text-secondary"></i>
                            </div>

                            <div>
                                <h6 class="fw-bold mb-0 text-dark">@(danhGia.NguoiDung?.HoTen ?? "Khách hàng ẩn danh")</h6>

                                <div class="text-warning small mt-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= danhGia.SoSao)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                    <span class="text-muted ms-2" style="font-size: 0.8rem;">@danhGia.NgayDanhGia.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>

                        <p class="text-muted mb-0 ps-5" style="line-height: 1.6; font-size: 0.95rem;">
                            @danhGia.NoiDung
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square-text text-light" style="font-size: 4rem;"></i>
                <h5 class="fw-bold text-dark mt-3">Chưa có đánh giá nào</h5>
                <p class="text-muted mb-0">Sản phẩm này chưa có đánh giá. Hãy là người đầu tiên để lại nhận xét nhé!</p>
            </div>
        }
    </div>
</div>