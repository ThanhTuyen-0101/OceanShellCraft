@model OceanShellCraft.Models.SanPham

@{
    ViewData["Title"] = Model.TenSanPham;
}

<div class="container mt-5 mb-5">
    <a asp-action="DanhSach" class="glass-btn mb-4 px-4 py-2">
        <i class="bi bi-arrow-left me-2"></i> Quay lại cửa hàng
    </a>

    <div class="glass-card overflow-hidden position-relative mb-4 p-0">
        <div class="row align-items-center g-0">

            <div class="col-lg-6 p-5">
                <p class="opacity-75 mb-2 small" style="letter-spacing: 1px;">
                    OceanShellCraft <i class="bi bi-gem"></i>
                </p>

                <h1 class="display-4 mb-4" style="line-height: 1.15; letter-spacing: -1px;">
                    @Model.TenSanPham
                </h1>

                <h2 class="h3 mb-4">@Model.GiaTien.ToString("N0") VNĐ</h2>

                <div class="d-flex align-items-center gap-3 mb-5">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="GioHang" asp-action="ThemVaoGio" method="get" class="m-0">
                            <input type="hidden" name="sanPhamId" value="@Model.Id" />
                            <button type="submit" class="glass-btn rounded-pill px-4 py-3">
                                Thêm giỏ hàng <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </form>
                        <button class="glass-btn rounded-pill px-4 py-3">Mua ngay</button>

                        <button id="btnFavorite" type="button" class="glass-circle p-0" style="width: 53px; height: 53px;" data-id="@Model.Id" title="Yêu thích sản phẩm">
                            <i id="iconFavorite" class="bi @(ViewBag.IsFavorite == true ? "bi-heart-fill" : "bi-heart") fs-5"></i>
                        </button>
                    }
                    else
                    {
                        <a asp-controller="TaiKhoan" asp-action="DangNhap" class="glass-btn rounded-pill px-4 py-3">
                            <i class="bi bi-lock-fill me-2"></i> Đăng nhập mua
                        </a>
                        <a asp-controller="TaiKhoan" asp-action="DangNhap" class="glass-circle p-0" style="width: 53px; height: 53px;" title="Đăng nhập để lưu yêu thích">
                            <i class="bi bi-heart fs-5"></i>
                        </a>
                    }
                </div>

                <div class="d-flex gap-3 mb-4">
                    <div class="glass-circle" style="width: 45px; height: 45px;" title="Đảm bảo chất lượng"><i class="bi bi-award"></i></div>
                    <div class="glass-circle" style="width: 45px; height: 45px;" title="Thủ công tinh xảo"><i class="bi bi-stars"></i></div>
                    <div class="glass-circle" style="width: 45px; height: 45px;" title="Vật liệu tự nhiên"><i class="bi bi-leaf"></i></div>
                    <div class="glass-circle" style="width: 45px; height: 45px;" title="Giao hàng an toàn"><i class="bi bi-box-seam"></i></div>
                </div>
            </div>

            <div class="col-lg-6 text-center p-5">
                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/default-shell.png" : Model.HinhAnh)"
                     alt="@Model.TenSanPham"
                     class="img-fluid rounded-circle p-2"
                     style="width: 100%; max-width: 450px; aspect-ratio: 1/1; object-fit: cover; border: 1px solid var(--border-light); background: var(--glass-bg); backdrop-filter: var(--glass-blur);" />
            </div>
        </div>

        <div class="row p-5 pt-0 align-items-start">
            <div class="col-lg-6 d-flex flex-wrap gap-4">
                <div class="glass-card p-4 flex-fill" style="border-radius: 25px;">
                    <div class="glass-circle mb-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-gem fs-4"></i>
                    </div>
                    <h5 class="mb-1">Chất liệu</h5>
                    <p class="opacity-75 small mb-0">@Model.ChatLieu</p>
                </div>

                <div class="glass-card p-4 flex-fill" style="border-radius: 25px;">
                    <div class="glass-circle mb-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-ruler fs-4"></i>
                    </div>
                    <h5 class="mb-1">Kích thước</h5>
                    <p class="opacity-75 small mb-0">@Model.KichThuoc</p>
                </div>
            </div>

            <div class="col-lg-6 ps-lg-5 mt-4 mt-lg-0">
                <h3 class="mb-3">Thông tin chi tiết</h3>
                <p class="opacity-75" style="line-height: 1.8; font-size: 0.95rem;">
                    @Model.MoTa
                </p>
            </div>
        </div>
    </div>

    <div id="danh-gia" class="glass-card p-5">
        <h3 class="mb-4">Đánh giá từ khách hàng</h3>

        @if (User.Identity.IsAuthenticated)
        {
            @if (ViewBag.CanReview == true)
            {
                <div class="glass-card mb-5 p-4" style="border-radius: 20px;">
                    <h5 class="mb-3">Viết đánh giá của bạn</h5>
                    <form id="formDanhGia" asp-controller="SanPham" asp-action="ThemDanhGia" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SanPhamId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="small opacity-75 mb-2 ms-2">Đánh giá sao:</label>
                            <input type="hidden" name="SoSao" id="SoSaoHidden" required />

                            <div class="dropdown" style="max-width: 300px;">
                                <button class="glass-input text-start d-flex justify-content-between align-items-center w-100"
                                        type="button" data-bs-toggle="dropdown" id="SoSaoDropdownBtn" style="border: 1px solid var(--border-light) !important; border-radius: 12px !important;">
                                    -- Chọn số sao --
                                </button>
                                <ul class="dropdown-menu glass-dropdown w-100">
                                    <li><a class="dropdown-item glass-dropdown-item" href="#" data-value="5">★★★★★ (5 Sao)</a></li>
                                    <li><a class="dropdown-item glass-dropdown-item" href="#" data-value="4">★★★★ (4 Sao)</a></li>
                                    <li><a class="dropdown-item glass-dropdown-item" href="#" data-value="3">★★★ (3 Sao)</a></li>
                                    <li><a class="dropdown-item glass-dropdown-item" href="#" data-value="2">★★ (2 Sao)</a></li>
                                    <li><a class="dropdown-item glass-dropdown-item" href="#" data-value="1">★ (1 Sao)</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="small opacity-75 mb-2 ms-2">Nội dung:</label>
                            <textarea name="NoiDung" class="glass-input" rows="3" required placeholder="Chia sẻ cảm nhận của bạn..." style="border: 1px solid var(--border-light) !important; border-radius: 15px !important;"></textarea>
                        </div>

                        <button type="submit" class="glass-btn px-4 py-2">
                            <i class="bi bi-send me-2"></i> Gửi đánh giá
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="glass-card mb-5 p-4 text-center opacity-75">
                    <i class="bi bi-bag-check fs-1 d-block mb-2"></i>
                    <p class="mb-0">Chức năng đánh giá dành cho khách hàng đã nhận hàng thành công.</p>
                </div>
            }
        }
        else
        {
            <div class="glass-card mb-5 p-4 text-center">
                Vui lòng <a asp-controller="TaiKhoan" asp-action="DangNhap" class="text-decoration-underline">Đăng nhập</a> để viết đánh giá.
            </div>
        }

        @if (Model.DanhGias != null && Model.DanhGias.Any())
        {
            <div class="review-list">
                @foreach (var danhGia in Model.DanhGias.OrderByDescending(d => d.NgayDanhGia))
                {
                    <div class="pb-4 mb-4" style="border-bottom: 1px solid var(--border-light);">
                        <div class="d-flex align-items-center mb-2">
                            <div class="glass-circle me-3" style="width: 45px; height: 45px;">
                                <i class="bi bi-person fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">@(danhGia.NguoiDung?.HoTen ?? "Khách hàng ẩn danh")</h6>
                                <div class="small opacity-75 mt-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= danhGia.SoSao ? "bi-star-fill" : "bi-star") me-1"></i>
                                    }
                                    <span class="ms-2" style="font-size: 0.75rem;">@danhGia.NgayDanhGia.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>
                        <p class="opacity-75 mb-0 ps-5 small" style="line-height: 1.6;">
                            @danhGia.NoiDung
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 opacity-50">
                <i class="bi bi-chat-square-text" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Chưa có đánh giá nào</h5>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Dropdown sao
            const starItems = document.querySelectorAll('#danh-gia .dropdown-item');
            const hiddenInput = document.getElementById('SoSaoHidden');
            const dropdownBtn = document.getElementById('SoSaoDropdownBtn');

            starItems.forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    const value = this.getAttribute('data-value');
                    hiddenInput.value = value;
                    dropdownBtn.innerHTML = this.innerHTML;
                });
            });

            // Form Submit
            const formDanhGia = document.getElementById('formDanhGia');
            if(formDanhGia) {
                formDanhGia.addEventListener('submit', function (e) {
                    if (!hiddenInput.value) {
                        e.preventDefault();
                        alert('Vui lòng chọn số sao đánh giá!');
                    }
                });
            }

            // Favorite Toggle
            const btnFavorite = document.getElementById('btnFavorite');
            if (btnFavorite) {
                btnFavorite.addEventListener('click', function () {
                    const spId = this.getAttribute('data-id');
                    fetch(`/SanPham/ToggleFavorite?sanPhamId=${spId}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            const icon = document.getElementById('iconFavorite');
                            icon.className = data.isFavorite ? 'bi bi-heart-fill' : 'bi bi-heart';
                        } else if (data.message === "Vui lòng đăng nhập") {
                            window.location.href = '/TaiKhoan/DangNhap';
                        }
                    });
                });
            }
        });
    </script>
}