@model OceanShellCraft.Models.SanPham

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4" style="background-color: #f8f9fa; border-left: 5px solid #28a745 !important;">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-success mb-0">
                    <i class="fas fa-file-excel me-2"></i>Nhập Dữ Liệu Hàng Loạt
                </h5>
                <a asp-action="TaiFileMau" class="btn btn-outline-success btn-sm px-3 shadow-sm">
                    <i class="fas fa-download me-1"></i>Tải File Excel Mẫu
                </a>
            </div>

            <form asp-action="NhapExcel" method="post" enctype="multipart/form-data" class="row g-3 align-items-center">
                <div class="col-md-8">
                    <input type="file" name="file" class="form-control border-success" accept=".xlsx, .xls" required />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-success w-100 shadow-sm">
                        <i class="fas fa-upload me-1"></i>Bắt đầu Tải lên
                    </button>
                </div>
                <div class="col-12 mt-2">
                    <small class="text-muted italic">* Lưu ý: Đảm bảo các cột trong file Excel khớp hoàn toàn với file mẫu.</small>
                </div>
            </form>
        </div>
    </div>

    <div class="text-center my-4">
        <span class="px-3 bg-white text-muted fw-bold">HOẶC THÊM THỦ CÔNG</span>
        <hr style="margin-top: -12px;">
    </div>

    <div class="card shadow border-0 overflow-hidden">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 text-center text-uppercase">Thông Tin Sản Phẩm Mới</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="TaoMoi" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="TenSanPham" class="form-control" placeholder="VD: Đèn ngủ vỏ ốc" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Danh mục</label>
                        <select asp-for="DanhMucId" class="form-select border-primary" asp-items="ViewBag.MaDanhMuc"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá tiền (VNĐ)</label>
                        <input asp-for="GiaTien" type="number" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Chất liệu</label>
                        <input asp-for="ChatLieu" class="form-control" placeholder="VD: Vỏ ốc xà cừ" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(event)" />
                        <div class="mt-3 text-center">
                            <img id="imgPreview" src="#" alt="Xem trước"
                                 style="max-width: 180px; display: none; border-radius: 12px; border: 2px solid #ddd;"
                                 class="shadow-sm" />
                        </div>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả sản phẩm..."></textarea>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3 d-flex justify-content-between">
                    <a asp-action="DanhSach" class="btn btn-light border px-4 text-muted">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary px-5 shadow">
                        <i class="fas fa-save me-2"></i>Lưu Sản Phẩm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const reader = new FileReader();
            const output = document.getElementById('imgPreview');
            reader.onload = function() {
                output.src = reader.result;
                output.style.display = 'inline-block';
            };
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}