@using System.Security.Claims
@inject OceanShellCraft.Models.MyNgheDbContext _context
@{
    string maPhien = Context.Request.Cookies["MaPhienGioHang"];
    var soLuongGioHang = !string.IsNullOrEmpty(maPhien) ? _context.GioHangs.Where(g => g.MaPhien == maPhien).Sum(g => (int?)g.SoLuong) ?? 0 : 0;
}

<header class="glass-effect w-100 position-relative shadow-sm" style="z-index: 2000;">
    <div class="container-fluid px-lg-5">
        <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10 small">
            <div class="d-none d-md-block opacity-75 fw-light" style="letter-spacing: 1px;">
                <i class="bi bi-stars me-2"></i>Tinh hoa từ biển cả
            </div>
            <div class="d-flex gap-3 ms-auto">
                <a href="#" class="text-white opacity-75 text-decoration-none"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-white opacity-75 text-decoration-none"><i class="bi bi-instagram"></i></a>
            </div>
        </div>

        <div class="row align-items-center py-3">
            <div class="col-6 col-lg-3">
                <a asp-controller="TrangChu" asp-action="TrangChu" class="d-inline-block logo-hover text-decoration-none">
                    <img src="/img/logo.png" alt="Logo" class="img-fluid" style="height: 55px; filter: drop-shadow(0 0 10px rgba(255,255,255,0.1));">
                </a>
            </div>

            <div class="col-lg-5 d-none d-lg-block">
                <form action="/Search" method="get" class="input-group input-group-sm mx-auto w-100" style="max-width: 450px;">
                    <input type="search" name="query" class="form-control bg-transparent border-white border-opacity-25 text-white shadow-none px-4 rounded-start-pill" placeholder="Tìm sản phẩm...">
                    <button class="btn btn-outline-light border-white border-opacity-25 px-4 rounded-end-pill border-start-0" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>

            <div class="col-6 col-lg-4 d-flex justify-content-end align-items-center gap-4">
                <a href="#" class="text-white fs-5 d-none d-sm-inline-block text-decoration-none opacity-75"><i class="bi bi-heart-pulse"></i></a>

                <div class="dropdown">
                    <a class="text-white opacity-75 text-decoration-none d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle fs-4"></i> @if (User.Identity.IsAuthenticated)
                        {
                            <span class="ms-2 d-none d-xl-inline small opacity-75">@User.Identity.Name</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end glass-effect border-white border-opacity-10 mt-2 p-2 shadow-lg">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li><a class="dropdown-item rounded-2" asp-controller="KhachHang" asp-action="TongQuan">Cài đặt</a></li>
                            <li><hr class="dropdown-divider opacity-10"></li>
                            <li><a class="dropdown-item text-danger fw-bold" asp-controller="TaiKhoan" asp-action="DangXuat">Đăng xuất</a></li>
                        }
                        else
                        {
                            <li><a class="dropdown-item rounded-2" asp-controller="TaiKhoan" asp-action="DangNhap">Đăng nhập</a></li>
                            <li><a class="dropdown-item rounded-2" asp-controller="TaiKhoan" asp-action="DangKy">Đăng ký thành viên</a></li>
                        }
                    </ul>
                </div>

                <a asp-controller="GioHang" asp-action="DanhSach" class="text-white position-relative fs-4 opacity-75 text-decoration-none">
                    <i class="bi bi-cart3"></i> @if (soLuongGioHang > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-white text-dark fw-bold px-2" style="font-size: 0.6rem;">
                            @soLuongGioHang
                        </span>
                    }
                </a>
            </div>
        </div>
    </div>
</header>

<nav class="sticky-top glass-effect border-top border-bottom border-white border-opacity-10 py-1" style="z-index: 1000;">
    <div class="container">
        <div class="navbar navbar-expand-lg p-0">
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav flex-row gap-lg-5 py-2">
                    <li class="nav-item"><a class="nav-link nav-link-glass text-uppercase small fw-semibold px-3" asp-controller="TrangChu" asp-action="TrangChu">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-glass text-uppercase small fw-semibold px-4" asp-controller="SanPham" asp-action="DanhSach">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-glass text-uppercase small fw-semibold px-3" asp-controller="TrangChu" asp-action="GioiThieu">Giới thiệu</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-glass text-uppercase small fw-semibold px-3" asp-controller="BaiViet" asp-action="DanhSach">Nghệ thuật vỏ ốc</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>