@using System.Security.Claims
@inject OceanShellCraft.Models.MyNgheDbContext _context
@{
    string maPhien = Context.Request.Cookies["MaPhienGioHang"];
    var soLuongGioHang = !string.IsNullOrEmpty(maPhien) ? _context.GioHangs.Where(g => g.MaPhien == maPhien).Sum(g => (int?)g.SoLuong) ?? 0 : 0;
}

<header class="glass-effect w-100 position-relative p-0" style="z-index: 2000; border-top: none; border-left: none; border-right: none; border-radius: 0;">
    <div class="container-fluid px-lg-5">

        <div class="d-flex justify-content-between align-items-center py-2 small" style="border-bottom: 1px solid var(--border-light);">
            <div class="d-none d-md-block" style="letter-spacing: 1px;">
                <i class="bi bi-stars me-2"></i>Tinh hoa từ biển cả
            </div>
            <div class="d-flex gap-2 ms-auto">
                <a href="#" class="glass-circle" style="width: 30px; height: 30px;"><i class="bi bi-facebook"></i></a>
                <a href="#" class="glass-circle" style="width: 30px; height: 30px;"><i class="bi bi-instagram"></i></a>
            </div>
        </div>

        <div class="row align-items-center py-3">

            <div class="col-6 col-lg-3">
                <a asp-controller="TrangChu" asp-action="TrangChu" class="d-inline-block text-decoration-none">
                    <img src="/img/logo.png" alt="logo" class="img-fluid" style="height: 55px; filter: drop-shadow(0 0 10px rgba(255,255,255,0.1));">
                </a>
            </div>

            <div class="col-lg-5 d-none d-lg-block">
                <form action="/Search" method="get" class="d-flex mx-auto w-100" style="max-width: 450px;">
                    <input type="search" name="query" class="glass-input m-0" style="border-radius: 50px 0 0 50px; border: 1px solid var(--border-light) !important; border-right: none !important; padding: 8px 20px;" placeholder="Tìm sản phẩm...">
                    <button class="glass-btn m-0" style="border-radius: 0 50px 50px 0; padding: 8px 20px;" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>

            <div class="col-6 col-lg-4 d-flex justify-content-end align-items-center gap-4">

                <a asp-controller="KhachHang" asp-action="SanPhamYeuThich" class="fs-5 d-none d-sm-inline-block text-decoration-none">
                    <i class="bi bi-heart"></i>
                </a>

                <div class="dropdown">
                    <a class="text-decoration-none d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle fs-4"></i>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="ms-2 d-none d-xl-inline small">@User.Identity.Name.ToLower()</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end glass-dropdown mt-2 p-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li><a class="dropdown-item glass-dropdown-item" asp-controller="KhachHang" asp-action="TongQuan">Cài đặt</a></li>
                            <li><hr class="dropdown-divider" style="border-color: var(--border-light);"></li>
                            <li><a class="dropdown-item glass-dropdown-item" asp-controller="TaiKhoan" asp-action="DangXuat">Đăng xuất</a></li>
                        }
                        else
                        {
                            <li><a class="dropdown-item glass-dropdown-item" asp-controller="TaiKhoan" asp-action="DangNhap">Đăng nhập</a></li>
                            <li><a class="dropdown-item glass-dropdown-item" asp-controller="TaiKhoan" asp-action="DangKy">Đăng ký</a></li>
                        }
                    </ul>
                </div>

                <a asp-controller="GioHang" asp-action="DanhSach" class="position-relative fs-4 text-decoration-none">
                    <i class="bi bi-cart3"></i>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill" style="font-size: 0.6rem; background: var(--glass-bg); backdrop-filter: var(--glass-blur); border: 1px solid var(--border-light);">
                            @soLuongGioHang
                        </span>
                    }
                </a>
            </div>
        </div>
    </div>
</header>

<nav class="sticky-top glass-effect py-1" style="z-index: 1000; border-left: none; border-right: none; border-radius: 0;">
    <div class="container">
        <div class="navbar navbar-expand-lg p-0">
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav flex-row gap-lg-4 py-2">
                    <li class="nav-item">
                        <a class="nav-link px-4" asp-controller="TrangChu" asp-action="TrangChu" style="border: none !important;">TRANG CHỦ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-4" asp-controller="SanPham" asp-action="DanhSach" style="border: none !important;">SẢN PHẨM</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-4" asp-controller="TrangChu" asp-action="GioiThieu" style="border: none !important;">GIỚI THIỆU</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-4" asp-controller="BaiViet" asp-action="DanhSach" style="border: none !important;">BÀI VIẾT</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>