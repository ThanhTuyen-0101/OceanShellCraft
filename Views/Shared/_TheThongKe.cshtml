@model IEnumerable<dynamic>

<div class="row g-4 mb-4">
    @foreach (var item in Model)
    {
        <div class="col-xl-3 col-md-6">
            <div class="glass-card p-4 h-100 d-flex flex-column justify-content-center" style="border-radius: 20px !important;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-50 small mb-2">@item.TieuDe</h6>
                        <h3 class="fw-bold m-0">@item.GiaTri</h3>
                    </div>
                    <div class="@item.Opacity">
                        <i class="bi @item.Icon fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    }
</div>