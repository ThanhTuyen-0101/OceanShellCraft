<div class="position-fixed d-flex flex-column gap-3" style="bottom: 30px; right: 30px; z-index: 9999;">
    <button id="liveChatToggleBtn" class="glass-circle position-relative shadow-lg" style="width: 60px; height: 60px;" title="Chat với nhân viên">
        <i class="bi bi-headset fs-3"></i>
        <span class="position-absolute top-0 start-100 translate-middle p-2 bg-success rounded-circle" style="border: 2px solid var(--border-light);"></span>
    </button>
</div>

<div id="liveChatWindow" class="glass-card position-fixed d-none p-0 d-flex flex-column" style="bottom: 30px; right: 110px; width: 350px; height: 500px; z-index: 9999; overflow: hidden;">

    <div class="px-3 py-3 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid var(--border-light);">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-headset fs-5 text-success"></i>
            <h6 class="mb-0">Hỗ trợ viên trực tuyến</h6>
        </div>
        <button id="liveChatCloseBtn" class="glass-btn border-0 p-1" style="border-radius: 50%; width: 30px; height: 30px;">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="p-3 overflow-auto hide-scrollbar" id="liveChatBody" style="flex: 1;">
        <div class="d-flex mb-3 justify-content-start">
            <div class="chat-bubble-sm received-sm" style="max-width: 85%;">
                Chào bạn, mình là nhân viên hỗ trợ của OceanShellCraft. Bạn cần tư vấn về sản phẩm nào ạ?
            </div>
        </div>
    </div>

    <div class="px-3 py-3 d-flex gap-2" style="border-top: 1px solid var(--border-light);">
        <input type="text" id="liveChatInput" class="glass-input pill-style flex-grow-1" placeholder="Nhập tin nhắn...">
        <button class="glass-circle" type="button" id="liveChatSendBtn" style="flex-shrink: 0;">
            <i class="bi bi-send"></i>
        </button>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const liveToggleBtn = document.getElementById('liveChatToggleBtn');
        const liveWindow = document.getElementById('liveChatWindow');
        const liveCloseBtn = document.getElementById('liveChatCloseBtn');
        const liveInput = document.getElementById('liveChatInput');
        const liveSendBtn = document.getElementById('liveChatSendBtn');
        const liveBody = document.getElementById('liveChatBody');

        // Bật/Tắt Cửa Sổ
        liveToggleBtn.addEventListener('click', () => {
            liveWindow.classList.toggle('d-none');
        });

        liveCloseBtn.addEventListener('click', () => {
            liveWindow.classList.add('d-none');
        });

        // Hàm in tin nhắn (Đã cập nhật class theo file CSS chuẩn)
        function appendMessage(chatBody, text, isUser) {
            const align = isUser ? 'justify-content-end' : 'justify-content-start';
            const bubbleClass = isUser ? 'sent-sm' : 'received-sm';

            const msgHTML = `
                <div class="d-flex mb-3 ${align}">
                    <div class="chat-bubble-sm ${bubbleClass}" style="max-width: 85%;">
                        ${text}
                    </div>
                </div>
            `;
            chatBody.insertAdjacentHTML('beforeend', msgHTML);
            chatBody.scrollTop = chatBody.scrollHeight;
        }

        // Gửi tin nhắn
        function sendLiveMessage() {
            const text = liveInput.value.trim();
            if (text !== '') {
                appendMessage(liveBody, text, true); // True = User gửi
                liveInput.value = '';
                // Logic giả lập nhân viên trả lời sau 1 giây
                /*
                setTimeout(() => {
                    appendMessage(liveBody, "Mình đang kiểm tra thông tin, bạn đợi chút nhé.", false);
                }, 1000);
                */
            }
        }

        liveSendBtn.addEventListener('click', sendLiveMessage);
        liveInput.addEventListener('keypress', e => {
            if (e.key === 'Enter') sendLiveMessage();
        });
    });
</script>