<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OceanShellCraft</title>

    @* Bootstrap 5 CSS *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @* 1. Bootstrap Icons *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @* 2. Font Awesome *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    @* 3. Font chữ Be Vietnam Pro *@
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;600;700&display=swap" rel="stylesheet">

    @* CSS Mặc định của Web *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* CSS GIAO DIỆN BIỂN ĐẠI DƯƠNG *@
    <link rel="stylesheet" href="~/css/ocean-theme.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    @* Kiểm tra nếu không yêu cầu ẩn thì mới gọi Header *@
    @if (ViewData["HideHeaderFooter"] == null)
    {
        <partial name="_Header" />
    }

    @* Phần thân tràn viền full màn hình *@
    <div class="flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @* Kiểm tra nếu không yêu cầu ẩn thì mới gọi Footer và Chat Widget *@
    @if (ViewData["HideHeaderFooter"] == null)
    {
        <partial name="_Footer" />

        <partial name="_ChatWidget" />
    }

    @* JavaScript cơ bản *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* 4. Nơi chứa Script của từng trang *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>