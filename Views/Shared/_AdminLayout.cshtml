<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin OceanShell</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="overflow-hidden p-0 m-0 bg-dark text-white">

    <div id="admin-layout" class="d-flex flex-nowrap vh-100 vw-100 p-3 gap-4">

        <aside class="glass-effect d-flex flex-column align-items-center py-4 h-100" style="width: 85px; flex-shrink: 0; z-index: 10; border-radius: 30px !important;">

            <a href="/admin" class="text-decoration-none mb-4 d-flex justify-content-center" title="Trang chủ Ocean">
                <img src="/img/logo.png" alt="Ocean Logo" style="width: 45px; height: 45px; object-fit: contain;" />
            </a>

            <nav class="flex-grow-1 overflow-auto hide-scrollbar w-100 mt-2">
                <ul class="nav flex-column gap-4 align-items-center mb-auto list-unstyled">
                    <li class="nav-item">
                        <a href="/admin" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Tổng quan">
                            <i class="bi bi-grid-1x2-fill"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/bai-viet" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Bài viết">
                            <i class="bi bi-journal-text"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/san-pham" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Sản phẩm">
                            <i class="bi bi-box-seam"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/giam-gia" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Mã giảm giá">
                            <i class="bi bi-ticket-perforated"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/nguoi-dung" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Người dùng">
                            <i class="bi bi-people"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/hoa-don" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Hóa đơn">
                            <i class="bi bi-receipt"></i>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/admin/quan-ly-danh-muc" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Danh mục">
                            <i class="bi bi-tags"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/admin/quan-ly-bien-the" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Biến thể">
                            <i class="bi bi-collection"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Vận chuyển">
                            <i class="bi bi-truck"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center" title="Phân quyền">
                            <i class="bi bi-shield-lock"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="mt-auto d-flex flex-column gap-4 align-items-center w-100 pt-3">
                <div class="dropup d-flex justify-content-center">
                    <a href="#" class="text-decoration-none text-white fs-3 opacity-hover" data-bs-toggle="dropdown" aria-expanded="false" title="Tài khoản">
                        <img src="/img/logo.png" alt="User" class="rounded-circle" style="width: 35px; height: 35px; background: rgba(255,255,255,0.2); padding: 5px;">
                    </a>
                    <ul class="dropdown-menu glass-dropdown mb-2 border-0 shadow" style="min-width: 180px; margin-left: 20px;">
                        <li><a class="dropdown-item text-white d-flex align-items-center gap-2 opacity-hover" href="#"><i class="bi bi-person-vcard"></i> Hồ sơ</a></li>
                        <li><hr class="dropdown-divider bg-light opacity-25 my-1"></li>
                        <li><a class="dropdown-item text-danger d-flex align-items-center gap-2 opacity-hover" href="#"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </aside>

        <main class="flex-grow-1 h-100 overflow-auto hide-scrollbar" style="z-index: 5;">
            @RenderBody()
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>