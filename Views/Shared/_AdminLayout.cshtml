<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin OceanShellCraft</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="overflow-hidden p-0 m-0">

    <div class="d-flex flex-nowrap vh-100 vw-100">

        <div class="glass-effect d-flex flex-column p-4 h-100" style="width: 280px; z-index: 10;">

            <a href="/" class="d-flex align-items-center mb-5 text-decoration-none text-white px-2">
                <span class="fs-4 fw-light">Admin</span>
            </a>

            <ul class="nav flex-column gap-2 mb-4">
                <li class="nav-item">
                    <a href="/Admin" class="glass-btn w-100 d-flex align-items-center justify-content-start ps-4 py-2 border-0 bg-transparent text-decoration-none text-white">
                        <i class="bi bi-grid-1x2-fill me-3"></i>
                        <span>Tổng quan</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="#collapseManagement"
                       class="glass-btn w-100 d-flex align-items-center justify-content-between ps-4 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white"
                       data-bs-toggle="collapse"
                       role="button">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-collection-fill me-3"></i>
                            <span>Quản lý</span>
                        </div>
                        <i class="bi bi-chevron-down small pe-3"></i>
                    </a>

                    <div class="collapse" id="collapseManagement">
                        <ul class="nav flex-column mt-1 gap-1">
                            <li class="nav-item">
                                <a href="/Admin/BaiViet" class="glass-btn w-100 d-flex align-items-center ps-5 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                                    <i class="bi bi-journal-text me-3"></i>
                                    <span>Bài viết</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/Admin/SanPham" class="glass-btn w-100 d-flex align-items-center ps-5 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                                    <i class="bi bi-box-seam me-3"></i>
                                    <span>Sản phẩm</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/Admin/GiamGia" class="glass-btn w-100 d-flex align-items-center ps-5 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                                    <i class="bi bi-box-seam me-3"></i>
                                    <span>Mã giảm giá</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/Admin/NguoiDung" class="glass-btn w-100 d-flex align-items-center ps-5 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                                    <i class="bi bi-box-seam me-3"></i>
                                    <span>Người dùng</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="nav-item">
                    <a href="/Admin/Chat" class="glass-btn w-100 d-flex align-items-center justify-content-start ps-4 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                        <i class="bi bi-chat-dots me-3"></i>
                        <span>Trò chuyện</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Admin/HoaDon" class="glass-btn w-100 d-flex align-items-center justify-content-start ps-4 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                        <i class="bi bi-receipt me-3"></i>
                        <span>Hóa đơn</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Admin/CaiDat" class="glass-btn w-100 d-flex align-items-center justify-content-start ps-4 py-2 opacity-75 border-0 bg-transparent text-decoration-none text-white">
                        <i class="bi bi-gear me-3"></i>
                        <span>Cài đặt</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="glass-effect flex-grow-1 p-4 p-md-5 d-flex flex-column h-100 overflow-auto border-start-0" style="z-index: 5;">
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>