@using System.Security.Claims
@inject OceanShellCraft.Models.MyNgheDbContext _context

@{
    var isAuthenticated = User.Identity.IsAuthenticated;
    var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    OceanShellCraft.Models.NguoiDung currentUser = null;
    List<OceanShellCraft.Models.TinNhan> chatHistory = new List<OceanShellCraft.Models.TinNhan>();

    if (isAuthenticated && !string.IsNullOrEmpty(userIdClaim) && int.TryParse(userIdClaim, out int uId))
    {
        currentUser = _context.NguoiDungs.FirstOrDefault(u => u.Id == uId);
        chatHistory = _context.TinNhans
                            .Where(t => t.NguoiDungId == uId)
                            .OrderBy(t => t.ThoiGian)
                            .ToList();
    }

    var hoTen = currentUser?.HoTen ?? "Khách hàng";
    var vaiTro = currentUser?.VaiTro ?? "Thành viên";
    var anhDaiDien = (currentUser != null && !string.IsNullOrEmpty(currentUser.AnhDaiDien))
                     ? currentUser.AnhDaiDien : "/img/meo.jpg";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OceanShellCraft</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        /* Đảm bảo giao diện tối nhất quán */
        body {
            background-color: #0f1014;
            color: white;
        }

        .glass-effect {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .nav-link.active {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            opacity: 1 !important;
        }

        .opacity-hover:hover {
            opacity: 1 !important;
            transform: scale(1.1);
            transition: all 0.2s;
        }

        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="overflow-hidden p-0 m-0">

    <div id="customer-layout" class="d-flex flex-nowrap vh-100 vw-100 p-3 gap-4">

        @* SIDEBAR: Tương tự Admin (Slim Sidebar) *@
        <aside class="glass-effect d-flex flex-column align-items-center py-4 h-100" style="width: 85px; flex-shrink: 0; z-index: 10; border-radius: 30px;">

            @* Logo *@
            <a asp-controller="TrangChu" asp-action="TrangChu" class="text-decoration-none mb-4 d-flex justify-content-center" title="Về trang chủ">
                <img src="/img/logo.png" alt="Ocean Logo" style="width: 45px; height: 45px; object-fit: contain;" />
            </a>

            @* Navigation Icons *@
            <nav class="flex-grow-1 overflow-auto hide-scrollbar w-100 mt-2">
                <ul class="nav flex-column gap-4 align-items-center mb-auto list-unstyled">
                    <li class="nav-item">
                        <a asp-controller="KhachHang" asp-action="TongQuan"
                           class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center @(ViewContext.RouteData.Values["Action"]?.ToString() == "TongQuan" ? "active" : "opacity-50")"
                           title="Tổng quan">
                            <i class="bi bi-grid-1x2-fill"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="KhachHang" asp-action="Orders"
                           class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center @(ViewContext.RouteData.Values["Action"]?.ToString() == "Orders" ? "active" : "opacity-50")"
                           title="Đơn hàng">
                            <i class="bi bi-box-seam"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="KhachHang" asp-action="SanPhamYeuThich"
                           class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center @(ViewContext.RouteData.Values["Action"]?.ToString() == "SanPhamYeuThich" ? "active" : "opacity-50")"
                           title="Sản phẩm yêu thích">
                            <i class="bi bi-heart-fill"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="KhachHang" asp-action="Chat"
                           class="nav-link text-white p-2 fs-5 opacity-hover d-flex align-items-center justify-content-center @(ViewContext.RouteData.Values["Action"]?.ToString() == "Chat" ? "active" : "opacity-50")"
                           title="Trò chuyện">
                            <i class="bi bi-chat-dots-fill"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            @* User Profile Dropup (Giống Admin) *@
            <div class="mt-auto d-flex flex-column gap-4 align-items-center w-100 pt-3">
                <div class="dropup d-flex justify-content-center">
                    <a href="#" class="text-decoration-none text-white opacity-hover" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="@anhDaiDien" alt="User" class="rounded-circle shadow" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid rgba(255,255,255,0.2);">
                    </a>
                    <ul class="dropdown-menu glass-dropdown mb-2 border-0 shadow text-small" style="min-width: 200px; background: rgba(20,20,20,0.9); backdrop-filter: blur(10px);">
                        <li class="px-3 py-2 border-bottom border-secondary border-opacity-25">
                            <p class="text-white mb-0 small fw-bold">@hoTen</p>
                            <p class="text-white-50 mb-0" style="font-size: 0.7rem;">@vaiTro</p>
                        </li>
                        <li><a class="dropdown-item text-white py-2" href="#"><i class="bi bi-person me-2"></i> Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item text-white py-2" href="#"><i class="bi bi-gear me-2"></i> Cài đặt</a></li>
                        <li><hr class="dropdown-divider bg-light opacity-10"></li>
                        <li><a class="dropdown-item text-danger py-2" href="/dang-xuat"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </aside>

        @* MAIN CONTENT *@
        <main class="flex-grow-1 h-100 overflow-auto hide-scrollbar glass-effect" style="z-index: 5; border-radius: 40px; padding: 40px;">
            @RenderBody()
        </main>

    </div>

    @* NÚT CHAT FLOATING (Giữ lại logic SignalR của bạn) *@
    <div class="position-fixed" style="bottom: 40px; right: 40px; z-index: 9999;">
        <button id="liveChatToggleBtn" class="glass-circle shadow-lg position-relative border-0"
                style="width: 65px; height: 65px; background: linear-gradient(135deg, #0d6efd, #00d2ff); color: white;">
            <i class="bi bi-headset fs-3"></i>
            @if (isAuthenticated)
            {
                <span class="position-absolute top-0 start-100 translate-middle p-2 bg-success border border-light rounded-circle"></span>
            }
        </button>
    </div>

    @* CỬA SỔ CHAT *@
    <div id="liveChatWindow" class="glass-card position-fixed d-none flex-column shadow-lg"
         style="bottom: 120px; right: 40px; width: 380px; height: 550px; z-index: 9999; border-radius: 30px; overflow: hidden; background: rgba(15,15,15,0.9); border: 1px solid rgba(255,255,255,0.1);">

        <div class="px-4 py-3 d-flex justify-content-between align-items-center bg-white bg-opacity-10">
            <h6 class="mb-0 fw-bold">Ocean Support</h6>
            <button id="liveChatCloseBtn" class="btn-close btn-close-white small"></button>
        </div>

        <div class="p-4 overflow-auto hide-scrollbar flex-grow-1" id="liveChatBody">
            @if (isAuthenticated)
            {
                @foreach (var msg in chatHistory)
                {
                    bool isMe = !msg.IsAdmin;
                    <div class="d-flex mb-4 @(isMe ? "justify-content-end" : "justify-content-start")">
                        <div class="chat-bubble-sm p-3 @(isMe ? "sent-sm" : "received-sm")" style="max-width: 80%; border-radius: 20px;">
                            @msg.NoiDung
                            <div class="mt-1 opacity-50 text-end" style="font-size: 0.6rem;">@msg.ThoiGian.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-5">
                    <i class="bi bi-lock fs-1 opacity-25"></i>
                    <p class="mt-3">Vui lòng đăng nhập để trao đổi với chúng tôi</p>
                    <a href="/dang-nhap" class="btn btn-primary rounded-pill px-4">Đăng nhập</a>
                </div>
            }
        </div>

        @if (isAuthenticated)
        {
            <div class="px-4 py-3 bg-white bg-opacity-5 d-flex gap-2 align-items-center">
                <input type="text" id="liveChatInput" class="form-control bg-transparent text-white border-0" placeholder="Aa...">
                <button class="btn btn-primary rounded-circle" id="liveChatSendBtn"><i class="bi bi-send-fill"></i></button>
            </div>
        }
    </div>

    @* SCRIPTS *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isAuthenticated = @isAuthenticated.ToString().ToLower();
            const liveToggleBtn = document.getElementById('liveChatToggleBtn');
            const chatWin = document.getElementById('liveChatWindow');
            const widgetBody = document.getElementById('liveChatBody');

            if (liveToggleBtn) {
                liveToggleBtn.onclick = () => {
                    if (!isAuthenticated) {
                        window.location.href = '/dang-nhap';
                        return;
                    }
                    chatWin.classList.toggle('d-none');
                    if (widgetBody) widgetBody.scrollTop = widgetBody.scrollHeight;
                };
            }

            document.getElementById('liveChatCloseBtn').onclick = () => chatWin.classList.add('d-none');

            if (isAuthenticated) {
                const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").withAutomaticReconnect().build();
                connection.start().catch(err => console.error(err));

                connection.on("ReceiveMessage", function (userId, userName, message, role, time) {
                    const isMe = (role === "KhachHang");
                    if(widgetBody) {
                        const htmlWidget = `<div class="d-flex mb-4 ${isMe ? 'justify-content-end' : 'justify-content-start'} animate__animated animate__fadeIn">
                            <div class="chat-bubble-sm p-3 ${isMe ? 'sent-sm' : 'received-sm'}" style="max-width: 80%; border-radius: 20px;">
                                ${message}
                                <div class="mt-1 opacity-50 text-end" style="font-size: 0.6rem;">${time}</div>
                            </div>
                        </div>`;
                        widgetBody.insertAdjacentHTML('beforeend', htmlWidget);
                        widgetBody.scrollTop = widgetBody.scrollHeight;
                    }
                });

                async function sendMessage(inputId) {
                    const input = document.getElementById(inputId);
                    if (input && input.value.trim()) {
                        await connection.invoke("CustomerSendMessage", input.value.trim());
                        input.value = '';
                    }
                }

                document.getElementById('liveChatSendBtn')?.addEventListener('click', () => sendMessage('liveChatInput'));
                document.getElementById('liveChatInput')?.addEventListener('keypress', e => { if(e.key === 'Enter') sendMessage('liveChatInput'); });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>