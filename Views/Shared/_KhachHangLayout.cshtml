@using System.Security.Claims
@inject OceanShellCraft.Models.MyNgheDbContext _context

@{
    var isAuthenticated = User.Identity.IsAuthenticated;
    var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    OceanShellCraft.Models.NguoiDung currentUser = null;
    List<OceanShellCraft.Models.TinNhan> chatHistory = new List<OceanShellCraft.Models.TinNhan>();

    if (isAuthenticated && !string.IsNullOrEmpty(userIdClaim) && int.TryParse(userIdClaim, out int uId))
    {
        currentUser = _context.NguoiDungs.FirstOrDefault(u => u.Id == uId);
        chatHistory = _context.TinNhans
                              .Where(t => t.NguoiDungId == uId)
                              .OrderBy(t => t.ThoiGian)
                              .ToList();
    }

    // Bỏ .ToLower() để giữ đúng chữ hoa/chữ thường của Tên và Vai trò
    var hoTen = currentUser?.HoTen ?? "Khách hàng";
    var vaiTro = currentUser?.VaiTro ?? "Thành viên";
    var anhDaiDien = (currentUser != null && !string.IsNullOrEmpty(currentUser.AnhDaiDien))
                     ? currentUser.AnhDaiDien : "/img/meo.jpg";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OceanShellCraft</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="overflow-hidden m-0 p-0">

    <div class="d-flex flex-nowrap vh-100 vw-100">

        <div class="glass-effect d-flex flex-column p-4 h-100" style="width: 280px; z-index: 10; border-top: none; border-bottom: none; border-left: none;">

            <a asp-controller="TrangChu" asp-action="TrangChu" class="d-flex align-items-center mb-4 text-decoration-none">
                <span class="fs-3 me-2"><i class="bi bi-droplet-half"></i></span>
                <span class="fs-4">OceanShellCraft</span>
            </a>

            <ul class="nav flex-column gap-3 mb-4 overflow-auto hide-scrollbar flex-grow-1">
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="TongQuan" class="glass-btn w-100 text-start justify-content-start @(ViewContext.RouteData.Values["Action"]?.ToString() == "TongQuan" ? "opacity-100" : "opacity-75")">
                        <i class="bi bi-grid-1x2 me-3"></i> Tổng quan
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="Orders" class="glass-btn w-100 text-start justify-content-start @(ViewContext.RouteData.Values["Action"]?.ToString() == "Orders" ? "opacity-100" : "opacity-75")">
                        <i class="bi bi-box-seam me-3"></i> Đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="SanPhamYeuThich" class="glass-btn w-100 text-start justify-content-start @(ViewContext.RouteData.Values["Action"]?.ToString() == "SanPhamYeuThich" ? "opacity-100" : "opacity-75")">
                        <i class="bi bi-heart me-3"></i> Yêu thích
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="Chat" class="glass-btn w-100 text-start justify-content-start @(ViewContext.RouteData.Values["Action"]?.ToString() == "Chat" ? "opacity-100" : "opacity-75")">
                        <i class="bi bi-chat-dots me-3"></i> Chat
                    </a>
                </li>
            </ul>

            <div class="mt-auto text-center p-3 glass-card">
                <img src="@anhDaiDien" alt="user" class="rounded-circle mb-2" width="60" height="60" style="object-fit: cover; border: 1px solid var(--border-light);">
                <h6 class="mb-0">@hoTen</h6>
                <small class="opacity-75 d-block mb-3"><i class="bi bi-star-fill"></i> @vaiTro</small>
                <a asp-controller="TaiKhoan" asp-action="DangXuat" class="glass-btn w-100">
                    <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="glass-effect flex-grow-1 p-4 p-md-5 d-flex flex-column h-100 overflow-auto hide-scrollbar border-start-0" style="z-index: 5;">
            @RenderBody()
        </div>
    </div>

    <div class="position-fixed d-flex flex-column gap-3" style="bottom: 30px; right: 30px; z-index: 9999;">
        <button id="liveChatToggleBtn" class="glass-circle shadow-lg position-relative" style="width: 60px; height: 60px;" title="Chat với nhân viên">
            <i class="bi bi-headset fs-3"></i>
            @if (isAuthenticated)
            {
                <span class="position-absolute top-0 start-100 translate-middle p-2 bg-success rounded-circle" style="border: 2px solid var(--border-light);"></span>
            }
        </button>
    </div>

    <div id="liveChatWindow" class="glass-card position-fixed d-none p-0 d-flex flex-column shadow-lg" style="bottom: 30px; right: 110px; width: 350px; height: 500px; z-index: 9999; overflow: hidden;">

        <div class="px-3 py-3 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid var(--border-light);">
            <h6 class="mb-0">Hỗ trợ trực tuyến</h6>
            <button id="liveChatCloseBtn" class="glass-btn border-0 p-1" style="border-radius: 50%; width: 30px; height: 30px;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="p-3 overflow-auto hide-scrollbar flex-grow-1" id="liveChatBody">
            @if (isAuthenticated)
            {
                @foreach (var msg in chatHistory)
                {
                    bool isMe = !msg.IsAdmin;
                    <div class="d-flex mb-3 @(isMe ? "justify-content-end" : "justify-content-start")">
                        <div class="chat-bubble-sm @(isMe ? "sent-sm" : "received-sm")" style="max-width: 85%;">
                            @msg.NoiDung
                            <div class="mt-1 opacity-50 text-end" style="font-size: 0.6rem;">@msg.ThoiGian.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-4">
                    <p class="small">Vui lòng đăng nhập để bắt đầu trò chuyện</p>
                    <a href="/TaiKhoan/DangNhap" class="glass-btn">Đăng nhập ngay</a>
                </div>
            }
        </div>

        @if (isAuthenticated)
        {
            <div class="px-3 py-3 d-flex gap-2" style="border-top: 1px solid var(--border-light);">
                <input type="text" id="liveChatInput" class="glass-input pill-style flex-grow-1" placeholder="Nhập tin nhắn...">
                <button class="glass-circle" id="liveChatSendBtn" style="flex-shrink: 0;"><i class="bi bi-send"></i></button>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const isAuthenticated = @isAuthenticated.ToString().ToLower();

            const liveToggleBtn = document.getElementById('liveChatToggleBtn');
            const chatWin = document.getElementById('liveChatWindow');
            const widgetBody = document.getElementById('liveChatBody');

            liveToggleBtn.onclick = () => {
                if (!isAuthenticated) {
                    window.location.href = '/TaiKhoan/DangNhap';
                    return;
                }
                chatWin.classList.toggle('d-none');
                if (widgetBody) widgetBody.scrollTop = widgetBody.scrollHeight;
            };

            document.getElementById('liveChatCloseBtn').onclick = () => chatWin.classList.add('d-none');

            if (isAuthenticated) {
                const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").withAutomaticReconnect().build();
                connection.start().catch(err => console.error(err));

                connection.on("ReceiveMessage", function (userId, userName, message, role, time) {
                    const isMe = (role === "KhachHang");

                    // Render cho Mini Chat Widget
                    if(widgetBody) {
                        const htmlWidget = `<div class="d-flex mb-3 ${isMe ? 'justify-content-end' : 'justify-content-start'}">
                            <div class="chat-bubble-sm ${isMe ? 'sent-sm' : 'received-sm'}" style="max-width: 85%;">${message}
                            <div class="mt-1 opacity-50 text-end" style="font-size: 0.6rem;">${time}</div></div></div>`;
                        widgetBody.insertAdjacentHTML('beforeend', htmlWidget);
                        widgetBody.scrollTop = widgetBody.scrollHeight;
                    }

                    // Render cho trang chi tiết Chat Khách hàng
                    const pageChatBody = document.getElementById('customer-chat-content');
                    if(pageChatBody) {
                        const avatar = isMe ? '' : `<div class="glass-circle flex-shrink-0" style="width: 35px; height: 35px;"><img src="/img/logo-small.jpg" class="rounded-circle" width="35" height="35" style="opacity: 0.8;"></div>`;
                        const htmlPage = `<div class="d-flex gap-3 ${isMe ? 'justify-content-end' : ''}">
                            ${avatar}<div style="max-width: 75%;">
                            <small class="opacity-50 mb-1 d-block ${isMe ? 'text-end' : ''}">${isMe ? 'Bạn' : 'OceanShellCraft'}</small>
                            <div class="chat-bubble-sm ${isMe ? 'sent-sm' : 'received-sm'}">${message}</div>
                            <small class="opacity-50 mt-1 d-block ${isMe ? 'text-end' : ''}" style="font-size: 0.7rem;">${time}</small></div></div>`;
                        pageChatBody.insertAdjacentHTML('beforeend', htmlPage);
                        pageChatBody.scrollTop = pageChatBody.scrollHeight;
                    }
                });

                async function sendMessage(inputId) {
                    const input = document.getElementById(inputId);
                    if (input && input.value.trim()) {
                        await connection.invoke("CustomerSendMessage", input.value.trim());
                        input.value = '';
                    }
                }

                document.getElementById('liveChatSendBtn')?.addEventListener('click', () => sendMessage('liveChatInput'));
                document.getElementById('liveChatInput')?.addEventListener('keypress', e => { if(e.key === 'Enter') sendMessage('liveChatInput'); });

                // Lắng nghe ở trang Chat chính
                const checkPageElements = setInterval(() => {
                    const pageSendBtn = document.getElementById('cust-page-send-btn');
                    const pageInput = document.getElementById('cust-page-input');
                    if(pageSendBtn && pageInput) {
                        pageSendBtn.onclick = () => sendMessage('cust-page-input');
                        pageInput.onkeypress = e => { if(e.key === 'Enter') sendMessage('cust-page-input'); };
                        clearInterval(checkPageElements);
                    }
                }, 500);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>