@using System.Security.Claims
@inject OceanShellCraft.Models.MyNgheDbContext _context

@{
    // 1. Lấy ID người dùng từ Claims
    var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    OceanShellCraft.Models.NguoiDung currentUser = null;

    if (!string.IsNullOrEmpty(userIdClaim) && int.TryParse(userIdClaim, out int userId))
    {
        currentUser = _context.NguoiDungs.FirstOrDefault(u => u.Id == userId);
    }

    // 2. Thiết lập giá trị mặc định
    var hoTen = currentUser?.HoTen ?? "Khách hàng";
    var vaiTro = currentUser?.VaiTro ?? "Thành viên";
    var anhDaiDien = (currentUser != null && !string.IsNullOrEmpty(currentUser.AnhDaiDien))
                     ? currentUser.AnhDaiDien : "/img/meo.jpg";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OceanShellCraft</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        .sidebar-glass {
            background: rgba(255, 255, 255, 0.05) !important;
            backdrop-filter: blur(25px);
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .main-glass {
            background: rgba(255, 255, 255, 0.05) !important;
            backdrop-filter: blur(15px);
        }

        .menu-item {
            color: rgba(255, 255, 255, 0.6) !important;
            border-radius: 10px;
            transition: color 0.3s ease;
            margin-bottom: 5px;
            text-decoration: none;
            background: transparent !important;
        }

            .menu-item:hover {
                color: #ffffff !important;
                background: transparent !important;
            }

            .menu-item.active {
                color: #ffffff !important;
                font-weight: bold;
                background: rgba(255, 255, 255, 0.05) !important; /* Tuân thủ 1 màu kính duy nhất */
                border: 1px solid rgba(255, 255, 255, 0.15);
            }

                .menu-item.active i {
                    color: #ffffff !important;
                }

        .full-screen-app {
            height: 100vh;
            width: 100vw;
        }

        /* Tùy chỉnh thanh cuộn cho sidebar nếu menu quá dài */
        .sidebar-menu-scroll {
            overflow-y: auto;
            overflow-x: hidden;
        }

            .sidebar-menu-scroll::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-menu-scroll::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.2);
                border-radius: 10px;
            }
    </style>
</head>
<body style="background: url('/img/bien.jpg') no-repeat center center fixed; background-size: cover; overflow: hidden; margin: 0;">

    <div class="d-flex flex-nowrap full-screen-app">
        <div class="sidebar-glass d-flex flex-column p-4 h-100" style="width: 280px; z-index: 10;">
            <a asp-controller="TrangChu" asp-action="TrangChu" class="d-flex align-items-center mb-4 text-decoration-none">
                <span class="fs-3 text-white me-2"><i class="bi bi-droplet-half"></i></span>
                <span class="fs-4 fw-bold text-white" style="font-family: 'Playfair Display', serif;">OceanShell</span>
            </a>

            <ul class="nav flex-column gap-2 mb-4 sidebar-menu-scroll flex-grow-1">
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="TongQuan" class="nav-link menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "TongQuan" ? "active" : "") d-flex align-items-center px-3 py-2">
                        <i class="bi bi-grid-1x2 me-3"></i> Tổng quan
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="Orders" class="nav-link menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Orders" ? "active" : "") d-flex align-items-center px-3 py-2">
                        <i class="bi bi-box-seam me-3"></i> Đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="YeuThich" class="nav-link menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "YeuThich" ? "active" : "") d-flex align-items-center px-3 py-2">
                        <i class="bi bi-heart me-3"></i> Yêu thích
                    </a>
                </li>

                <li class="my-2"><hr style="border-color: rgba(255,255,255,0.1); margin: 0;"></li>

                <li class="nav-item">
                    <a asp-controller="KhachHang" asp-action="HoSo" class="nav-link menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "HoSo" ? "active" : "") d-flex align-items-center px-3 py-2">
                        <i class="bi bi-person-vcard me-3"></i> Thông tin cá nhân
                    </a>
                </li>
                
                
                
            </ul>

            <div class="mt-auto text-center p-3" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 15px;">
                <img src="@anhDaiDien" alt="User" class="rounded-circle mb-2 border border-2 border-light shadow-sm" width="60" height="60" style="object-fit: cover;">
                <h6 class="text-white mb-0 fw-bold">@hoTen</h6>
                <small class="text-white opacity-75 d-block mb-3"><i class="bi bi-star-fill"></i> @vaiTro</small>
                <a asp-controller="TaiKhoan" asp-action="DangXuat" class="btn btn-outline-light btn-sm w-100 rounded-pill shadow-sm custom-glass-btn">
                    <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="main-glass flex-grow-1 p-4 p-md-5 d-flex flex-column h-100 overflow-auto text-white" style="z-index: 5;">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>