@model OceanShellCraft.Models.ViewModels.SuaQuyenNguoiDungViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-4 opacity-75 small">
                    <li class="breadcrumb-item"><a asp-action="DanhSach" class="text-decoration-none">quản lý</a></li>
                    <li class="breadcrumb-item active">sửa quyền</li>
                </ol>
            </nav>

            <div class="glass-card p-5">
                <h3 class="text-center mb-4">thiết lập quyền</h3>

                <div class="mb-4 text-center">
                    <div class="p-3 rounded-3" style="border: 1px solid var(--border-light); background: var(--glass-bg);">
                        <p class="opacity-50 small mb-1">đang chỉnh sửa tài khoản:</p>
                        <h6 class="mb-0">@Model.Email?.ToLower()</h6>
                    </div>
                </div>

                <form asp-action="SuaQuyen" method="post">
                    @* Hidden field để gửi ID *@
                    <input type="hidden" asp-for="NguoiDungId" />

                    <div class="mb-4">
                        <label class="small opacity-75 mb-2 ps-2">chọn vai trò mới</label>
                        <select name="vaiTroMoi" class="glass-input" style="background-color: transparent;">
                            @foreach (var role in Model.DanhSachVaiTro)
                            {
                                <option value="@role" selected="@(role == Model.VaiTroHienTai)" style="background: #222; color: #fff;">
                                    @role.ToLower()
                                </option>
                            }
                        </select>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="glass-btn py-3 fs-6">
                            xác nhận thay đổi
                        </button>
                        <a asp-action="DanhSach" class="text-center small opacity-50 text-decoration-none">
                            hủy bỏ và quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>