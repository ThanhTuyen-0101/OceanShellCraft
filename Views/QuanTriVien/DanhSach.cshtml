@model IEnumerable<OceanShellCraft.Models.NguoiDung>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-people-fill me-2"></i>quản lý thành viên</h2>
    </div>

    @if (TempData["ThongBao"] != null)
    {
        <div class="glass-card mb-4 p-3 d-flex justify-content-between align-items-center" role="alert">
            <span class="small"><i class="bi bi-check-circle-fill me-2"></i>@TempData["ThongBao"]?.ToString().ToLower()</span>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="close" style="filter: invert(1);"></button>
        </div>
    }

    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="glass-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">họ và tên</th>
                        <th>email</th>
                        <th>vai trò</th>
                        <th class="text-center">thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">@item.HoTen?.ToLower()</td>
                            <td class="opacity-75">@item.Email?.ToLower()</td>
                            <td>
                                @if (item.VaiTro == "Admin")
                                {
                                    <span class="small">quản trị viên</span>
                                }
                                else
                                {
                                    <span class="small opacity-50">khách hàng</span>
                                }
                            </td>
                            <td class="text-center px-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="SuaQuyen" asp-route-id="@item.Id" class="glass-btn py-1 px-3 small">
                                        <i class="bi bi-pencil-square me-1"></i>đổi quyền
                                    </a>

                                    @if (item.Email != "admin@biendanang.com")
                                    {
                                        <form asp-action="XoaNguoiDung" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('bạn có chắc chắn muốn xóa người dùng này?')">
                                            <button type="submit" class="glass-btn py-1 px-3 small opacity-75">
                                                <i class="bi bi-trash me-1"></i>xóa
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>