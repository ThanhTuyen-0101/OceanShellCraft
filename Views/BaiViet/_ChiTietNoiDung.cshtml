@model OceanShellCraft.Models.BaiViet

@{
    var videoId = "";
    if (!string.IsNullOrEmpty(Model.VideoYoutube))
    {
        var url = Model.VideoYoutube;
        if (url.Contains("youtu.be/")) videoId = url.Split("youtu.be/")[1].Split('?')[0];
        else if (url.Contains("v=")) videoId = url.Split("v=")[1].Split('&')[0];
        else videoId = url;
    }
}

@* Container duy nhất bao phủ toàn bộ nội dung *@
<div class="article-inner py-5 px-4 px-md-5 animate__animated animate__fadeIn shadow-lg"
     style="border-radius: 40px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 50px;">

    @* 1. Phần tiêu đề bài viết *@
    <div class="text-center mb-5">
        <span class="opacity-50 small text-uppercase" style="letter-spacing: 3px;">@(Model.HinhThuc ?? "Tác phẩm")</span>
        <h1 class="display-3 mt-2 mb-4 fw-bold text-white">@Model.TieuDe</h1>
        <div class="mx-auto" style="width: 80px; height: 2px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);"></div>
    </div>

    @* 2. Phần nội dung chữ (Không dùng nền riêng nữa) *@
    <div class="article-content fs-5 lh-lg opacity-75 text-white mb-5" style="text-align: justify;">
        @Html.Raw(Model.NoiDung)
    </div>

    @* 3. Phần Video Youtube *@
    @if (!string.IsNullOrEmpty(videoId))
    {
        <div class="mt-5 mb-5 ratio ratio-16x9 rounded-4 overflow-hidden shadow-lg border" style="border-color: rgba(255,255,255,0.1) !important;">
            <iframe src="https://www.youtube.com/embed/@videoId" allowfullscreen frameborder="0"></iframe>
        </div>
    }

    @* Đường phân cách nhẹ giữa nội dung và bình luận *@
    <hr class="my-5" style="border-color: rgba(255,255,255,0.1);">

    @* 4. Khu vực bình luận *@
    <div id="khu-vuc-binh-luan">
        <h3 class="mb-5 text-center text-white fw-light">Bình luận & Đánh giá</h3>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            @* Form bình luận - Giữ trong suốt để tiệp với nền kính tổng *@
            <div class="mb-5 p-4" style="border-radius: 24px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                <h5 class="mb-4 text-white-50">Viết đánh giá của bạn</h5>
                <form id="formBinhLuanBV">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="BaiVietId" value="@Model.Id" />

                    <div class="mb-4" style="max-width: 300px;">
                        <label class="small opacity-75 mb-2 text-white">Đánh giá sao:</label>
                        <select name="SoSao" id="real_SoSao" class="d-none" required>
                            <option value="">-- Chọn số sao --</option>
                            @for (int i = 5; i >= 1; i--)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>

                        <div class="dropdown w-100">
                            <button class="glass-input d-flex justify-content-between align-items-center w-100 text-white"
                                    type="button" data-bs-toggle="dropdown" id="btn_SoSao"
                                    style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1); padding: 12px 15px; border-radius: 12px;">
                                <span id="text_SoSao">-- Chọn số sao --</span>
                                <i class="bi bi-chevron-down small opacity-50"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark w-100 p-2 shadow-lg border-0" style="background: rgba(30, 30, 30, 0.95); backdrop-filter: blur(10px);">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 text-warning" href="javascript:void(0)"
                                           onclick="window.chonMenuThaXuong('real_SoSao', 'text_SoSao', '@i', '★★★★★ (@i Sao)'.substring(5-@i))">
                                            @for (int j = 0; j < i; j++)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            (@i Sao)
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="mb-3">
                        <textarea name="NoiDung" class="glass-input w-100 p-3 text-white" rows="3" required placeholder="Chia sẻ cảm nhận của bạn..."
                              style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; outline: none;"></textarea>
                    </div>

                    <button type="submit" class="glass-btn px-5 py-2 mt-2">
                        <i class="bi bi-send-fill me-2"></i> Gửi đánh giá
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="mb-5 p-4 text-center" style="border-radius: 20px; background: rgba(255,255,255,0.03); border: 1px dashed rgba(255,255,255,0.2);">
                <p class="text-white-50 mb-0">Vui lòng <a href="/dang-nhap" class="text-warning fw-bold text-decoration-none">Đăng nhập</a> để để lại cảm nghĩ của bạn.</p>
            </div>
        }

        @* Danh sách các bình luận *@
        <div id="danhSachBinhLuanContainer">
            @if (Model.DanhGiaBaiViets != null && Model.DanhGiaBaiViets.Any())
            {
                @foreach (var danhGia in Model.DanhGiaBaiViets.OrderByDescending(d => d.NgayDanhGia))
                {
                    <div class="p-4 mb-4" style="border-radius: 20px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                        <div class="d-flex align-items-center mb-3">
                            <div class="glass-circle me-3" style="width: 45px; height: 45px; background: rgba(255,255,255,0.1); display: flex; align-items:center; justify-content:center; border-radius: 50%;">
                                <i class="bi bi-person-fill text-white-50 fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-white fw-bold">@(danhGia.NguoiDung?.HoTen ?? "Khách hàng ẩn danh")</h6>
                                <div class="small mt-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= danhGia.SoSao ? "bi-star-fill text-warning" : "bi-star text-white-50") me-1"></i>
                                    }
                                    <span class="ms-2 opacity-50 text-white" style="font-size: 0.75rem;">@danhGia.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>
                        </div>
                        <p class="opacity-75 mb-0 small text-white" style="line-height: 1.6;">@danhGia.NoiDung</p>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 opacity-25 text-white" id="empty-review-msg">
                    <i class="bi bi-chat-dots fs-1"></i>
                    <h5 class="mt-3">Hãy là người đầu tiên để lại bình luận</h5>
                </div>
            }
        </div>
    </div>
</div>