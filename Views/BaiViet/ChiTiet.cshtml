@model OceanShellCraft.Models.BaiViet

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.TieuDe;
}

<div class="container mt-5 mb-5">
    <a asp-action="DanhSach" class="btn btn-outline-secondary mb-4 rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> Quay lại khám phá
    </a>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        @if (!string.IsNullOrEmpty(Model.AnhNen))
        {
            <img src="@Model.AnhNen" class="card-img-top object-fit-cover" alt="@Model.TieuDe" style="height: 400px; width: 100%;">
        }

        <div class="card-body p-5">
            <div class="text-center mb-5">
                <span class="badge bg-warning text-dark px-3 py-2 mb-3 rounded-pill">@(string.IsNullOrEmpty(Model.HinhThuc) ? "Thông tin" : Model.HinhThuc)</span>
                <h1 class="fw-bold display-5 mb-3">@Model.TieuDe</h1>
                <p class="text-muted">
                    <i class="bi bi-calendar-event me-2"></i> Đăng lúc: @Model.NgayTao.ToString("HH:mm - dd/MM/yyyy")
                </p>
            </div>

            @if (!string.IsNullOrEmpty(Model.NoiDungTomTat))
            {
                <div class="alert alert-secondary border-0 border-start border-4 border-warning fst-italic fs-5 mb-5">
                    @Model.NoiDungTomTat
                </div>
            }

            <div class="fs-5 lh-lg mb-5" style="color: #333;">
                @Html.Raw(Model.NoiDung)
            </div>

            @if (!string.IsNullOrEmpty(Model.VideoYoutube))
            {
                <hr class="my-5">
                <h4 class="fw-bold mb-4">Video liên quan</h4>
                <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow-sm">
                    @Html.Raw(Model.VideoYoutube)
                </div>
            }
        </div>
    </div>
</div>