@model OceanShellCraft.Models.BaiViet

<div class="container mt-4">
    <h2>✍️ Soạn thảo bài viết</h2>
    <form asp-action="ThemMoi" method="post">
        <div class="mb-3">
            <label class="form-label font-weight-bold">Tiêu đề bài viết</label>
            <input asp-for="TieuDe" class="form-control" placeholder="Nhập tiêu đề..." required />
        </div>
        <div class="mb-3">
            <label class="form-label font-weight-bold">Nội dung</label>
            <textarea asp-for="NoiDung" class="form-control" rows="8" placeholder="Viết nội dung vào đây..." required></textarea>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-success">✅ Lưu bài viết</button>
            <a asp-action="DanhSach" class="btn btn-outline-danger">Hủy bỏ</a>
        </div>
    </form>
</div>