@model IEnumerable<OceanShellCraft.Models.BaiViet>

<div class="ds-scroll-container bg-transparent" id="mainScroll">
    <div class="text-center pt-5 mt-5">
        <h6 class="text-white opacity-50 fw-bold text-uppercase small mb-2 ls-3">Collection</h6>
        <h1 class="display-4 fw-bold text-white mb-0">Câu Chuyện Đại Dương</h1>
    </div>

    <section class="d-flex align-items-center" style="height: 100vh; scroll-snap-align: start;">
        <div class="w-100 overflow-hidden py-5">
            <div class="ds-slider-track" id="sliderTrack">
                @if (Model != null)
                {
                    @for (int i = 0; i < 3; i++)
                    {
                        @foreach (var item in Model)
                        {
                            <div class="shell-card p-4 m-3 rounded-5 shadow" onclick="loadArticle('@item.Id')" style="width: 350px; cursor: pointer;">
                                <div class="text-center">
                                    <img src="@(item.AnhNen ?? "/img/bien.jpg")" class="rounded-circle border border-white border-opacity-25 mb-4 shadow-sm" style="width:140px; height:140px; object-fit:cover;" />
                                    <h3 class="text-white fs-5 fw-bold mb-3">@item.TieuDe</h3>
                                    <p class="text-white-50 small opacity-75">ĐỌC CÂU CHUYỆN <i class="bi bi-arrow-right ms-1"></i></p>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </section>

    <section id="section-detail" class="position-relative" style="min-height: 100vh; scroll-snap-align: start;">
        <div class="container py-5 h-100 d-flex align-items-center justify-content-center">
            <div id="detailPlaceholder" class="w-100 h-100">
                <div class="text-center text-white opacity-25 py-5">
                    <i class="bi bi-mouse fs-1 d-block mb-3"></i>
                    <p class="fs-5">Cuộn hoặc chọn một câu chuyện để khám phá</p>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
    function loadArticle(id) {
        const placeholder = document.getElementById('detailPlaceholder');
        const detailSection = document.getElementById('section-detail');

        placeholder.innerHTML = `<div class="d-flex justify-content-center py-5"><div class="spinner-border text-light opacity-50" role="status"></div></div>`;
        detailSection.scrollIntoView({ behavior: 'smooth' });

        fetch(`/BaiViet/GetChiTiet/${id}`)
            .then(res => res.text())
            .then(html => {
                placeholder.innerHTML = `<div class="glass-detail-box p-4 p-md-5 rounded-5 animate__animated animate__fadeInUp">${html}</div>`;
            });
    }

    const track = document.getElementById('sliderTrack');
    if (track) {
        track.addEventListener('mouseenter', () => track.style.animationPlayState = 'paused');
        track.addEventListener('mouseleave', () => track.style.animationPlayState = 'running');
    }
</script>