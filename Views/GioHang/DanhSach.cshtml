@model IEnumerable<OceanShellCraft.Models.GioHang>

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-primary"><i class="bi bi-cart3"></i> Giỏ Hàng Của Bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded bg-white shadow-sm">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Giỏ hàng đang trống</h3>
            <a asp-controller="SanPham" asp-action="DanhSach" class="btn btn-primary mt-3">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Giá</th>
                        <th style="width: 120px;">Số lượng</th>
                        <th>Thành tiền</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@item.SanPham?.HinhAnh" width="60" class="rounded border me-2" />
                                <strong>@item.SanPham?.TenSanPham</strong>
                            </td>
                            <td>@item.SanPham?.GiaTien.ToString("N0") đ</td>
                            <td>
                                @* Thay đổi số lượng tự động gọi AJAX *@
                                <input type="number" value="@item.SoLuong" min="1"
                                       class="form-control text-center fw-bold border-primary"
                                       data-id="@item.Id"
                                       onchange="updateCart(this)" />
                            </td>
                            <td class="fw-bold text-primary">
                                @((item.SoLuong * (item.SanPham?.GiaTien ?? 0)).ToString("N0")) đ
                            </td>
                            <td class="text-center">
                                <a asp-action="XoaKhoiGio" asp-route-id="@item.Id"
                                   class="btn btn-link text-danger p-0"
                                   onclick="return confirm('Xóa sản phẩm này?')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 d-flex justify-content-between align-items-center">
            <a asp-controller="SanPham" asp-action="DanhSach" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
            </a>
            <a asp-action="DatHang" class="btn btn-success btn-lg w-100 mt-3 fw-bold text-uppercase shadow">
                Tiến Hành Đặt Hàng <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function updateCart(input) {
            var id = $(input).data('id');
            var qty = $(input).val();
            if (qty < 1) { $(input).val(1); qty = 1; }

            $.get('/GioHang/CapNhatSoLuong', { id: id, soLuong: qty }, function () {
                location.reload(); // Reload để cập nhật tiền và badge ở Header
            });
        }
    </script>
}