@model OceanShellCraft.Models.ViewModels.GioHangViewModel

<div class="container py-5" style="min-height: 85vh;">
    <h2 class="mb-5 pb-3 text-center" style="border-bottom: 1px solid var(--border-light);">
        <i class="bi bi-bag-check me-2"></i>Thông tin đặt hàng 🐚
    </h2>

    <form asp-action="XacNhanDatHang" method="post" id="formDatHang">
        <div class="row g-4">

            <div class="col-lg-5">
                <div class="glass-card p-4 sticky-top" style="top: 100px; z-index: 10;">
                    <h5 class="mb-4 pb-3 opacity-75" style="border-bottom: 1px solid var(--border-light); letter-spacing: 1px;">Địa chỉ nhận hàng</h5>

                    <div class="mb-4">
                        <label class="small opacity-75 mb-2 ps-2">Số điện thoại *</label>
                        <input type="tel" name="SoDienThoai" class="glass-input" required placeholder="Nhập số điện thoại..." />
                    </div>

                    <div class="mb-4">
                        <label class="small opacity-75 mb-2 ps-2">Địa chỉ giao hàng *</label>
                        <textarea name="DiaChi" class="glass-input" rows="3" required placeholder="Nhập địa chỉ giao hàng chi tiết..."></textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="glass-card p-4">
                    <h5 class="mb-4 pb-3 opacity-75" style="border-bottom: 1px solid var(--border-light); letter-spacing: 1px;">Kiểm tra sản phẩm</h5>

                    <div class="table-responsive hide-scrollbar">
                        <table class="w-100 align-middle">
                            <tbody>
                                @for (int i = 0; i < Model.DanhSachItem.Count; i++)
                                {
                                    var item = Model.DanhSachItem[i];
                                    <tr class="product-row" data-price="@item.SanPham.GiaTien" style="border-bottom: 1px solid var(--border-light);">
                                        @* Lưu ID sản phẩm *@
                                        <input type="hidden" name="ListSanPhamId" value="@item.SanPhamId" />

                                        <td class="py-4" style="width: 80px;">
                                            <img src="@(item.SanPham?.HinhAnh ?? "/images/default-shell.png")"
                                                 alt="product"
                                                 class="rounded-3"
                                                 style="width: 70px; height: 70px; object-fit: cover; border: 1px solid var(--border-light);" />
                                        </td>

                                        <td class="py-4 px-3">
                                            <div class="mb-2" style="font-size: 1rem;">@item.SanPham.TenSanPham</div>

                                            @* Ô nhập số lượng *@
                                            <div class="d-flex align-items-center rounded-pill" style="width: fit-content; border: 1px solid var(--border-light); background: var(--glass-bg); padding: 2px 10px;">
                                                <span class="small opacity-50 me-2">SL:</span>
                                                <input type="number" name="ListSoLuong" class="bg-transparent border-0 text-center input-soluong"
                                                       value="@item.SoLuong" min="1" style="width: 50px; height: 30px; font-size: 0.9rem; color: var(--text-main); outline: none;" />
                                            </div>
                                        </td>

                                        <td class="py-4 text-end">
                                            <span class="line-total">@((item.SoLuong * item.SanPham.GiaTien).ToString("N0"))</span> đ
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5 mb-4 pt-4" style="border-top: 1px solid var(--border-light);">
                        <span class="opacity-75">Tổng cộng</span>
                        <div class="fs-4">
                            <span id="grand-total">@Model.TongTien.ToString("N0")</span> đ
                        </div>
                    </div>

                    <button type="submit" class="glass-btn w-100 py-3 fs-5" style="letter-spacing: 1px;">
                        Xác nhận đặt hàng
                    </button>

                    <div class="text-center mt-4 opacity-50 small">
                        <i class="bi bi-shield-check me-1"></i>Thông tin của bạn luôn được bảo mật bởi OceanShellCraft
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.input-soluong').on('input change', function () {
                let grandTotal = 0;

                $('.product-row').each(function () {
                    const price = parseFloat($(this).data('price'));
                    const quantity = parseInt($(this).find('.input-soluong').val()) || 0;
                    const lineTotal = price * quantity;

                    $(this).find('.line-total').text(lineTotal.toLocaleString('vi-VN'));
                    grandTotal += lineTotal;
                });

                $('#grand-total').text(grandTotal.toLocaleString('vi-VN'));
            });
        });
    </script>
}