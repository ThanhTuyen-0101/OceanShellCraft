@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 text-center py-5 shadow-lg rounded-4 bg-white border border-info border-3">
            <div class="mb-4">
                <i class="bi bi-bag-check-fill display-1 text-success"></i>
            </div>
            <h2 class="fw-bold text-primary">Cảm ơn Như đã đặt hàng! 🐚</h2>
            <p class="lead text-muted mt-3">Đơn hàng của bạn đã được hệ thống ghi nhận và đang chờ xử lý.</p>

            <div class="alert alert-info d-inline-block px-4 mt-2">
                <i class="bi bi-info-circle me-2"></i> Chúng mình sẽ liên hệ với bạn qua Email để xác nhận vận chuyển.
            </div>

            <div class="mt-5 d-flex justify-content-center gap-3">
                <a asp-controller="TrangChu" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">
                    <i class="bi bi-house-door"></i> Về Trang Chủ
                </a>
                <a asp-controller="SanPham" asp-action="DanhSach" class="btn btn-primary btn-lg px-4 shadow">
                    Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
</div>