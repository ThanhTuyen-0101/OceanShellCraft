@model OceanShellCraft.Models.GiamGia
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Tiêu đề thay đổi động tùy theo việc thêm mới (Id = 0) hay sửa
    ViewData["Title"] = Model.Id == 0 ? "Thêm mới mã giảm giá" : "Cập nhật mã giảm giá";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="GiamGia" class="text-decoration-none text-muted mb-2 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
            </a>
            <h4 class="m-0 fw-normal">@ViewData["Title"]</h4>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card p-4">
                <form asp-action="ThemSuaGiamGia" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-4">
                        @* Mã Voucher *@
                        <div class="col-md-6">
                            <label asp-for="MaVoucher" class="form-label opacity-75 small mb-1">Mã Voucher (Code) <span class="text-danger">*</span></label>
                            <input asp-for="MaVoucher" class="glass-input form-control text-uppercase" placeholder="VD: OCEAN10, SUMMER20" required />
                            <span asp-validation-for="MaVoucher" class="text-danger small"></span>
                        </div>

                        @* Tên Voucher *@
                        <div class="col-md-6">
                            <label asp-for="TenVoucher" class="form-label opacity-75 small mb-1">Tên chương trình / Mô tả <span class="text-danger">*</span></label>
                            <input asp-for="TenVoucher" class="glass-input form-control" placeholder="VD: Giảm 10% cho khách hàng mới" required />
                            <span asp-validation-for="TenVoucher" class="text-danger small"></span>
                        </div>

                        @* Hạn Sử Dụng *@
                        <div class="col-md-6">
                            <label asp-for="HanSuDung" class="form-label opacity-75 small mb-1">Hạn sử dụng <span class="text-danger">*</span></label>
                            <input asp-for="HanSuDung" type="datetime-local" class="glass-input form-control" required />
                            <span asp-validation-for="HanSuDung" class="text-danger small"></span>
                        </div>

                        @* Đối Tượng Áp Dụng (Chọn người dùng) *@
                        <div class="col-md-6">
                            <label asp-for="NguoiDungId" class="form-label opacity-75 small mb-1">Cấp riêng cho khách hàng (Tùy chọn)</label>
                            <select asp-for="NguoiDungId" class="glass-input form-select" asp-items="ViewBag.KhachHangList">
                                <option value="">-- Áp dụng cho tất cả mọi người --</option>
                            </select>
                            <div class="form-text opacity-50 small" style="color: var(--text-main);">Để trống nếu muốn voucher dùng chung.</div>
                            <span asp-validation-for="NguoiDungId" class="text-danger small"></span>
                        </div>

                    </div>

                    <div class="mt-5 pt-4 d-flex justify-content-end gap-2" style="border-top: 1px solid rgba(255,255,255,0.1);">
                        <a asp-action="GiamGia" class="glass-btn px-4 fw-normal opacity-75">Hủy bỏ</a>
                        <button type="submit" class="glass-btn px-4 fw-normal text-success">
                            <i class="bi bi-check-circle me-1"></i>Lưu thông tin
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Tự động viết hoa mã voucher khi người dùng nhập
        document.querySelector('input[name="MaVoucher"]').addEventListener('input', function (e) {
            this.value = this.value.toUpperCase().replace(/\s/g, ''); // Viết hoa và xóa khoảng trắng
        });
    </script>
}