@model OceanShellCraft.Models.NguoiDung
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật người dùng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="NguoiDung" class="text-decoration-none text-muted mb-2 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
            </a>
            <h4 class="m-0 fw-normal">@ViewData["Title"]</h4>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card p-4">
                <form asp-action="SuaNguoiDung" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    @* Giữ lại mật khẩu cũ để không bị ghi đè thành null *@
                    <input type="hidden" asp-for="MatKhau" />

                    <div class="row g-4">
                        @* Email (Tài khoản) - Thường không cho đổi nên để readonly và làm mờ *@
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label opacity-75 small mb-1">Email (Tài khoản đăng nhập)</label>
                            <input asp-for="Email" class="glass-input form-control opacity-50" readonly />
                            <div class="form-text opacity-50 small" style="color: var(--text-main);">Không thể thay đổi email.</div>
                        </div>

                        @* Vai trò *@
                        <div class="col-md-6">
                            <label asp-for="VaiTro" class="form-label opacity-75 small mb-1">Vai trò hệ thống</label>
                            <select asp-for="VaiTro" class="glass-input form-select" style="cursor: pointer;">
                                <option value="KhachHang">Khách hàng (Cơ bản)</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                        </div>

                        @* Họ Tên *@
                        <div class="col-md-6">
                            <label asp-for="HoTen" class="form-label opacity-75 small mb-1">Họ và tên</label>
                            <input asp-for="HoTen" class="glass-input form-control" placeholder="Nhập họ và tên..." />
                        </div>

                        @* Số điện thoại *@
                        <div class="col-md-6">
                            <label asp-for="SoDienThoai" class="form-label opacity-75 small mb-1">Số điện thoại</label>
                            <input asp-for="SoDienThoai" class="glass-input form-control" placeholder="Nhập số điện thoại..." />
                        </div>
                    </div>

                    <div class="mt-5 pt-4 d-flex justify-content-end gap-2" style="border-top: 1px solid rgba(255,255,255,0.1);">
                        <a asp-action="NguoiDung" class="glass-btn px-4 fw-normal opacity-75">Hủy bỏ</a>
                        <button type="submit" class="glass-btn px-4 fw-normal">
                            <i class="bi bi-check-circle me-1"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}