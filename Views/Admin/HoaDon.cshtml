@model IEnumerable<OceanShellCraft.Models.DonHang>
@{
    ViewData["Title"] = "Hóa đơn";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var selectedOrder = ViewBag.SelectedOrder as OceanShellCraft.Models.DonHang;
}

<div class="row g-4 vh-100 overflow-hidden p-3">

    @* --- DANH SÁCH HÓA ĐƠN (BÊN TRÁI) --- *@
    <div class="col-lg-4 d-flex flex-column h-100 pe-lg-3">

        @* Ô tìm kiếm *@
        <form method="get" action="@Url.Action("HoaDon", "Admin")" class="mb-3">
            <div class="d-flex align-items-center px-3 glass-input" style="height: 45px;">
                <i class="bi bi-search opacity-50"></i>
                @* Thay type="number" thành type="text" và thêm inputmode/pattern *@
                <input type="text"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       name="id"
                       class="bg-transparent border-0 shadow-none ms-2 small flex-grow-1 fw-normal"
                       style="color: var(--text-main); outline: none;"
                       placeholder="Nhập mã đơn hàng..."
                       value="@Context.Request.Query["id"]">

                @if (Context.Request.Query.ContainsKey("id"))
                {
                    <a href="@Url.Action("HoaDon", "Admin")" class="opacity-50 ms-2"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </form>

        @* Danh sách cuộn *@
        <div class="flex-grow-1 overflow-auto hide-scrollbar">
            @foreach (var item in Model)
            {
                <a href="?id=@item.Id" class="text-decoration-none">
                    <div class="glass-card p-3 mb-2 fw-normal"
                         style="@(selectedOrder?.Id == item.Id ? "background: rgba(255,255,255,0.15); border-color: var(--text-main);" : "border: 1px solid transparent;")">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small">#Inv-@item.Id</div>
                                <div class="opacity-50 small">@item.NguoiDung?.HoTen</div>
                            </div>
                            <div class="text-end">
                                <div class="small">@item.TongTien.ToString("N0")đ</div>
                                <div class="opacity-30" style="font-size: 0.65rem;">@item.NgayDat.ToString("dd/MM/yy")</div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>

    @* --- CHI TIẾT HÓA ĐƠN (BÊN PHẢI) --- *@
    <div class="col-lg-8 d-flex flex-column h-100 ps-lg-3 overflow-auto hide-scrollbar">

        @if (selectedOrder != null)
        {
            <div id="invoice-content" class="p-5 d-flex flex-column mb-5 fw-normal" style="border-radius: 4px;">

                @* Tiêu đề hóa đơn *@
                <div class="d-flex justify-content-between align-items-start mb-5">
                    <div>
                        <h2 class="m-0 fw-normal" style="letter-spacing: 1px;">Hóa đơn chi tiết</h2>
                        <p class="m-0 small opacity-70">Mã tham chiếu: #DH-@selectedOrder.Id</p>
                    </div>
                    <div class="text-end" data-html2canvas-ignore="true">
                        <span class="small opacity-70 me-2">Trạng thái:</span>
                        <span class="small px-3 py-1 border border-dark rounded-pill">
                            @selectedOrder.TrangThai
                        </span>
                    </div>
                </div>

                @* Thông tin khách và Đơn hàng *@
                <div class="row mb-5 g-4">
                    <div class="col-md-6">
                        <h6 class="small mb-3 opacity-70 fw-normal">Người nhận hàng</h6>
                        <table class="w-100 m-0 fw-normal" style="font-size: 0.9rem; line-height: 1.8;">
                            <tbody>
                                <tr>
                                    <td class="opacity-60" style="width: 35%;">Tên khách</td>
                                    <td>@selectedOrder.NguoiDung?.HoTen</td>
                                </tr>
                                <tr>
                                    <td class="opacity-60">Điện thoại</td>
                                    <td>@selectedOrder.SoDienThoai</td>
                                </tr>
                                <tr>
                                    <td class="opacity-60">Địa chỉ</td>
                                    <td>@selectedOrder.DiaChi</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h6 class="small mb-3 opacity-70 fw-normal">Thông tin đơn hàng</h6>
                        <table class="w-100 m-0 fw-normal" style="font-size: 0.9rem; line-height: 1.8;">
                            <tbody>
                                <tr>
                                    <td class="opacity-60" style="width: 35%;">Ngày đặt</td>
                                    <td>@selectedOrder.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <td class="opacity-60">Phương thức</td>
                                    <td class="text-uppercase">COD</td>
                                </tr>
                                <tr>
                                    <td class="opacity-60">Vận chuyển</td>
                                    <td>Tiêu chuẩn</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <h6 class="small mb-3 opacity-70 fw-normal">Danh mục vật phẩm</h6>

                @* Bảng danh sách sản phẩm trong đơn *@
                <div class="mb-4 border border-dark p-2">
                    <table class="w-100 align-middle m-0 fw-normal" style="font-size: 0.9rem;">
                        <thead>
                            <tr class="small opacity-70 border-bottom border-dark">
                                <th class="ps-2 py-2 fw-normal">Sản phẩm</th>
                                <th class="text-center py-2 fw-normal">Số lượng</th>
                                <th class="text-end py-2 fw-normal">Đơn giá</th>
                                <th class="text-end pe-2 py-2 fw-normal">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in selectedOrder.ChiTietDonHangs)
                            {
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td class="ps-2 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div style="width: 40px; height: 40px; border: 1px solid #ddd; padding: 2px;">
                                                <img src="@detail.SanPham?.HinhAnh" class="w-100 h-100 object-fit-cover" />
                                            </div>
                                            <span class="small">@detail.SanPham?.TenSanPham</span>
                                        </div>
                                    </td>
                                    <td class="text-center small">@detail.SoLuong</td>
                                    <td class="text-end opacity-70 small">@detail.GiaLucMua.ToString("N0")đ</td>
                                    <td class="text-end pe-2 small">@((detail.SoLuong * detail.GiaLucMua).ToString("N0"))đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Tổng tiền *@
                <div class="pt-4 text-end mt-auto">
                    <div class="row justify-content-end">
                        <div class="col-md-5">
                            <div class="d-flex justify-content-between mb-2 small opacity-70">
                                <span>Tạm tính</span>
                                <span>@selectedOrder.TongTien.ToString("N0")đ</span>
                            </div>
                            <div class="d-flex justify-content-between mt-3 pt-3 border-top border-dark">
                                <span class="fs-6">Tổng thanh toán</span>
                                <span class="fs-5">@selectedOrder.TongTien.ToString("N0")đ</span>
                            </div>
                        </div>
                    </div>

                    @* Các nút thao tác *@
                    <div class="d-flex gap-3 mt-5 justify-content-end pb-2" data-html2canvas-ignore="true">
                        <button type="button" onclick="xuatPDF()" class="glass-btn small px-4 py-2 fw-normal"
                                style="border: 1px solid #000 !important; color: #000 !important; background: transparent !important;">
                            <i class="bi bi-printer me-2"></i>In hóa đơn
                        </button>

                        @if (selectedOrder.TrangThai != "Đã thanh toán")
                        {
                            <form asp-action="CapNhatTrangThai" method="post" class="m-0">
                                <input type="hidden" name="id" value="@selectedOrder.Id" />
                                <button type="submit" class="glass-btn small px-4 py-2 fw-normal"
                                        style="border: 1px solid #000 !important; color: #000 !important; background: transparent !important;">
                                    Xác nhận đã thu tiền
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="glass-card h-100 d-flex flex-column align-items-center justify-content-center opacity-30 fw-normal">
                <i class="bi bi-search display-1 mb-3"></i>
                <h5>Không tìm thấy mã đơn hàng hoặc chưa chọn đơn hàng</h5>
            </div>
        }
    </div>
</div>

<style>
    /* Ép buộc màu sắc khi hiển thị khu vực hóa đơn chi tiết */
    #invoice-content {
        background-color: #ffffff !important;
        color: #000000 !important;
    }

        #invoice-content * {
            color: #000000 !important;
            border-color: #000000 !important;
            font-weight: normal !important;
        }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function xuatPDF() {
            var element = document.getElementById('invoice-content');
            var opt = {
                margin: 0.4,
                filename: 'HoaDon_OceanShellCraft_@selectedOrder?.Id' + '.pdf',
                image: { type: 'jpeg', quality: 1 },
                html2canvas: { scale: 2, useCORS: true, backgroundColor: '#ffffff' },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save();
        }
    </script>
}