@model OceanShellCraft.Models.ViewModels.AdminDashboardVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var duLieuThongKe = new List<dynamic>
    {
        new { TieuDe = "Doanh thu", GiaTri = Model.DoanhThuThangNay.ToString("N0") + "đ", Icon = "bi-bar-chart-fill", Opacity = "opacity-50" },
        new { TieuDe = "Khách mới", GiaTri = Model.TongKhachHang.ToString(), Icon = "bi-people-fill", Opacity = "opacity-50" },
        new { TieuDe = "Đơn hàng", GiaTri = Model.TongDonHang.ToString(), Icon = "bi-bag-check-fill", Opacity = "opacity-75" },
        new { TieuDe = "Sản phẩm", GiaTri = Model.TongSanPham.ToString(), Icon = "bi-graph-up", Opacity = "opacity-75" }
    };
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
        <div>
            <h3 class="m-0 fw-bold">@DateTime.Now.ToString("dd.MM.yyyy")</h3>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="glass-effect rounded-pill d-flex align-items-center px-3 py-1" style="border-radius: 30px !important; min-width: 250px;">
                <i class="bi bi-search opacity-50"></i>
                <form action="/admin/hoa-don" method="get" class="m-0 w-100">
                    <input type="text" name="id" inputmode="numeric" pattern="[0-9]*"
                           class="bg-transparent border-0 text-white shadow-none ms-2 w-100"
                           style="outline: none;"
                           placeholder="Tìm kiếm..."
                           value="@Context.Request.Query["id"]">
                </form>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/chat" class="glass-circle border border-white border-opacity-25 bg-white bg-opacity-10 text-white" style="width: 45px; height: 45px;" title="Trò chuyện">
                    <i class="bi bi-chat-dots"></i>
                </a>
                <a href="/" class="glass-circle border border-white border-opacity-25" style="width: 45px; height: 45px;" title="Thông báo">
                    <i class="bi bi-bell"></i>
                </a>
            </div>
        </div>
    </div>
    <partial name="_TheThongKe" model="duLieuThongKe" />
    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="glass-card p-4 h-100 d-flex flex-column" style="border-radius: 20px !important;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="m-0 fw-bold">Biến động <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 rounded-pill fw-normal ms-2 small">Ổn định</span></h5>
                    <input type="number" id="yearFilter"
                           class="small py-1 px-3 opacity-75 border-0 text-white text-center"
                           style="font-size: 0.85rem; border-radius: 8px; background: rgba(255,255,255,0.1) !important; box-shadow: none !important; outline: none; width: 80px;"
                           min="2020" max="2099" step="1"
                           value="@(ViewBag.NamDuocChon ?? DateTime.Now.Year)"
                           onchange="locDoanhThuTheoNam()">
                </div>
                <div class="mb-4 d-flex gap-4">
                    <div>
                        <div class="small opacity-50 mb-1">Tổng năm</div>
                        <h4 class="fw-bold m-0">@Model.TongDoanhThu.ToString("N0")đ</h4>
                    </div>
                </div>
                <div class="flex-grow-1" style="min-height: 200px; position: relative;">
                    <canvas id="revenueLineChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="glass-card p-4 h-100 d-flex flex-column justify-content-between" style="border-radius: 20px !important;">
                <div>
                    <h5 class="fw-bold mb-2">Tiến độ</h5>
                    <p class="small opacity-50 mb-4">Xử lý đơn</p>
                </div>

                @{
                    int total = Model.DonChoXuLy + Model.DonDangGiao + Model.DonHoanThanh;
                    int p3 = total == 0 ? 0 : (Model.DonHoanThanh * 100 / total);
                }

                <div class="text-center mb-4">
                    <div class="position-relative d-inline-block">
                        <svg viewBox="0 0 36 36" class="circular-chart" style="width: 120px; height: 120px;">
                            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="3" />
                            <path class="circle" stroke-dasharray="@p3, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="3" stroke-linecap="round" />
                        </svg>
                        <div class="position-absolute top-50 start-50 translate-middle text-center">
                            <h4 class="fw-bold m-0">@p3%</h4>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between text-center mt-auto">
                    <div><span class="d-block small fw-bold">@Model.DonChoXuLy</span><span class="small opacity-50">Chờ</span></div>
                    <div><span class="d-block small fw-bold">@Model.DonDangGiao</span><span class="small opacity-50">Giao</span></div>
                    <div><span class="d-block small fw-bold">@Model.DonHoanThanh</span><span class="small opacity-50">Xong</span></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3">
            <div class="glass-card p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center" style="border-radius: 20px !important;">
                <img src="/img/logo.png" alt="Admin" class="rounded-circle mb-3 border border-2 border-white border-opacity-25" style="width: 80px; height: 80px; object-fit: cover; background: rgba(0,0,0,0.2); padding: 5px;">
                <h5 class="fw-bold mb-1">Admin</h5>
                <p class="small opacity-50 mb-4">admin@oceanshell.com</p>

                <div class="d-flex w-100 justify-content-around text-center mb-4 pt-2 border-top border-white border-opacity-10">
                    <div>
                        <h5 class="fw-bold m-0">@Model.TongSanPham</h5>
                        <span class="small opacity-50" style="font-size: 0.75rem;">Mặt hàng</span>
                    </div>
                    <div>
                        <h5 class="fw-bold m-0">@Model.DonHoanThanh</h5>
                        <span class="small opacity-50" style="font-size: 0.75rem;">Đã bán</span>
                    </div>
                </div>

                <a href="/admin/them-sua-san-pham" class="glass-btn small py-2 w-100" style="border-radius: 12px; background: rgba(255,255,255,0.1) !important;">Thêm SP</a>
            </div>
        </div>
    </div>

    @* --- 4. BẢNG GIAO DỊCH MỚI --- *@
    <div class="row g-4">
        <div class="col-xl-8">
            <div class="glass-card p-4 h-100 d-flex flex-column" style="border-radius: 20px !important;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="m-0 fw-bold">Giao dịch mới</h5>
                    <i class="bi bi-arrow-clockwise opacity-50 cursor-pointer fs-5" title="Tải lại" onclick="taiLaiDonHang(this)"></i>
                </div>
                <div class="table-responsive flex-grow-1">
                    <table class="glass-table align-middle w-100" style="font-size: 0.9rem;">
                        <tbody>
                            @foreach (var item in Model.DonHangGanDay.Take(4))
                            {
                                <tr>
                                    <td class="py-3 border-bottom border-white border-opacity-10">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-white bg-opacity-10 fw-bold" style="width: 35px; height: 35px; font-size: 0.85rem;">
                                                @(string.IsNullOrEmpty(item.NguoiDung?.HoTen) ? "?" : item.NguoiDung.HoTen.Substring(0, 1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-bold">@item.NguoiDung?.HoTen</div>
                                                <div class="opacity-50" style="font-size: 0.75rem;">#@item.Id</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3 border-bottom border-white border-opacity-10">
                                        <span class="badge rounded-pill fw-normal bg-white bg-opacity-10 px-3 py-1" style="font-size: 0.75rem;">@item.TrangThai</span>
                                    </td>
                                    <td class="py-3 text-end fw-bold border-bottom border-white border-opacity-10">@item.TongTien.ToString("N0")đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="glass-card p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center" style="border-radius: 20px !important;">
                <i class="bi bi-shield-lock mb-3 opacity-75" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-2">Bảo mật</h5>
                <p class="small opacity-50 mb-4">Quản lý mật khẩu và an toàn tài khoản.</p>
                <a href="/admin/cai-dat" class="glass-btn small py-2 w-100" style="border-radius: 12px; background: rgba(255,255,255,0.1) !important;">Thiết lập</a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    function locDoanhThuTheoNam() {
        var selectedYear = document.getElementById("yearFilter").value;
        if (selectedYear) {
            window.location.href = '?nam=' + selectedYear;
        }
    }

    function taiLaiDonHang(iconElement) {
        iconElement.style.transform = "rotate(360deg)";
        iconElement.classList.remove("opacity-50");
        iconElement.classList.add("opacity-100", "text-white");
        setTimeout(function () {
            window.location.reload();
        }, 400);
    }

    document.addEventListener("DOMContentLoaded", function () {
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NhanBieuDo));
        const dataValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DoanhThuTheoNgay));
        const ctx = document.getElementById('revenueLineChart').getContext('2d');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu',
                    data: dataValues,
                    borderColor: 'rgba(255, 255, 255, 0.8)',
                    backgroundColor: 'rgba(255, 255, 255, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 0,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let value = context.parsed.y;
                                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
                            }
                        }
                    }
                },
                scales: {
                    x: { display: false },
                    y: { display: false, beginAtZero: true }
                }
            }
        });
    });
</script>