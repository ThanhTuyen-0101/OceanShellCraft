@model OceanShellCraft.Models.SanPham
@{
    ViewData["Title"] = (Model?.Id > 0 ? "chỉnh sửa sản phẩm" : "thêm sản phẩm mới").ToLower();
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0"><i class="bi bi-box-seam me-2"></i>@ViewData["Title"]</h4>
    </div>

    <div class="glass-card p-4 p-md-5">
        <form id="formSanPham" asp-action="ThemSuaSanPham" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="HinhAnh" />

            <input type="hidden" asp-for="GiaTien" id="GiaTienReal" />
            <input type="hidden" asp-for="GiaKhuyenMai" id="GiaKhuyenMaiReal" />

            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-4">
                        <label class="small opacity-50 mb-1 ps-2">tên sản phẩm *</label>
                        <input asp-for="TenSanPham" type="text" class="glass-input" placeholder="vd: đèn ngủ vỏ ốc xà cừ..." required>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-3">
                            <label class="small opacity-50 mb-1 ps-2">giá gốc (vnđ)</label>
                            <input type="text" id="displayGiaTien" class="glass-input"
                                   value="@(Model?.GiaTien > 0 ? Model.GiaTien.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) : "")"
                                   oninput="formatCurrency(this, 'GiaTienReal')">
                        </div>
                        <div class="col-md-3">
                            <label class="small opacity-50 mb-1 ps-2">giá giảm (vnđ)</label>
                            <input type="text" id="displayGiaKhuyenMai" class="glass-input"
                                   value="@(Model?.GiaKhuyenMai > 0 ? Model.GiaKhuyenMai.Value.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) : "")"
                                   oninput="formatCurrency(this, 'GiaKhuyenMaiReal')" placeholder="bỏ trống nếu không giảm">
                        </div>
                        <div class="col-md-3">
                            <label class="small opacity-50 mb-1 ps-2">số lượng</label>
                            <input asp-for="SoLuong" type="number" class="glass-input no-spinners">
                        </div>
                        <div class="col-md-3">
                            <label class="small opacity-50 mb-1 ps-2">danh mục</label>
                            <select asp-for="DanhMucId" class="glass-input" asp-items="ViewBag.DanhMucList" style="background-color: transparent;">
                                <option value="" style="background: #222;">-- chọn danh mục --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="small opacity-50 mb-1 ps-2">chất liệu</label>
                            <input asp-for="ChatLieu" type="text" class="glass-input" placeholder="vd: vỏ ốc xà cừ">
                        </div>
                        <div class="col-md-6">
                            <label class="small opacity-50 mb-1 ps-2">kích thước</label>
                            <input asp-for="KichThuoc" type="text" class="glass-input" placeholder="vd: 15cm x 20cm">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="small opacity-50 mb-1 ps-2">mô tả sản phẩm</label>
                        <textarea asp-for="MoTa" class="glass-input" rows="5" placeholder="nhập mô tả chi tiết về sản phẩm..."></textarea>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-4 rounded-4" style="border: 1px solid var(--border-light); background: rgba(255,255,255,0.02);">
                        <label class="small opacity-50 d-block mb-3 ps-2">hình ảnh sản phẩm</label>
                        <div class="text-center mb-3">
                            <img id="imgPreview" src="@(string.IsNullOrEmpty(Model?.HinhAnh) ? "/img/no-image.png" : Model.HinhAnh)"
                                 class="img-fluid rounded-3"
                                 style="max-height: 250px; object-fit: cover; border: 1px solid var(--border-light); padding: 5px; background: var(--glass-bg);">
                        </div>
                        <input type="file" name="fileHinhAnh" class="glass-input small" accept="image/*" onchange="previewImage(event)">

                        <hr class="my-4 opacity-25" style="border-color: var(--border-light);">

                        <label class="small opacity-50 d-block mb-2 ps-2">tùy chọn hiển thị</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" asp-for="IsFeatured" id="checkFeatured" style="cursor: pointer;">
                            <label class="form-check-label small opacity-75" for="checkFeatured" style="cursor: pointer;">sản phẩm nổi bật</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-5 pt-3" style="border-top: 1px solid var(--border-light);">
                <a href="/Admin/SanPham" id="btnCancel" class="glass-btn px-4 opacity-75">
                    <i class="bi bi-arrow-left me-2"></i>quay lại
                    <kbd class="ms-2 opacity-50" style="background: transparent; border: 1px solid var(--border-light); font-size: 0.7rem;">f6</kbd>
                </a>
                <button type="submit" id="btnSave" class="glass-btn px-5">
                    <i class="bi bi-save me-2"></i>lưu thông tin
                    <kbd class="ms-2 opacity-50" style="background: transparent; border: 1px solid var(--border-light); font-size: 0.7rem;">f8</kbd>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <style>
        /* ẩn thanh tăng giảm của input number */
        .no-spinners::-webkit-outer-spin-button,
        .no-spinners::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .no-spinners {
            -moz-appearance: textfield;
        }
    </style>

    <script>
        // hàm định dạng tiền tệ việt nam
        function formatCurrency(input, hiddenId) {
            let value = input.value.replace(/\D/g, '');
            document.getElementById(hiddenId).value = value;
            if (value) {
                input.value = parseInt(value).toLocaleString('vi-VN');
            } else {
                input.value = '';
            }
        }

        // hàm xem trước ảnh khi chọn file
        function previewImage(event) {
            const reader = new FileReader();
            const output = document.getElementById('imgPreview');
            reader.onload = function() {
                output.src = reader.result;
            };
            if (event.target.files[0]) reader.readAsDataURL(event.target.files[0]);
        }

        // bắt sự kiện phím tắt hệ thống
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F6') {
                e.preventDefault();
                document.getElementById('btnCancel').click();
            }
            if (e.key === 'F8') {
                e.preventDefault();
                document.getElementById('formSanPham').submit();
            }
        });
    </script>
}