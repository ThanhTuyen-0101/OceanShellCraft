@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Ẩn thanh cuộn cho mượt */
    .hide-scrollbar::-webkit-scrollbar {
        width: 4px;
    }

    .hide-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
    }

    /* Custom Form Controls cho hiệu ứng Kính */
    .glass-form-label {
        color: var(--text-dim);
        font-size: 0.85rem;
        margin-bottom: 0.4rem;
        font-weight: 500;
    }

    .glass-form-control {
        background: rgba(255, 255, 255, 0.08) !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        color: var(--text-pure) !important;
        border-radius: 12px;
        padding: 12px 16px;
        transition: all 0.3s ease;
    }

        .glass-form-control:focus {
            background: rgba(255, 255, 255, 0.15) !important;
            border-color: rgba(255, 255, 255, 0.3) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.1) !important;
            outline: none;
        }

    /* Radio dot custom */
    .gender-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
        margin-left: 8px;
    }

    .dot-inactive {
        background-color: rgba(255, 255, 255, 0.2);
    }

    .dot-active {
        background-color: var(--gt-gold);
    }

    /* Menu cá nhân bên trái */
    .profile-menu-item {
        color: var(--text-pure);
        transition: all 0.3s ease;
        padding: 10px 15px;
        border-radius: 12px;
        cursor: pointer;
    }

        .profile-menu-item:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .profile-menu-item.active {
            font-weight: bold;
        }

    .settings-container-height {
        height: calc(100vh - 120px);
    }
</style>

<div class="settings-container-height overflow-auto hide-scrollbar pe-2">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
        <div class="d-flex align-items-center gap-3">
            <a href="/Admin" class="text-dim text-decoration-none"><i class="bi bi-arrow-left fs-5 hover-white transition"></i></a>
            <nav aria-label="breadcrumb" class="mb-0">
                <ol class="breadcrumb mb-0 align-items-center">
                    <li class="breadcrumb-item"><a href="#" class="text-dim text-decoration-none small">Settings</a></li>
                    <li class="breadcrumb-item active text-pure small fw-bold" aria-current="page">Profile</li>
                </ol>
            </nav>
        </div>

        <div class="d-flex align-items-center gap-3">
            <a href="#" class="social-btn position-relative">
                <i class="bi bi-bell"></i>
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-gold border border-light rounded-circle" style="width: 10px; height: 10px;"></span>
            </a>
            <a href="#" class="social-btn border-0 text-pure fs-4"><i class="bi bi-three-dots"></i></a>
        </div>
    </div>

    <h2 class="fw-bold text-pure mb-4" style="font-family: 'Playfair Display', serif !important;">Profile</h2>

    <div class="row g-4 pb-5">
        <div class="col-lg-4">
            <div class="bento-card p-4 p-xl-5 text-center h-100" style="border-radius: 20px;">

                <div class="position-relative d-inline-block mb-3">
                    <img src="https://i.pravatar.cc/150?img=47" class="rounded-circle object-fit-cover border border-light border-opacity-25 shadow" width="120" height="120" alt="Joy Ezechukwu">
                    <div class="position-absolute bottom-0 end-0 bg-gold rounded-circle d-flex justify-content-center align-items-center cursor-pointer shadow-sm" style="width: 32px; height: 32px; border: 2px solid rgba(18, 43, 39, 1); transform: translate(-5px, -5px);">
                        <i class="bi bi-pencil-fill text-dark" style="font-size: 0.8rem;"></i>
                    </div>
                </div>

                <h4 class="text-pure fw-bold mb-1">Joy Ezechukwu</h4>
                <small class="text-dim d-block mb-4">On Shift · 6h 42m</small>

                <div class="d-flex justify-content-center align-items-center mb-5 border-top border-bottom border-light border-opacity-25 py-3">
                    <div class="pe-4 border-end border-light border-opacity-25">
                        <h4 class="text-pure fw-bold m-0">$2,750</h4>
                        <small class="text-dim">Monthly Sales</small>
                    </div>
                    <div class="ps-4">
                        <h4 class="text-pure fw-bold m-0">128</h4>
                        <small class="text-dim">Orders Served</small>
                    </div>
                </div>

                <div class="text-start d-flex flex-column gap-2">
                    <div class="profile-menu-item active d-flex align-items-center gap-3">
                        <i class="bi bi-person-fill fs-5"></i>
                        <span>Personal information</span>
                    </div>
                    <div class="profile-menu-item d-flex align-items-center gap-3">
                        <i class="bi bi-shield-lock-fill fs-5 opacity-75"></i>
                        <span class="opacity-75">Login & Password</span>
                    </div>
                    <div class="profile-menu-item d-flex align-items-center gap-3 text-danger mt-2">
                        <i class="bi bi-box-arrow-right fs-5"></i>
                        <span>Log out</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="p-lg-4">
                <h4 class="text-pure fw-bold mb-4">Personal information</h4>

                <div class="d-flex align-items-center gap-4 mb-4 pb-2">
                    <div class="d-flex align-items-center text-dim cursor-pointer transition hover-white">
                        <span>Male</span>
                        <span class="gender-dot dot-inactive"></span>
                    </div>
                    <div class="d-flex align-items-center text-pure fw-bold cursor-pointer">
                        <span>Female</span>
                        <span class="gender-dot dot-active"></span>
                    </div>
                </div>

                <form class="row g-4">
                    <div class="col-md-6">
                        <label class="glass-form-label">First Name</label>
                        <input type="text" class="form-control glass-form-control shadow-none" value="Joy">
                    </div>
                    <div class="col-md-6">
                        <label class="glass-form-label">Last Name</label>
                        <input type="text" class="form-control glass-form-control shadow-none" value="Ezechukwu">
                    </div>

                    <div class="col-12">
                        <label class="glass-form-label">Email</label>
                        <div class="position-relative">
                            <input type="email" class="form-control glass-form-control shadow-none pe-5" value="Joyeze999@gmail.com">
                            <div class="position-absolute top-50 end-0 translate-middle-y pe-3 d-flex align-items-center gap-1 text-success fw-medium small">
                                <i class="bi bi-check-circle-fill"></i> Verified
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="glass-form-label">Phone number</label>
                        <input type="text" class="form-control glass-form-control shadow-none" value="+1 (408) 555-9724">
                    </div>
                    <div class="col-md-6">
                        <label class="glass-form-label">Date of Birth</label>
                        <div class="position-relative">
                            <input type="text" class="form-control glass-form-control shadow-none pe-5" value="Jun 23, 1995">
                            <i class="bi bi-calendar3 position-absolute top-50 end-0 translate-middle-y pe-3 text-dim"></i>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="glass-form-label">Location</label>
                        <input type="text" class="form-control glass-form-control shadow-none" value="California, USA">
                    </div>
                    <div class="col-md-6">
                        <label class="glass-form-label">Postal Code</label>
                        <input type="text" class="form-control glass-form-control shadow-none" value="98675">
                    </div>

                    <div class="col-12 mt-5">
                        <button type="button" class="btn btn-gold w-100 rounded-3 py-3 fw-bold fs-6 shadow-sm transition">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>