@model OceanShellCraft.Models.BaiViet
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-3 bg-white" style="min-height: calc(100vh - 60px);">
    <div class="row mb-4">
        <div class="col">
            <h4 class="fw-bold text-danger">@ViewData["Title"]</h4>
        </div>
    </div>

    <form asp-action="ThemSuaBaiViet" method="post" enctype="multipart/form-data">

        <div class="mb-4">
            <label class="form-label text-danger">Hình thức giới thiệu</label>
            <select asp-for="HinhThuc" class="form-select text-muted">
                <option value="intro-Giới thiệu">intro-Giới thiệu</option>
                <option value="Sản phẩm">Sản phẩm</option>
                <option value="Tin tức">Tin tức</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label text-danger">Tiêu đề</label>
            <input asp-for="TieuDe" type="text" class="form-control" placeholder="Nhập tiêu đề" required>
        </div>

        <div class="mb-4">
            <label class="form-label text-danger">Ảnh nền</label>
            <input type="file" name="fileAnhNen" class="form-control" accept="image/*">
            <small class="text-muted">Chọn ảnh từ máy tính của bạn</small>
        </div>

        <div class="mb-4">
            <label class="form-label text-danger">Nội dung tóm tắt</label>
            <textarea asp-for="NoiDungTomTat" class="form-control" rows="2" placeholder="Nhập nội dung tóm tắt"></textarea>
        </div>

        <div class="mb-4">
            <label class="form-label text-danger">Video youtube (Link iframe)</label>
            <textarea asp-for="VideoYoutube" class="form-control" rows="2" placeholder="Nhập iframe youtube"></textarea>
        </div>

        <div class="mb-4">
            <label class="form-label text-danger">Nội dung Chi tiết</label>
            <textarea asp-for="NoiDung" class="form-control" rows="8" placeholder="Nhập nội dung chi tiết bài viết..."></textarea>
        </div>

        <hr />

        <div class="d-flex justify-content-end gap-2 mb-4">
            <a href="/Admin/BaiViet" class="btn btn-outline-primary px-4">
                <i class="bi bi-x-lg me-1"></i> Quay lại (F6)
            </a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-1"></i> Lưu (F8)
            </button>
        </div>
    </form>
</div>