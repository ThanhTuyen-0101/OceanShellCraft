@model OceanShellCraft.Models.BaiViet
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = (Model?.Id == 0 ? "thêm bài viết mới" : "chỉnh sửa bài viết").ToLower();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0">
            <i class="bi bi-journal-plus me-2"></i>@ViewData["Title"]
        </h4>
    </div>

    <div class="glass-card p-4 p-md-5">
        <form id="formBaiViet" asp-action="ThemSuaBaiViet" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="AnhNen" />

            <div class="row mb-4">
                <div class="col-md-4 mb-3 mb-md-0">
                    <label class="small opacity-50 mb-1 ps-2">hình thức giới thiệu *</label>
                    <select asp-for="HinhThuc" class="glass-input" style="background-color: transparent;">
                        <option value="Bài viết" style="background: #222;">bài viết</option>
                        <option value="Cảm hứng" style="background: #222;">cảm hứng</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label class="small opacity-50 mb-1 ps-2">tiêu đề bài viết *</label>
                    <input asp-for="TieuDe" type="text" class="glass-input" placeholder="vd: khám phá vẻ đẹp của đại dương..." required>
                </div>
            </div>

            <div class="mb-4">
                <label class="small opacity-50 mb-1 ps-2">ảnh nền bìa (hero image)</label>
                <input type="file" name="fileAnhNen" class="glass-input mb-2" accept="image/*" onchange="previewImage(event)">

                @if (!string.IsNullOrEmpty(Model?.AnhNen))
                {
                    <div class="d-flex align-items-center opacity-50 small mb-2">
                        <i class="bi bi-link-45deg me-1"></i> đường dẫn hiện tại:
                        <span class="ms-1 text-break">@Model.AnhNen.ToLower()</span>
                    </div>
                }
                else
                {
                    <small class="opacity-50 fst-italic mt-1 d-block">* khuyến nghị ảnh ngang chất lượng cao (1920x1080px)</small>
                }

                <div class="mt-3">
                    <img id="imgPreview"
                         src="@(string.IsNullOrEmpty(Model?.AnhNen) ? "#" : Model.AnhNen)"
                         alt="xem trước"
                         class="rounded-3"
                         style="max-width: 300px; height: 150px; object-fit: cover; display: @(string.IsNullOrEmpty(Model?.AnhNen) ? "none" : "block"); border: 1px solid var(--border-light); padding: 5px; background: var(--glass-bg);" />
                </div>
            </div>

            <div class="mb-4">
                <label class="small opacity-50 mb-1 ps-2">nội dung tóm tắt</label>
                <textarea asp-for="NoiDungTomTat" class="glass-input" rows="3" placeholder="nhập một đoạn mô tả ngắn gọn, súc tích..."></textarea>
            </div>

            <div class="mb-4">
                <label class="small opacity-50 mb-1 ps-2">video youtube (tùy chọn)</label>
                <input asp-for="VideoYoutube" type="text" class="glass-input" placeholder="dán link hoặc id video youtube vào đây...">
            </div>

            <div class="mb-4">
                <label class="small opacity-50 mb-1 ps-2">nội dung chi tiết *</label>
                <textarea asp-for="NoiDung" id="editor" class="glass-input" rows="12" placeholder="nhập nội dung chi tiết bài viết..."></textarea>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-5 pt-3" style="border-top: 1px solid var(--border-light);">
                <a href="/Admin/BaiViet" id="btnCancel" class="glass-btn px-4 opacity-75">
                    <i class="bi bi-x-lg me-2"></i>quay lại
                    <kbd class="ms-2 opacity-50" style="background: transparent; border: 1px solid var(--border-light); font-size: 0.7rem;">f6</kbd>
                </a>
                <button type="submit" id="btnSave" class="glass-btn px-5">
                    <i class="bi bi-check-lg me-2"></i>lưu bài viết
                    <kbd class="ms-2 opacity-50" style="background: transparent; border: 1px solid var(--border-light); font-size: 0.7rem;">f8</kbd>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // 1. chức năng xem trước ảnh bìa
        function previewImage(event) {
            const reader = new FileReader();
            const output = document.getElementById('imgPreview');
            reader.onload = function() {
                output.src = reader.result;
                output.style.display = 'block';
            };
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        // 2. bắt sự kiện phím tắt f6 và f8
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F6') {
                e.preventDefault();
                const btn = document.getElementById('btnCancel');
                if(btn) btn.click();
            }
            if (e.key === 'F8') {
                e.preventDefault();
                const form = document.getElementById('formBaiViet');
                if(form) form.submit();
            }
        });
    </script>
}