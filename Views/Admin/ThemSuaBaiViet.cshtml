@model OceanShellCraft.Models.BaiViet
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model?.Id == 0 ? "Thêm bài viết" : "Sửa bài viết";
}

<style>
    .uniform-text {
        font-size: 1rem !important;
    }

    .input-text-small {
        font-size: 0.9rem !important;
        width: 100%;
    }
</style>

<div class="container-fluid py-4">
    <div class="mb-4">
        <a href="/admin/bai-viet"
           class="d-inline-flex align-items-center text-decoration-none text-white opacity-75"
           style="transition: all 0.3s ease;"
           onmouseover="this.style.opacity='1'; this.style.transform='translateX(-5px)';"
           onmouseout="this.style.opacity='0.75'; this.style.transform='translateX(0)';">
            <i class="bi bi-chevron-left fs-5 me-2"></i>
            <span class="uniform-text">Quay lại trang quản lý bài viết</span>
        </a>
    </div>

    <form id="formBaiViet" action="/admin/them-sua-bai-viet" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AnhNen" />
        <input type="hidden" asp-for="NgayTao" />
        <input type="hidden" asp-for="HinhThuc" value="Bài viết" />

        <div class="row g-4">
            <div class="col-xl-8">
                <div class="glass-card p-4 p-md-5 h-100" style="border-radius: 20px !important;">

                    <div class="mb-4">
                        <label class="opacity-50 mb-1 uniform-text">Tiêu đề *</label>
                        <input asp-for="TieuDe" type="text"
                               class="glass-input p-0 input-text-small"
                               style="border: none !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; border-radius: 0 !important; box-shadow: none !important; background: transparent !important; font-weight: normal !important;"
                               placeholder="Nhập tiêu đề..." required>
                    </div>

                    <div class="mb-4">
                        <label class="opacity-50 mb-1 uniform-text">Tóm tắt</label>
                        <textarea asp-for="NoiDungTomTat"
                                  class="glass-input p-0 input-text-small"
                                  rows="1"
                                  style="border: none !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; border-radius: 0 !important; box-shadow: none !important; background: transparent !important; font-weight: normal !important;"
                                  placeholder="Mô tả ngắn..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="opacity-50 mb-1 uniform-text">YouTube (Tùy chọn)</label>
                        <input asp-for="VideoYoutube" type="text"
                               class="glass-input p-0 input-text-small"
                               style="border: none !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; border-radius: 0 !important; box-shadow: none !important; background: transparent !important; font-weight: normal !important;"
                               placeholder="https://youtube.com/...">
                    </div>

                    <div class="mb-2">
                        <label class="opacity-50 mb-2 uniform-text">Nội dung *</label>
                        <textarea asp-for="NoiDung" id="editor" class="glass-input input-text-small" rows="20" placeholder="Nội dung bài viết..."></textarea>
                    </div>

                </div>
            </div>

            <div class="col-xl-4">
                <div class="d-flex flex-column gap-4 h-100">

                    <div class="glass-card p-4" style="border-radius: 20px !important;">
                        <div class="d-flex justify-content-end align-items-center">
                            <button type="submit" id="btnSave" class="glass-btn py-2 px-4 border-0 bg-white bg-opacity-10 text-white uniform-text" style="border-radius: 8px; font-weight: normal !important;">Lưu (F8)</button>
                        </div>
                    </div>

                    <div class="glass-card p-4 flex-grow-1" style="border-radius: 20px !important;">
                        <div class="mb-3 opacity-75 border-bottom border-white border-opacity-10 pb-2 uniform-text">Ảnh bìa</div>

                        <div class="position-relative text-center p-4 mb-3" style="border: 1px dashed rgba(255,255,255,0.3); border-radius: 12px; background: rgba(0,0,0,0.2);">
                            <input type="file" name="fileAnhNen" accept="image/*" onchange="previewImage(event)" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;">
                            <i class="bi bi-cloud-arrow-up fs-2 opacity-50"></i>
                            <p class="opacity-50 m-0 mt-2 uniform-text">Chọn ảnh</p>
                        </div>

                        <img id="imgPreview"
                             src="@(string.IsNullOrEmpty(Model?.AnhNen) ? "#" : Model.AnhNen)"
                             class="rounded-3 w-100 object-fit-cover"
                             style="height: 180px; display: @(string.IsNullOrEmpty(Model?.AnhNen) ? "none" : "block"); border: 1px solid rgba(255,255,255,0.1);" />
                    </div>

                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/dvd0ycqhxh8p2fzab7n9jlb698blww08dx8k56ao55izih3t/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#editor',
            plugins: 'anchor autolink charmap codesample emoticons image link lists media searchreplace table visualblocks wordcount',
            toolbar: 'undo redo | blocks fontfamily fontsize | italic underline | link image media table | align | numlist bullist | emoticons charmap | removeformat',
            skin: "oxide-dark",
            content_css: "dark",
            height: 500,
            content_style: "body { font-size: 0.9rem; }", 
            setup: function (editor) {
                editor.on('change', function () {
                    tinymce.triggerSave();
                });
            }
        });

        function previewImage(event) {
            const reader = new FileReader();
            const output = document.getElementById('imgPreview');
            reader.onload = function() {
                output.src = reader.result;
                output.style.display = 'block';
            };
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        document.addEventListener('keydown', function(e) {
            
            if (e.key === 'F8' || e.key === 'f8') {
                e.preventDefault();
                const form = document.getElementById('formBaiViet');
                if(form) form.submit();
            }
        });
    </script>
}