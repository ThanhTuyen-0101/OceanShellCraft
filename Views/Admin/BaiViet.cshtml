@model IEnumerable<OceanShellCraft.Models.BaiViet>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0 fw-normal">@ViewData["Title"]</h4>

        <div class="d-flex gap-3 align-items-center">
            <a href="/Admin/ThemSuaBaiViet" id="btnAdd" class="glass-btn small py-1 px-3 fw-normal">
                <i class="bi bi-plus-circle me-1"></i> Thêm mới (F7)
            </a>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive hide-scrollbar">
            <table class="glass-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4 fw-normal" style="width: 10%;">Ảnh nền</th>
                        <th class="fw-normal" style="width: 25%;">Tiêu đề</th>
                        <th class="fw-normal" style="width: 35%;">Nội dung tóm tắt</th>
                        <th class="text-center fw-normal" style="width: 15%;">Tác giả</th>
                        <th class="text-end pe-4 fw-normal" style="width: 15%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <img src="@(string.IsNullOrEmpty(item.AnhNen) ? "/img/no-image.png" : item.AnhNen)"
                                         class="rounded-circle object-fit-cover"
                                         style="width: 45px; height: 45px; border: 1px solid var(--border-light);" alt="thumbnail" />
                                </td>
                                <td>
                                    @* Bỏ ToLower() để giữ định dạng tiêu đề chuẩn *@
                                    <span class="opacity-100">@item.TieuDe</span>
                                </td>
                                <td>
                                    <span class="opacity-75 small">
                                        @(string.IsNullOrEmpty(item.NoiDungTomTat) ? "" : (item.NoiDungTomTat.Length > 80 ? item.NoiDungTomTat.Substring(0, 80) + "..." : item.NoiDungTomTat))
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="small opacity-75">Admin</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="ThemSuaBaiViet" asp-route-id="@item.Id" class="glass-btn py-1 px-2 fw-normal" title="Sửa">
                                            <i class="bi bi-pencil small"></i>
                                        </a>
                                        <form asp-action="XoaBaiViet" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?')" style="display:inline;">
                                            <button type="submit" class="glass-btn py-1 px-2 fw-normal opacity-75" title="Xóa">
                                                <i class="bi bi-trash small"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 opacity-50 fw-normal fw-italic">Không có dữ liệu bài viết</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 opacity-75 small" style="border-top: 1px solid var(--border-light);">
            <span>Hiển thị @Model.Count() bài viết</span>
            <div class="d-flex gap-2">
                <button class="glass-btn small py-1 px-3 border-0 opacity-50 fw-normal">Trước</button>
                <button class="glass-btn small py-1 px-3 border-0 fw-normal">Sau</button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Bắt sự kiện phím tắt F7 để thêm mới bài viết
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F7') {
                e.preventDefault();
                const btn = document.getElementById('btnAdd');
                if(btn) btn.click();
            }
        });
    </script>
}