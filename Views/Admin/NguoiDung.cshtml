@model IEnumerable<OceanShellCraft.Models.NguoiDung>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid py-4">
    @* --- Đầu trang --- *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="m-0 fw-normal">@ViewData["Title"]</h4>
        </div>

        @* --- Form Tìm kiếm thay cho nút Thêm mới --- *@
        <div class="d-flex gap-2" style="width: 100%; max-width: 400px;">
            <form asp-action="NguoiDung" method="get" class="d-flex w-100 position-relative">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="glass-input pill-style pe-5" placeholder="Tìm kiếm theo Tên hoặc Email..." />
                <button type="submit" class="glass-btn position-absolute end-0 top-0 bottom-0 m-1 px-3" style="border-radius: 40px;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    @* --- Bảng dữ liệu --- *@
    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="glass-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 40px;"><input type="checkbox" class="form-check-input" id="selectAll"></th>
                        <th class="fw-normal">Họ và tên</th>
                        <th class="fw-normal">Email (Tài khoản)</th>
                        <th class="fw-normal">Số điện thoại</th>
                        <th class="text-center fw-normal">Vai trò</th>
                        <th class="text-end pe-4 fw-normal">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <input type="checkbox" class="form-check-input item-checkbox" value="@item.Id">
                                </td>
                                <td>
                                    @* Nếu không có tên, hiển thị mờ 'Chưa cập nhật' *@
                                    @if (!string.IsNullOrEmpty(item.HoTen))
                                    {
                                        <div class="fw-bold">@item.HoTen</div>
                                    }
                                    else
                                    {
                                        <div class="fw-normal opacity-50 fst-italic">Chưa cập nhật</div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-normal">@item.Email</div>
                                </td>
                                <td>
                                    <div class="fw-normal @(string.IsNullOrEmpty(item.SoDienThoai) ? "opacity-50 fst-italic" : "")">
                                        @(string.IsNullOrEmpty(item.SoDienThoai) ? "Chưa có SDT" : item.SoDienThoai)
                                    </div>
                                </td>
                                <td class="text-center">
                                    @* Phân biệt vai trò bằng độ mờ và class glass-effect thay vì màu sắc *@
                                    @if (item.VaiTro == "Admin")
                                    {
                                        <span class="badge glass-effect px-3 py-2 fw-bold">Quản trị viên</span>
                                    }
                                    else
                                    {
                                        <span class="badge glass-effect px-3 py-2 fw-normal opacity-75">Khách hàng</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @* Thay vì sửa/xóa, với user thường xem chi tiết lịch sử mua hàng hoặc cấp quyền *@
                                        <a asp-action="SuaNguoiDung" asp-route-id="@item.Id" class="glass-btn p-1 px-2 fw-normal" title="Chỉnh sửa">
                                            <i class="bi bi-pencil small"></i>
                                        </a>
                                        @if (item.VaiTro != "Admin")
                                        {
                                            <a asp-action="XoaNguoiDung" asp-route-id="@item.Id" class="glass-btn p-1 px-2 fw-normal" onclick="return confirm('Xác nhận xóa tài khoản này? Mọi dữ liệu liên quan có thể bị mất.');" title="Xóa người dùng">
                                                <i class="bi bi-trash small"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 opacity-50">Không tìm thấy người dùng nào phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý Checkbox chọn tất cả
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.item-checkbox');

        selectAll.addEventListener('change', function() {
            checkboxes.forEach(cb => cb.checked = this.checked);
        });
    </script>
}