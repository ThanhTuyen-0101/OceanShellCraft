@model OceanShellCraft.Models.ViewModels.CaiDatViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cài đặt";
}

<div class="container-fluid py-5">
    <div class="mb-5 ps-3 border-start border-info border-2">
        <h4 class="fw-normal m-0 text-white opacity-75">
            <i class="bi bi-sliders2-vertical me-2"></i>Cấu hình hệ thống
        </h4>
        <p class="text-white-50 mb-0 small">Chọn mục để thiết lập.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <a href="/admin/quan-ly-danh-muc" class="text-decoration-none h-100 d-block">
                <div class="glass-card h-100 rounded-4 p-4 text-center border-0 shadow-sm">
                    <div class="mb-3">
                        <i class="bi bi-tags fs-1 text-white opacity-50"></i>
                    </div>
                    <h5 class="fw-normal text-white mb-2">Danh mục</h5>
                    <p class="small text-white-50 mb-0">Quản lý nhóm sản phẩm</p>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="/admin/quan-ly-bien-the" class="text-decoration-none h-100 d-block">
                <div class="glass-card h-100 rounded-4 p-4 text-center border-0 shadow-sm">
                    <div class="mb-3">
                        <i class="bi bi-box-seam fs-1 text-white opacity-50"></i>
                    </div>
                    <h5 class="fw-normal text-white mb-2">Biến thể</h5>
                    <p class="small text-white-50 mb-0">Phân loại sản phẩm</p>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="#" class="text-decoration-none h-100 d-block">
                <div class="glass-card h-100 rounded-4 p-4 text-center border-0 shadow-sm">
                    <div class="mb-3">
                        <i class="bi bi-truck fs-1 text-white opacity-50"></i>
                    </div>
                    <h5 class="fw-normal text-white mb-2">Vận chuyển</h5>
                    <p class="small text-white-50 mb-0">Phí ship và khu vực</p>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a href="#" class="text-decoration-none h-100 d-block">
                <div class="glass-card h-100 rounded-4 p-4 text-center border-0 shadow-sm">
                    <div class="mb-3">
                        <i class="bi bi-shield-lock fs-1 text-white opacity-50"></i>
                    </div>
                    <h5 class="fw-normal text-white mb-2">Phân quyền</h5>
                    <p class="small text-white-50 mb-0">Vai trò nhân viên</p>
                </div>
            </a>
        </div>
    </div>
</div>