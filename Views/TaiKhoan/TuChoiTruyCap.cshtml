@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container d-flex flex-column justify-content-center align-items-center min-vh-100 text-center py-5">
    <div class="luxury-card shadow-lg p-5" style="max-width: 500px;">
        <h1 class="display-1 text-danger mb-3"><i class="bi bi-shield-lock-fill"></i></h1>
        <h2 class="luxury-title fs-3 mb-3">Truy Cập Bị Từ Chối</h2>
        <p class="text-white-50 mb-4">
            Rất tiếc, tài khoản của bạn không có đặc quyền để xem khu vực này của OceanShellCraft.
        </p>
        <a asp-controller="TrangChu" asp-action="TrangChu" class="btn-luxury-solid w-100 py-3 text-decoration-none fs-6">
            <i class="bi bi-arrow-left me-2"></i> Trở về Trang Chủ
        </a>
    </div>
</div>