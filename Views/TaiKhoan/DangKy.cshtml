@model OceanShellCraft.Models.ViewModels.DangKyViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">
                    <h2 class="fw-bold text-center mb-4">Đăng Ký</h2>
                    <form asp-action="DangKy" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="HoTen" class="form-control" placeholder="Họ tên" />
                            <label asp-for="HoTen">Họ và Tên</label>
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        @* Ô Mật khẩu có con mắt *@
                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="MatKhau" type="password" class="form-control" id="pass" placeholder="Mật khẩu" />
                            <label asp-for="MatKhau">Mật khẩu</label>
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 fs-5"
                               id="eye-pass" style="cursor: pointer; z-index: 10;"></i>
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>

                        @* Ô Xác nhận có con mắt *@
                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="NhapLaiMatKhau" type="password" class="form-control" id="re-pass" placeholder="Nhập lại" />
                            <label asp-for="NhapLaiMatKhau">Xác nhận mật khẩu</label>
                            <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 fs-5"
                               id="eye-re-pass" style="cursor: pointer; z-index: 10;"></i>
                            <span asp-validation-for="NhapLaiMatKhau" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-3">Đăng Ký</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function enableToggle(eyeId, inputId) {
            const eye = document.getElementById(eyeId);
            const input = document.getElementById(inputId);
            eye.addEventListener('click', () => {
                const type = input.type === 'password' ? 'text' : 'password';
                input.type = type;
                eye.classList.toggle('bi-eye');
                eye.classList.toggle('bi-eye-slash');
            });
        }
        enableToggle('eye-pass', 'pass');
        enableToggle('eye-re-pass', 're-pass');
    </script>
}