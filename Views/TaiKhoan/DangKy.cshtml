@model OceanShellCraft.Models.ViewModels.DangKyViewModel
@{
    ViewData["Title"] = "Đăng ký";
    ViewData["HideHeaderFooter"] = true;
}

<div class="login-scope container-fluid g-0">
    <div class="row g-0 min-vh-100">

        <div class="col-lg-6 d-flex flex-column justify-content-center p-5 position-relative">
            <div class="my-auto animate__animated animate__fadeInLeft">
                <h1 class="display-3 mb-0" style="line-height: 1.1;">
                    Tham gia ngay <br />cùng OceanShellCraft
                </h1>
            </div>

            <div class="mt-auto animate__animated animate__fadeInUp">
                <div class="glass-card p-3 px-4 d-inline-block">
                    <p class="mb-1 small opacity-75">Đã có tài khoản?</p>
                    <a href="/dang-nhap" class="text-decoration-none fs-5">
                        Đăng nhập <i class="bi bi-chevron-right small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-6 glass-effect d-flex align-items-center justify-content-center p-4 p-md-5 border-start-0 border-top-0 border-bottom-0 border-end-0">
            <div class="w-100" style="max-width: 420px;">

                <h2 class="mb-4 fs-1">Đăng ký</h2>

                <form action="/dang-ky" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="mb-1 ps-2 small opacity-75">Họ và tên</label>
                        <input asp-for="HoTen" class="glass-input pill-style" placeholder="Nhập họ tên của bạn" />
                        <span asp-validation-for="HoTen" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-3">
                        <label class="mb-1 ps-2 small opacity-75">E-mail</label>
                        <input asp-for="Email" class="glass-input pill-style" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-3">
                        <label class="mb-1 ps-2 small opacity-75">Mật khẩu</label>
                        <div class="position-relative d-flex align-items-center">
                            <input asp-for="MatKhau" type="password" id="pass" class="glass-input pill-style w-100 pe-5" placeholder="••••••••" />
                            <button class="position-absolute end-0 me-3 p-0" type="button" onclick="togglePass('pass', 'eye-pass')" style="background: transparent; border: none; outline: none; color: var(--text-main);">
                                <i class="bi bi-eye-slash opacity-50" id="eye-pass"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-4">
                        <label class="mb-1 ps-2 small opacity-75">Xác nhận mật khẩu</label>
                        <div class="position-relative d-flex align-items-center">
                            <input asp-for="NhapLaiMatKhau" type="password" id="re-pass" class="glass-input pill-style w-100 pe-5" placeholder="••••••••" />
                            <button class="position-absolute end-0 me-3 p-0" type="button" onclick="togglePass('re-pass', 'eye-re-pass')" style="background: transparent; border: none; outline: none; color: var(--text-main);">
                                <i class="bi bi-eye-slash opacity-50" id="eye-re-pass"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NhapLaiMatKhau" class="text-danger small ms-2"></span>
                    </div>

                    <button type="submit" class="glass-btn w-100 py-2 mb-4 fs-5">
                        Tạo tài khoản
                    </button>

                    <p class="text-center opacity-50 small mb-4">Hoặc đăng ký với</p>

                    <div class="d-flex justify-content-center gap-3">
                        <a href="/login-google" class="glass-circle"><i class="bi bi-google"></i></a>
                    </div>

                    <div class="text-center mt-4">
                        <a asp-controller="TrangChu" asp-action="TrangChu" class="text-decoration-none small opacity-75">
                            Quay lại trang chủ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}