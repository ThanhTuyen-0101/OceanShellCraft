@model OceanShellCraft.Models.ViewModels.QuenMatKhauVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    ViewData["HideHeaderFooter"] = true;
}

<div class="login-scope container-fluid g-0">
    <div class="row g-0 min-vh-100">
        <div class="col-lg-6 d-flex flex-column justify-content-center p-5 position-relative">
            <div class="my-auto animate__animated animate__fadeInLeft">
                <h1 class="display-3 mb-0" style="line-height: 1.1;">Bảo mật <br />tài khoản</h1>
                <p class="mt-4 opacity-75">Hãy tạo một mật khẩu mới mạnh mẽ để bảo vệ thông tin của bạn.</p>
            </div>
        </div>

        <div class="col-lg-6 glass-effect d-flex align-items-center justify-content-center p-4 p-md-5">
            <div class="w-100" style="max-width: 420px;">
                <h2 class="mb-5 fs-1">Mật khẩu mới</h2>

                @if (ViewBag.Loi != null)
                {
                    <div class="alert alert-danger bg-danger bg-opacity-10 border-0 text-white small mb-4">
                        @ViewBag.Loi
                    </div>
                }

                <form action="/dat-lai-mat-khau" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="mb-2 ps-2 small opacity-75">Mật khẩu mới</label>
                        <div class="position-relative d-flex align-items-center">
                            <input asp-for="MatKhauMoi" type="password" id="pass" class="glass-input pill-style w-100 pe-5" placeholder="••••••••" required />
                            <button class="position-absolute end-0 me-3 p-0" type="button" onclick="togglePass('pass', 'eye-pass')" style="background: transparent; border: none; outline: none; color: var(--text-main);">
                                <i class="bi bi-eye-slash opacity-50" id="eye-pass"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="mb-2 ps-2 small opacity-75">Nhập lại mật khẩu</label>
                        <div class="position-relative d-flex align-items-center">
                            <input asp-for="NhapLaiMatKhau" type="password" id="re-pass" class="glass-input pill-style w-100 pe-5" placeholder="••••••••" required />
                            <button class="position-absolute end-0 me-3 p-0" type="button" onclick="togglePass('re-pass', 'eye-re-pass')" style="background: transparent; border: none; outline: none; color: var(--text-main);">
                                <i class="bi bi-eye-slash opacity-50" id="eye-re-pass"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="glass-btn w-100 py-2 mb-4 fs-5">
                        Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}