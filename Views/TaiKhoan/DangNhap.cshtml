@model OceanShellCraft.Models.ViewModels.DangNhapViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["HideHeaderFooter"] = true;
}

<div class="login-scope container-fluid g-0">
    <div class="row g-0 min-vh-100">

        <div class="col-lg-6 d-flex flex-column justify-content-center p-5 position-relative">
            <div class="my-auto animate__animated animate__fadeInLeft">
                <h1 class="display-3 mb-0" style="line-height: 1.1;">
                    Đăng ký ngay <br />để mua hàng
                </h1>
            </div>

            <div class="mt-auto animate__animated animate__fadeInUp">
                <div class="glass-card p-3 px-4 d-inline-block">
                    <p class="mb-1 small opacity-75">Chưa có tài khoản?</p>
                    <a asp-controller="TaiKhoan" asp-action="DangKy" class="text-decoration-none fs-5">
                        Đăng ký <i class="bi bi-chevron-right small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-6 glass-effect d-flex align-items-center justify-content-center p-4 p-md-5 border-start-0 border-top-0 border-bottom-0 border-end-0">
            <div class="w-100" style="max-width: 420px;">

                <h2 class="mb-5 fs-1">Đăng nhập</h2>

                <form asp-action="DangNhap" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="mb-2 ps-2 small opacity-75">E-mail</label>
                        <input asp-for="Email" class="glass-input pill-style" placeholder="Tên đăng nhập / Email" />
                        <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-5">
                        <label class="mb-2 ps-2 small opacity-75">Mật khẩu</label>
                        <div class="position-relative d-flex align-items-center">
                            <input asp-for="MatKhau" type="password" id="login-pass" class="glass-input pill-style w-100 pe-5" placeholder="••••••••" />
                            <button class="position-absolute end-0 me-3 p-0" type="button" id="togglePassword" style="background: transparent; border: none; outline: none; color: var(--text-main);">
                                <i class="bi bi-eye-slash opacity-50" id="eye-icon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small ms-2"></span>
                    </div>

                    <button type="submit" class="glass-btn w-100 py-2 mb-4 fs-5">
                        Đăng nhập
                    </button>

                    <p class="text-center opacity-50 small mb-4">Hoặc đăng nhập với</p>

                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="glass-circle"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="glass-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="glass-circle"><i class="bi bi-google"></i></a>
                    </div>

                    <div class="text-center mt-5">
                        <a asp-controller="TrangChu" asp-action="TrangChu" class="text-decoration-none small opacity-75">
                            Quay lại trang chủ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('#togglePassword').addEventListener('click', function () {
            const passInput = document.querySelector('#login-pass');
            const icon = document.querySelector('#eye-icon');
            passInput.type = passInput.type === 'password' ? 'text' : 'password';

            // Chuyển đổi class icon giống hệt trang đăng ký
            if (passInput.type === 'password') {
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        });
    </script>
}