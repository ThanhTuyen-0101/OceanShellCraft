@model OceanShellCraft.Models.ViewModels.DangNhapViewModel
@{
    ViewData["Title"] = "Đăng Nhập";
    ViewData["HideHeaderFooter"] = true;
}

<div class="login-scope container-fluid g-0">
    <div class="row g-0 min-vh-100">

        <div class="col-lg-6 d-flex flex-column justify-content-center p-5 position-relative">
            <div class="my-auto animate__animated animate__fadeInLeft">
                <h1 class="display-3 fw-bold text-white mb-0" style="line-height: 1.1;">
                    Đăng kí ngay <br />để mua hàng
                </h1>
            </div>

            <div class="mt-auto animate__animated animate__fadeInUp">
                <div class="glass-sub-box p-3 px-4 rounded-4 d-inline-block">
                    <p class="mb-1 small opacity-75 text-white">Chưa có tài khoản?</p>
                    <a asp-controller="TaiKhoan" asp-action="DangKy" class="text-white text-decoration-none fw-bold fs-5">
                        đăng ký <i class="bi bi-chevron-right small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-6 glass-panel d-flex align-items-center justify-content-center p-4 p-md-5">
            <div class="w-100" style="max-width: 420px;">

                <h2 class="text-white mb-5 fw-normal fs-1">Đăng nhập</h2>

                <form asp-action="DangNhap" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="text-white mb-2 ps-2 small">E-mail</label>
                        <input asp-for="Email" class="form-control pill-input" placeholder="Tên đăng nhập / Email" />
                        <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-5">
                        <label class="text-white mb-2 ps-2 small">Password</label>
                        <div class="position-relative">
                            <input asp-for="MatKhau" type="password" id="login-pass" class="form-control pill-input" placeholder="••••••••" />
                            <button class="btn btn-link text-white opacity-50 p-0 position-absolute end-0 top-50 translate-middle-x me-3 shadow-none border-0" type="button" id="togglePassword">
                                <i class="bi bi-eye-slash" id="eye-icon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small ms-2"></span>
                    </div>

                    <button type="submit" class="btn btn-light w-100 py-2 rounded-pill fw-bold text-primary mb-4 shadow-sm">
                        Đăng Nhập
                    </button>

                    <p class="text-center text-white-50 small mb-4">hoặc đăng nhập với</p>

                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="social-circle"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-circle"><i class="bi bi-google"></i></a>
                    </div>

                    <div class="text-center mt-5">
                        <a asp-controller="TrangChu" asp-action="TrangChu" class="text-white-50 text-decoration-none small">
                            Quay lại trang chủ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('#togglePassword').addEventListener('click', function () {
            const passInput = document.querySelector('#login-pass');
            const icon = document.querySelector('#eye-icon');
            passInput.type = passInput.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('bi-eye');
            icon.classList.toggle('bi-eye-slash');
        });
    </script>
}