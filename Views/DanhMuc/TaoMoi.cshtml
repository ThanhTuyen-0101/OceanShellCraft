@model OceanShellCraft.Models.DanhMuc

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Thêm Loại Sản Phẩm Mới</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="TaoMoi">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên Danh Mục</label>
                            <input asp-for="TenDanhMuc" class="form-control" placeholder="VD: Đèn Trang Trí" required />
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Lưu Danh Mục</button>
                            <a asp-action="DanhSach" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>