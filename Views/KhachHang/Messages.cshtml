@{
    ViewData["Title"] = "Hỗ trợ trực tuyến";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";
    // Lấy tên khách hàng từ hệ thống
    var customerName = User.Identity?.Name ?? "Khách hàng";
}

<style>
    /* Chat Bubble CSS từ thiết kế của bạn */
    .chat-bubble {
        max-width: 75%;
        padding: 12px 18px;
        font-size: 0.95rem;
        backdrop-filter: blur(10px);
    }

        .chat-bubble.received {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0px 20px 20px 20px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .chat-bubble.sent {
            background: #c5a059;
            color: #1a1612;
            border-radius: 20px 0px 20px 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            font-weight: 500;
        }

    .chat-input-area {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
    }

    .chat-area-height {
        height: calc(100vh - 180px);
    }
</style>

<div class="bento-card p-0 d-flex flex-column chat-area-height overflow-hidden">
    <div class="p-3 border-bottom border-light border-opacity-25 d-flex justify-content-between align-items-center bg-black bg-opacity-25">
        <div class="d-flex align-items-center gap-3">
            <div class="position-relative">
                <img src="/img/logo-small.jpg" onerror="this.src='https://i.pravatar.cc/150?img=11'" class="rounded-circle object-fit-cover" width="45" height="45">
                <span class="position-absolute bottom-0 end-0 bg-success border border-dark rounded-circle" style="width: 12px; height: 12px;"></span>
            </div>
            <div>
                <h6 class="m-0 text-white fw-bold">OceanShellCraft</h6>
                <small class="text-success" style="font-size: 0.8rem;">Đang trực tuyến</small>
            </div>
        </div>
    </div>

    <div id="customer-chat-content" class="flex-grow-1 p-4 overflow-auto d-flex flex-column gap-3 hide-scrollbar">
        <div class="text-center mb-3">
            <span class="badge bg-black bg-opacity-25 fw-normal text-white-50 px-3 py-2 rounded-pill">Chào mừng @customerName đến với OceanShellCraft</span>
        </div>

        <div class="d-flex gap-3">
            <img src="https://i.pravatar.cc/150?img=11" class="rounded-circle align-self-end" width="35" height="35">
            <div>
                <small class="text-white-50 mb-1 d-block ms-1">OceanShellCraft</small>
                <div class="chat-bubble received">
                    Xin chào **@customerName**, chúng tôi có thể giúp gì cho bạn?
                </div>
            </div>
        </div>
    </div>

    <div class="p-3 border-top border-light border-opacity-25 bg-black bg-opacity-10">
        <div class="chat-input-area p-2 rounded-pill d-flex align-items-center gap-2">
            <input type="text" id="cust-msg-input" class="form-control bg-transparent border-0 text-white shadow-none ps-3" placeholder="Nhập tin nhắn...">
            <button id="cust-send-btn" class="btn btn-warning rounded-circle d-flex align-items-center justify-content-center p-0" style="width: 40px; height: 40px; background-color: #c5a059;">
                <i class="bi bi-send-fill text-dark"></i>
            </button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        // Elements
        const liveChatInput = document.getElementById('liveChatInput');
        const liveChatSendBtn = document.getElementById('liveChatSendBtn');
        const liveChatBody = document.getElementById('liveChatBody');
        const liveToggleBtn = document.getElementById('liveChatToggleBtn');
        const liveWindow = document.getElementById('liveChatWindow');
        const liveCloseBtn = document.getElementById('liveChatCloseBtn');

        // Lấy tên khách hàng từ Razor (Nếu dùng trong file .cshtml)
        const customerName = "@(User.Identity?.Name ?? "Khách vãng lai")";

        // 1. Khởi động kết nối
        connection.start().catch(err => console.error("SignalR Connection Error: ", err));

        // 2. Lắng nghe tin nhắn từ Server
        connection.on("ReceiveMessage", function (userId, userName, message, role, time) {
            // Đối với khách hàng:
            // - Nếu role là Admin -> Đây là tin nhắn nhận được (Received)
            // - Nếu role là KhachHang và là chính mình nhắn -> Đây là tin nhắn đã gửi (Sent)

            const isMe = (role === "KhachHang" && userName === customerName);
            const isAdmin = (role === "Admin");

            // Chỉ hiển thị nếu là tin nhắn của Admin trả lời mình hoặc chính mình nhắn
            // (Trong bài toán đơn giản này, chúng ta lọc theo userName)
            if (isAdmin || isMe) {
                appendLiveMessage(userName, message, isMe, time);
            }
        });

        // 3. Hàm hiển thị tin nhắn vào khung chat widget
        function appendLiveMessage(user, text, isUser, time) {
            const align = isUser ? 'justify-content-end' : 'justify-content-start';
            const bgStyle = isUser
                ? 'background: #c5a059; color: #1a1612; font-weight: 500;'
                : 'background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2);';

            const msgHTML = `
                <div class="d-flex mb-3 ${align}">
                    <div class="d-flex flex-column ${isUser ? 'align-items-end' : 'align-items-start'}">
                        <small class="text-white-50 mb-1" style="font-size: 0.7rem;">${isUser ? 'Bạn' : 'OceanShellCraft'}</small>
                        <div class="p-2 rounded-3" style="${bgStyle} max-width: 85%; font-size: 0.9rem;">
                            ${text}
                        </div>
                        <small class="text-white-50 mt-1" style="font-size: 0.6rem;">${time || 'Vừa xong'}</small>
                    </div>
                </div>`;

            liveChatBody.insertAdjacentHTML('beforeend', msgHTML);
            liveChatBody.scrollTop = liveChatBody.scrollHeight;
        }

        // 4. Gửi tin nhắn
        async function sendLiveMessage() {
            const text = liveChatInput.value.trim();
            if (text === "") return;

            try {
                // Gọi hàm CustomerSendMessage trong Hub
                await connection.invoke("CustomerSendMessage", text);
                liveChatInput.value = '';
            } catch (err) {
                console.error("Gửi tin nhắn thất bại: ", err);
            }
        }

        liveChatSendBtn.addEventListener('click', sendLiveMessage);
        liveChatInput.addEventListener('keypress', e => { if (e.key === 'Enter') sendLiveMessage(); });

        // Logic ẩn hiện cửa sổ
        liveToggleBtn.addEventListener('click', () => liveWindow.classList.toggle('d-none'));
        liveCloseBtn.addEventListener('click', () => liveWindow.classList.add('d-none'));
    });
</script>