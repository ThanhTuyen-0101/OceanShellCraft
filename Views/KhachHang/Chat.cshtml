@model List<OceanShellCraft.Models.TinNhan>
@{
    ViewData["Title"] = "hỗ trợ trực tuyến";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";
}

<div class="glass-card p-0 d-flex flex-column overflow-hidden" style="height: calc(100vh - 150px);">

    <div class="p-3 d-flex align-items-center" style="border-bottom: 1px solid var(--border-light);">
        <div class="glass-circle me-3" style="width: 45px; height: 45px; overflow: hidden; border: 1px solid var(--border-light);">
            <img src="/img/logo-small.jpg" alt="logo" width="45" height="45">
        </div>
        <div>
            <h6 class="m-0">oceanshellcraft support</h6>
            <small class="opacity-75"><i class="bi bi-circle-fill me-1" style="color: #28a745; font-size: 0.5rem;"></i> Trực tuyến</small>
        </div>
    </div>

    <div id="customer-chat-content" class="flex-grow-1 p-4 overflow-auto d-flex flex-column gap-3 hide-scrollbar">
        @foreach (var msg in Model)
        {
            bool isMe = !msg.IsAdmin;
            <div class="d-flex gap-3 @(isMe ? "justify-content-end" : "")">
                @if (!isMe)
                {
                    <div class="glass-circle align-self-end" style="width: 35px; height: 35px; flex-shrink: 0;">
                        <img src="/img/logo-small.jpg" class="rounded-circle" width="35" height="35" style="opacity: 0.8;">
                    </div>
                }
                <div style="max-width: 75%;">
                    <small class="opacity-50 mb-1 d-block @(isMe ? "text-end" : "")">@(isMe ? "bạn" : "oceanshellcraft")</small>
                    <div class="chat-bubble-sm @(isMe ? "sent-sm" : "received-sm")">
                        @msg.NoiDung?.ToLower()
                    </div>
                    <small class="opacity-50 mt-1 d-block @(isMe ? "text-end" : "")" style="font-size: 0.7rem;">@msg.ThoiGian.ToString("HH:mm")</small>
                </div>
            </div>
        }
    </div>

    <div class="p-3">
        <div class="d-flex gap-2 align-items-center">
            <input type="text" id="cust-page-input" class="glass-input pill-style flex-grow-1" placeholder="nhập tin nhắn...">
            <button id="cust-page-send-btn" class="glass-circle" style="width: 45px; height: 45px; flex-shrink: 0;">
                <i class="bi bi-send"></i>
            </button>
        </div>
    </div>
</div>