@model OceanShellCraft.Models.NguoiDung

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";

    var avatarUrl = string.IsNullOrEmpty(Model.AnhDaiDien)
        ? "/img/meo.jpg"
        : Model.AnhDaiDien;
}

<div class="container-fluid py-4 min-vh-100">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="bento-card d-flex flex-column align-items-center text-center p-4 p-xl-5 h-100">
                <div class="position-relative mb-4">
                    <img id="avatarPreview" src="@avatarUrl"
                         class="rounded-circle object-fit-cover border border-light border-opacity-25 shadow"
                         width="160" height="160" style="padding: 3px;">
                </div>

                <h5 class="fw-bold text-white mb-1 tracking-wider">@Model.HoTen</h5>
                <p class="text-white opacity-50 small mb-4">Thành viên @Model.VaiTro</p>

                <div class="w-100 mt-auto">
                    <label for="AvatarUpload" class="btn btn-white-outline w-100 py-2 m-0 shadow-sm" style="cursor: pointer;">
                        <i class="bi bi-camera me-2"></i> Đổi ảnh đại diện
                    </label>
                    <input type="file" id="AvatarUpload" class="d-none" accept="image/*" onchange="autoUploadAvatar(event)">
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <form asp-action="CapNhatHoSo" asp-controller="KhachHang" method="post" class="d-flex flex-column h-100 gap-4">
                <input type="hidden" asp-for="Id" id="UserId" />

                <div class="bento-card p-4 p-xl-5">
                    <h5 class="fw-bold text-white opacity-75 mb-4 tracking-wider">
                        <i class="bi bi-person-lines-fill me-2 fs-5"></i>Thông tin cá nhân
                    </h5>
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label text-white opacity-50 small">Họ và tên</label>
                            <input asp-for="HoTen" class="form-control rounded-3 p-3" placeholder="Nhập họ tên...">
                            <span asp-validation-for="HoTen" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white opacity-50 small">Ngày sinh</label>
                            <input asp-for="NgaySinh" type="date" class="form-control rounded-3 p-3" style="color-scheme: dark;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white opacity-50 small">Giới tính</label>
                            <input type="hidden" asp-for="GioiTinh" id="GioiTinhHidden" />

                            <div class="dropdown w-100">
                                <button class="form-select bg-transparent text-white border-light border-opacity-25 rounded-3 p-3 shadow-none no-hover-bg text-start d-flex justify-content-between align-items-center w-100"
                                        type="button" data-bs-toggle="dropdown" id="GioiTinhDropdownBtn">
                                    -- Chọn giới tính --
                                </button>
                                <ul class="dropdown-menu glass-effect border-light p-2 mt-1 w-100 shadow-lg">
                                    <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Nam">Nam</a></li>
                                    <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Nữ">Nữ</a></li>
                                    <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Khác">Khác</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bento-card p-4 p-xl-5">
                    <h5 class="fw-bold text-white opacity-75 mb-4 tracking-wider">
                        <i class="bi bi-geo-alt me-2 fs-5"></i>Liên hệ & Giao hàng
                    </h5>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-white opacity-50 small">Số điện thoại</label>
                            <input asp-for="SoDienThoai" class="form-control rounded-3 p-3" placeholder="Nhập số điện thoại...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white opacity-50 small">Địa chỉ Email</label>
                            <input asp-for="Email" class="form-control rounded-3 opacity-50 p-3" readonly style="cursor: not-allowed;">
                        </div>
                    </div>
                </div>

                <div class="text-end mt-2">
                    <button type="submit" class="btn btn-white-outline text-white px-5 py-3 rounded-pill fw-bold shadow hover-scale">
                        <i class="bi bi-check2-circle me-2"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // JS xử lý Upload và Dropdown giữ nguyên như cũ của bạn
        async function autoUploadAvatar(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
            reader.readAsDataURL(file);

            const formData = new FormData();
            formData.append('AvatarFile', file);
            formData.append('UserId', document.getElementById('UserId').value);

            try {
                const response = await fetch('/TaiKhoan/UploadAvatarAjax', { method: 'POST', body: formData });
                const result = await response.json();
                if(!result.success) alert("Lỗi: " + result.message);
            } catch (error) { alert('Lỗi kết nối server.'); }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const dropdownItems = document.querySelectorAll('.dropdown-menu .dropdown-item');
            const hiddenInput = document.getElementById('GioiTinhHidden');
            const dropdownBtn = document.getElementById('GioiTinhDropdownBtn');

            if (hiddenInput?.value) dropdownBtn.innerText = hiddenInput.value;

            dropdownItems.forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    const value = this.getAttribute('data-value');
                    hiddenInput.value = value;
                    dropdownBtn.innerText = this.innerText;
                });
            });
        });
    </script>
}