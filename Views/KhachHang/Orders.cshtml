@model IEnumerable<OceanShellCraft.Models.DonHang>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";

    string CapitalizeFirst(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return input;
        input = input.Trim().ToLower();
        return char.ToUpper(input[0]) + input.Substring(1);
    }

    var currentFilter = Context.Request.Query["trangThai"].ToString();
}

<div class="container-fluid py-4 min-vh-100 hide-scrollbar">

    @if (TempData["ThongBao"] != null)
    {
        <div class="glass-card mb-4 p-3 d-flex align-items-center" style="border-left: 4px solid #198754;">
            <i class="bi bi-check-circle-fill me-3 fs-5"></i>
            <span>@CapitalizeFirst(TempData["ThongBao"]?.ToString())</span>
        </div>
    }
    @if (TempData["Loi"] != null)
    {
        <div class="glass-card mb-4 p-3 d-flex align-items-center opacity-75" style="border-left: 4px solid #dc3545;">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-5"></i>
            <span>@CapitalizeFirst(TempData["Loi"]?.ToString())</span>
        </div>
    }

    <div class="mb-4">
        <h4 class="fw-bold m-0 ls-3">ĐƠN HÀNG CỦA TÔI</h4>
    </div>

    <div class="row g-3 mb-5">
        @{
            var filters = new[] {
                new { Name = "Tất cả", Icon = "bi-collection", Value = "" },
                new { Name = "Chờ xử lý", Icon = "bi-hourglass-split", Value = "Chờ xử lý" },
                new { Name = "Đóng gói", Icon = "bi-box-seam", Value = "Đang đóng gói" },
                new { Name = "Đang giao", Icon = "bi-truck", Value = "Đang giao hàng" },
                new { Name = "Hoàn thành", Icon = "bi-check-circle", Value = "Đã hoàn thành" },
                new { Name = "Đã hủy", Icon = "bi-x-octagon", Value = "Đã hủy" }
                };

            foreach (var item in filters)
            {
                bool isActive = (currentFilter == item.Value) || (string.IsNullOrEmpty(currentFilter) && string.IsNullOrEmpty(item.Value));
                string activeClass = isActive ? "opacity-100 border-bottom border-2" : "opacity-50";

                int count = 0;
                if (Model != null)
                {
                    count = string.IsNullOrEmpty(item.Value) ? Model.Count() : Model.Count(x => x.TrangThai == item.Value);
                }

                <div class="col-6 col-md-4 col-lg-2">
                    <a href="@Url.Action("Orders", "KhachHang", new { trangThai = item.Value })"
                       class="glass-card text-center text-decoration-none d-flex flex-column align-items-center justify-content-center h-100 p-3 @activeClass"
                       style="min-height: 110px;">
                        <i class="bi @item.Icon fs-3 mb-2"></i>
                        <span class="small fw-bold">@item.Name</span>

                        @if (count > 0)
                        {
                            <span class="badge bg-white text-dark rounded-pill mt-2">@count</span>
                        }
                    </a>
                </div>
            }
        }
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var donHang in Model)
        {
            var isCancelled = donHang.TrangThai == "Đã hủy";

            <div class="glass-card p-4 mb-4 @(isCancelled ? "opacity-50" : "")">

                <div class="d-flex flex-wrap justify-content-between align-items-center pb-3">
                    <div>
                        <h5 class="fw-bold m-0">#ORD-@donHang.Id.ToString("D4")</h5>
                        <small class="opacity-75"><i class="bi bi-clock me-1"></i>@donHang.NgayDat.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <div class="mt-2 mt-md-0">
                        <span class="glass-effect px-3 py-1 rounded-pill small">
                            @donHang.TrangThai
                        </span>
                    </div>
                </div>

                <hr class="opacity-25 m-0 mb-3" />

                <div class="py-2">
                    @if (donHang.ChiTietDonHangs != null && donHang.ChiTietDonHangs.Any())
                    {
                        var firstItem = donHang.ChiTietDonHangs.First();
                        <div class="d-flex align-items-center">
                            <img src="@(firstItem.SanPham?.HinhAnh ?? "/images/default-product.png")" alt="Product"
                                 class="rounded-3 shadow-sm" style="width: 80px; height: 80px; object-fit: cover; border: 1px solid var(--glass-bg);"
                                 onerror="this.src='/images/default-product.png'" />

                            <div class="ms-3 flex-grow-1">
                                <h6 class="fw-bold m-0">@(firstItem.SanPham?.TenSanPham ?? "Sản phẩm mỹ nghệ")</h6>
                                <small class="opacity-75 d-block mt-1">Số lượng: @firstItem.SoLuong</small>
                            </div>
                            <div class="text-end ps-3">
                                @{
                                    var giaHienTai = firstItem.SanPham?.GiaKhuyenMai ?? firstItem.SanPham?.GiaTien ?? 0;
                                    var tongTienSanPham = giaHienTai * firstItem.SoLuong;
                                }
                                <span class="fw-bold">@tongTienSanPham.ToString("N0") đ</span>
                            </div>
                        </div>

                        if (donHang.ChiTietDonHangs.Count > 1)
                        {
                            <div class="text-center mt-3 pt-2">
                                <small class="opacity-75 fst-italic">...và @(donHang.ChiTietDonHangs.Count - 1) sản phẩm khác</small>
                            </div>
                        }
                    }
                </div>

                <hr class="opacity-25 mt-3 mb-3" />

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <div class="mb-3 mb-md-0">
                        <small class="opacity-75 d-block mb-1">Tổng thanh toán:</small>
                        <h4 class="m-0 fw-bold">@donHang.TongTien.ToString("N0") đ</h4>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a href="/khach-hang/chi-tiet-don-hang/@donHang.Id" class="glass-btn px-4 small">Xem chi tiết</a>

                        @if (donHang.TrangThai == "Đã hoàn thành")
                        {
                            <button class="glass-btn px-4 small"><i class="bi bi-cart-plus me-1"></i> Mua lại</button>
                        }
                        else if (donHang.TrangThai == "Chờ xử lý")
                        {
                            <form asp-action="HuyDonHang" asp-route-id="@donHang.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="glass-btn px-4 small">
                                    Hủy đơn
                                </button>
                            </form>
                        }
                    </div>
                </div>

            </div>
        }
    }
    else
    {
        <div class="glass-card p-5 text-center my-4" style="border: 2px dashed var(--glass-bg) !important;">
            <i class="bi bi-receipt mb-3 d-block opacity-50" style="font-size: 4rem;"></i>
            <h5 class="fw-bold">Chưa có đơn hàng nào</h5>
            <p class="opacity-50 mb-4">Bạn chưa có giao dịch nào cho trạng thái này.</p>
            <a href="/san-pham" class="glass-btn px-5 py-2">Khám phá sản phẩm</a>
        </div>
    }
</div>