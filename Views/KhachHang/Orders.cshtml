@{
    ViewData["Title"] = "Đơn hàng & Vận chuyển";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";
}

<style>
    .tracking-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        z-index: 2;
        position: relative;
    }

    .dot-done {
        background: #198754;
        box-shadow: 0 0 10px #198754;
    }

    .dot-current {
        background: #c5a059;
        box-shadow: 0 0 10px #c5a059;
        border: 3px solid #fff;
    }

    .dot-pending {
        background: rgba(255,255,255,0.2);
        border: 2px solid rgba(255,255,255,0.5);
    }

    .tracking-line {
        height: 4px;
        background: rgba(255,255,255,0.1);
        width: 100%;
        position: absolute;
        top: 8px;
        z-index: 1;
    }

    .tracking-line-fill {
        height: 100%;
        background: #198754;
        width: 50%; /* Chỉnh % tiến độ ở đây */
    }
</style>

<h2 class="fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Đơn hàng của tôi</h2>

<div class="bento-card p-4 mb-4 border border-warning border-opacity-25">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-light border-opacity-25 pb-3">
        <div>
            <h5 class="fw-bold m-0 text-gold">Đơn hàng #ORD-089</h5>
            <small class="text-white-50">Dự kiến giao: 22/03/2026</small>
        </div>
        <button class="btn btn-outline-light btn-sm rounded-pill"><i class="bi bi-headset"></i> Cần hỗ trợ?</button>
    </div>

    <div class="position-relative mb-5 px-3">
        <div class="tracking-line">
            <div class="tracking-line-fill"></div>
        </div>
        <div class="d-flex justify-content-between position-relative">
            <div class="text-center" style="width: 80px; margin-left: -30px;">
                <div class="tracking-dot dot-done mx-auto mb-2"></div>
                <small class="fw-bold d-block text-success">Đã duyệt</small>
                <small class="text-white-50" style="font-size: 0.7rem;">15/03</small>
            </div>
            <div class="text-center" style="width: 80px;">
                <div class="tracking-dot dot-done mx-auto mb-2"></div>
                <small class="fw-bold d-block text-success">Đóng gói</small>
                <small class="text-white-50" style="font-size: 0.7rem;">16/03</small>
            </div>
            <div class="text-center" style="width: 80px;">
                <div class="tracking-dot dot-current mx-auto mb-2"></div>
                <small class="fw-bold d-block text-gold">Đang giao</small>
                <small class="text-white-50" style="font-size: 0.7rem;">Hôm nay</small>
            </div>
            <div class="text-center" style="width: 80px; margin-right: -30px;">
                <div class="tracking-dot dot-pending mx-auto mb-2"></div>
                <small class="fw-bold d-block text-white-50">Thành công</small>
            </div>
        </div>
    </div>

    <div class="bg-black bg-opacity-25 rounded-3 p-3">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="bg-white rounded d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;">
                <i class="bi bi-gem text-dark fs-4"></i>
            </div>
            <div class="flex-grow-1">
                <h6 class="m-0 fw-bold">Vỏ ốc Ngọc Trai điêu khắc</h6>
                <small class="text-white-50">Phân loại: Lớn | SL: 1</small>
            </div>
            <h6 class="m-0 fw-bold text-gold">1,250,000 VNĐ</h6>
        </div>
    </div>
</div>