@model OceanShellCraft.Models.NguoiDung

@{
    ViewData["Title"] = "Tổng quan hồ sơ";
    Layout = "~/Views/Shared/_KhachHangLayout.cshtml";

    // 1. Kiểm tra an toàn: Nếu Model null thì gán ảnh mặc định, ngược lại kiểm tra AnhDaiDien
    var avatarUrl = (Model == null || string.IsNullOrEmpty(Model.AnhDaiDien))
        ? "/img/meo.jpg"
        : Model.AnhDaiDien;

    // 2. Các giá trị khác cũng cần bảo vệ tương tự nếu Model null
    var hoTen = Model?.HoTen ?? "Khách hàng";
    var email = Model?.Email ?? "Chưa cập nhật email";
}
<div class="container-fluid py-4 min-vh-100 hide-scrollbar">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-white m-0" style="font-family: 'Playfair Display', serif;">
            <i class="bi bi-list-nested me-2"></i>Tổng quan hồ sơ
        </h3>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-xl-3 col-lg-4">
            <div class="bento-card p-4 d-flex flex-column align-items-center text-center h-100 shadow-sm">
                <div class="position-relative mb-3">
                    <img id="avatarPreview" src="@avatarUrl"
                         class="rounded-circle object-fit-cover border border-light border-opacity-50 shadow"
                         width="130" height="130" style="padding: 4px;">
                </div>
                <h5 class="fw-bold text-white mb-1 tracking-wider">@Model.HoTen</h5>
                <p class="text-white opacity-50 small mb-4">@Model.Email</p>

                <div class="w-100 mt-auto">
                    <label for="AvatarUpload" class="btn btn-white-outline w-100 py-2 m-0 shadow-sm" style="cursor: pointer;">
                        <i class="bi bi-camera me-2"></i> Đổi ảnh
                    </label>
                    <input type="file" id="AvatarUpload" class="d-none" accept="image/*" onchange="autoUploadAvatar(event)">
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-8">
            <form asp-action="CapNhatHoSo" asp-controller="KhachHang" method="post" class="bento-card p-4 h-100 d-flex flex-column shadow-sm">
                <input type="hidden" asp-for="Id" id="UserId" />

                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light border-opacity-25">
                    <h5 class="fw-bold text-white mb-0"><i class="bi bi-person-lines-fill me-2"></i>Thông tin cá nhân</h5>
                    <button type="submit" class="btn btn-white-outline btn-sm px-4 rounded-pill">
                        <i class="bi bi-pencil-square me-1"></i> Lưu
                    </button>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-white opacity-50 small mb-1">Họ và tên</label>
                        <input asp-for="HoTen" class="form-control rounded-3 p-2 text-white border-light border-opacity-25" style="background: transparent;">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white opacity-50 small mb-1">Số điện thoại</label>
                        <input asp-for="SoDienThoai" class="form-control rounded-3 p-2 text-white border-light border-opacity-25" style="background: transparent;">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white opacity-50 small mb-1">Ngày sinh</label>
                        <input asp-for="NgaySinh" type="date" class="form-control rounded-3 p-2 text-white border-light border-opacity-25" style="background: transparent; color-scheme: dark;">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white opacity-50 small mb-1">Giới tính</label>
                        <input type="hidden" asp-for="GioiTinh" id="GioiTinhHidden" />
                        <div class="dropdown w-100">
                            <button class="form-select text-white border-light border-opacity-25 rounded-3 p-2 shadow-none text-start d-flex justify-content-between align-items-center w-100"
                                    style="background: transparent;" type="button" data-bs-toggle="dropdown" id="GioiTinhDropdownBtn">
                                -- Chọn --
                            </button>
                            <ul class="dropdown-menu glass-effect border-light border-opacity-25 p-2 mt-1 w-100 shadow">
                                <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Nam">Nam</a></li>
                                <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Nữ">Nữ</a></li>
                                <li><a class="dropdown-item rounded-2 mb-1" href="#" data-value="Khác">Khác</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-xl-3 col-lg-12">
            <div class="bento-card p-4 h-100 d-flex flex-column justify-content-center shadow-sm">
                <h5 class="fw-bold text-white mb-4 pb-2 border-bottom border-light border-opacity-25">
                    <i class="bi bi-bar-chart me-2"></i>Tổng quát
                </h5>

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="border border-light border-opacity-50 p-2 rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-box2-heart fs-5"></i>
                        </div>
                        <span class="text-white opacity-75">Đơn đã mua</span>
                    </div>
                    <h5 class="mb-0 fw-bold text-white">12</h5>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="border border-light border-opacity-50 p-2 rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-truck fs-5"></i>
                        </div>
                        <span class="text-white opacity-75">Đang giao</span>
                    </div>
                    <h5 class="mb-0 fw-bold text-white">2</h5>
                </div>

                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="border border-light border-opacity-50 p-2 rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                            <i class="bi bi-coin fs-5"></i>
                        </div>
                        <span class="text-white opacity-75">Tích lũy</span>
                    </div>
                    <h5 class="mb-0 fw-bold text-white">1,250</h5>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-xl-8">
            <div class="bento-card p-4 h-100 shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light border-opacity-25">
                    <h5 class="fw-bold text-white m-0"><i class="bi bi-clock-history me-2"></i>Đơn hàng gần đây</h5>
                    <a href="/Customer/Orders" class="btn btn-white-outline btn-sm px-4 rounded-pill">Xem tất cả</a>
                </div>

                <div class="d-flex align-items-center justify-content-between py-3 px-3 mb-2 border border-light border-opacity-25 rounded-3 transition-row">
                    <div class="d-flex align-items-center gap-3" style="width: 30%;">
                        <div class="border border-light border-opacity-50 p-2 rounded text-white">
                            <i class="bi bi-bag-check fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold text-white">#ORD-089</h6>
                            <small class="text-white opacity-50">15/03/2026</small>
                        </div>
                    </div>
                    <div class="text-center" style="width: 40%;">
                        <span class="border border-light px-3 py-1 rounded-pill small text-white">Đang giao hàng</span>
                    </div>
                    <div class="text-end" style="width: 30%;">
                        <small class="text-white opacity-50 d-block mb-1">Tổng tiền</small>
                        <h6 class="m-0 fw-bold text-white">1,250,000đ</h6>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between py-3 px-3 border border-light border-opacity-25 rounded-3 transition-row opacity-75">
                    <div class="d-flex align-items-center gap-3" style="width: 30%;">
                        <div class="border border-light border-opacity-50 p-2 rounded text-white">
                            <i class="bi bi-check2-all fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold text-white">#ORD-042</h6>
                            <small class="text-white opacity-50">01/02/2026</small>
                        </div>
                    </div>
                    <div class="text-center" style="width: 40%;">
                        <span class="border border-light border-opacity-25 px-3 py-1 rounded-pill small text-white">Đã hoàn thành</span>
                    </div>
                    <div class="text-end" style="width: 30%;">
                        <small class="text-white opacity-50 d-block mb-1">Tổng tiền</small>
                        <h6 class="m-0 fw-bold text-white">850,000đ</h6>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="bento-card p-4 h-100 shadow-sm">
                <h5 class="fw-bold text-white mb-4 pb-2 border-bottom border-light border-opacity-25">
                    <i class="bi bi-ticket-perforated me-2"></i>Voucher của bạn
                </h5>

                <div class="border border-light border-opacity-25 p-3 rounded-3 mb-3 transition-row">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="text-white fw-bold m-0">Giảm 10% đơn tiếp theo</h6>
                        <i class="bi bi-download text-white opacity-50 cursor-pointer hover-white"></i>
                    </div>
                    <small class="text-white opacity-50 d-block mb-3">Hết hạn: 30/03/2026</small>
                    <div class="d-flex justify-content-between align-items-center border border-light border-opacity-25 px-3 py-2 rounded">
                        <span class="fw-mono tracking-widest text-white">OCEAN10</span>
                        <i class="bi bi-clipboard text-white opacity-50 cursor-pointer hover-white" title="Copy"></i>
                    </div>
                </div>

                <div class="border border-light border-opacity-25 p-3 rounded-3 transition-row opacity-75">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="text-white fw-bold m-0">Freeship đơn từ 500k</h6>
                        <i class="bi bi-download text-white opacity-50 cursor-pointer hover-white"></i>
                    </div>
                    <small class="text-white opacity-50 d-block mb-3">Hết hạn: 15/04/2026</small>
                    <div class="d-flex justify-content-between align-items-center border border-light border-opacity-25 px-3 py-2 rounded">
                        <span class="fw-mono tracking-widest text-white">FREESHIP50</span>
                        <i class="bi bi-clipboard text-white opacity-50 cursor-pointer hover-white" title="Copy"></i>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Xử lý upload ảnh
        async function autoUploadAvatar(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
            reader.readAsDataURL(file);

            const formData = new FormData();
            formData.append('AvatarFile', file);
            formData.append('UserId', document.getElementById('UserId').value);

            try {
                const response = await fetch('/TaiKhoan/UploadAvatarAjax', { method: 'POST', body: formData });
                const result = await response.json();
                if(!result.success) alert("Lỗi: " + result.message);
            } catch (error) { alert('Lỗi kết nối server.'); }
        }

        // Xử lý Dropdown Giới tính
        document.addEventListener("DOMContentLoaded", function () {
            const dropdownItems = document.querySelectorAll('.dropdown-menu .dropdown-item');
            const hiddenInput = document.getElementById('GioiTinhHidden');
            const dropdownBtn = document.getElementById('GioiTinhDropdownBtn');

            if (hiddenInput?.value) dropdownBtn.innerText = hiddenInput.value;

            dropdownItems.forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    const value = this.getAttribute('data-value');
                    hiddenInput.value = value;
                    dropdownBtn.innerText = this.innerText;
                });
            });
        });
    </script>
}