@model IEnumerable<OceanShellCraft.Models.SanPham>
@{
    ViewData["Title"] = "Trang chủ - OceanShellCraft";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var allProducts = Model?.OrderByDescending(x => x.Id).ToList() ?? new List<OceanShellCraft.Models.SanPham>();

    var hotProducts = allProducts.Where(x => x.IsFavorite || x.IsFeatured).Take(3).ToList();
    if (hotProducts.Count < 3)
    {
        var needed = 3 - hotProducts.Count;
        var fallbackHot = allProducts.Where(x => !hotProducts.Contains(x)).Take(needed).ToList();
        hotProducts.AddRange(fallbackHot);
    }

    var featuredProducts = allProducts.Where(x => x.IsFeatured).Take(8).ToList();
    if (featuredProducts.Count < 8)
    {
        var needed = 8 - featuredProducts.Count;
        var fallbackProducts = allProducts.Where(x => !x.IsFeatured).Take(needed).ToList();
        featuredProducts.AddRange(fallbackProducts);
    }

    var bestSellingProducts = allProducts.Skip(11).Take(8).ToList();

    var flashSaleProducts = allProducts
        .Where(x => x.GiaKhuyenMai.HasValue && x.GiaKhuyenMai.Value > 0 && x.GiaKhuyenMai.Value < x.GiaTien)
        .OrderByDescending(x => (1 - ((double)x.GiaKhuyenMai.Value / (double)x.GiaTien)) * 100)
        .Take(4).ToList();

    if (flashSaleProducts.Count == 0)
    {
        flashSaleProducts = allProducts.Skip(19).Take(4).ToList();
    }

    var lastChanceProducts = allProducts
        .Where(x => x.SoLuong > 0 && x.SoLuong < 10)
        .OrderBy(x => x.SoLuong)
        .Take(4).ToList();

    var newArrivals = allProducts.Take(4).ToList();
    var bottomListProducts = allProducts.OrderBy(x => Guid.NewGuid()).Take(4).ToList();
}

<div class="container-fluid py-4 px-lg-5">
    <div class="row g-4">
        @* CỘT TRÁI: DANH MỤC & HOT *@
        <div class="col-lg-2 d-none d-lg-block">
            <div class="glass-card p-4 mb-4">
                <h6 class="mb-3 pb-2" style="border-bottom: 1px solid var(--border-light);">
                    <i class="bi bi-list me-1"></i> Danh mục
                </h6>
                <ul class="list-unstyled mb-0 small lh-lg">
                    <li>
                        <a href="@Url.Action("DanhSach", "SanPham", new { maDanhMuc = (int?)null })"
                           class="opacity-75 text-decoration-none d-block py-1">
                            Tất cả sản phẩm
                        </a>
                    </li>
                    @if (ViewBag.DanhMucs != null)
                    {
                        foreach (var dm in ViewBag.DanhMucs)
                        {
                            <li>
                                <a href="@Url.Action("DanhSach", "SanPham", new { maDanhMuc = dm.Id })"
                                   class="opacity-75 text-decoration-none d-block py-1">
                                    @dm.TenDanhMuc
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>

            <div class="glass-card p-4 mb-4">
                <h6 class="mb-4">Sản phẩm Hot</h6>
                @foreach (var item in hotProducts)
                {
                    bool hasDiscount = item.GiaKhuyenMai.HasValue && item.GiaKhuyenMai.Value > 0 && item.GiaKhuyenMai.Value < item.GiaTien;
                    <div class="d-flex align-items-center mb-3">
                        <img src="@(item?.HinhAnh ?? "/images/default-shell.png")" class="rounded-4 me-3 object-fit-cover" width="55" height="55" alt="Hot" style="border: 1px solid var(--border-light);">
                        <div class="overflow-hidden flex-grow-1">
                            <p class="opacity-85 text-truncate mb-1" style="font-size: 0.8rem;" title="@item?.TenSanPham">@(item?.TenSanPham ?? "Sản phẩm")</p>
                            <span style="font-size: 0.8rem;">@(hasDiscount? item.GiaKhuyenMai.Value.ToString("N0") : item.GiaTien.ToString("N0")) đ</span>
                        </div>
                    </div>
                }
            </div>

            <div class="glass-card overflow-hidden position-relative p-0" style="height: 320px;">
                <div class="position-absolute w-100 h-100 z-1 p-3 d-flex flex-column justify-content-center align-items-center text-center">
                    <h4 class="opacity-75 fst-italic">Giá giảm sâu</h4>
                    <h1 class="display-4 mb-0">20<span class="fs-4">%</span></h1>
                    <p class="opacity-50 small">Cho tất cả từ 25/4</p>
                </div>
                <img src="/img/bien.jpg" class="w-100 h-100 object-fit-cover opacity-50 position-absolute top-0 start-0">
            </div>
        </div>

        @* CỘT GIỮA: NỘI DUNG CHÍNH *@
        <div class="col-lg-8">
            <div class="glass-card p-0 mb-4 position-relative overflow-hidden" style="min-height: 280px;">
                <div class="row g-0 h-100">
                    <div class="col-md-6 p-5 d-flex flex-column justify-content-center position-relative z-1">
                        <h1 class="display-5 mb-3 lh-sm">Sản phẩm từ biển</h1>
                        <p class="opacity-75 fs-6 mb-0 fst-italic">Hãy đến với chúng tôi.</p>
                    </div>
                </div>
            </div>

            <div class="glass-card d-flex justify-content-between align-items-center px-4 py-3 mb-5">
                <span class="small opacity-85"><i class="bi bi-shield-check me-2 fs-5"></i> Đóng gói an toàn & bảo hành nguyên bản</span>
                <a href="/SanPham/DanhSach" class="text-decoration-none small" style="border-bottom: 1px solid var(--text-main); padding-bottom: 2px;">Xem ưu đãi</a>
            </div>

            @* Sản phẩm nổi bật *@
            <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                <h4 class="mb-0">Sản phẩm nổi bật</h4>
                <div class="d-flex gap-4 opacity-75 small">
                    <span style="border-bottom: 1px solid var(--text-main); padding-bottom: 2px;">Tất cả</span>
                </div>
            </div>

            <div class="row g-4 mb-5">
                @foreach (var item in featuredProducts)
                {
                    <div class="col-6 col-md-3">
                        @{
                            ViewData["HienBadgeGiamGia"] = true;
                            ViewData["HienBadgeSoLuong"] = false;
                            ViewData["HienThanhTienDo"] = false;
                            ViewData["LaSanPhamMoi"] = false;
                            ViewData["AnhRoundedCircle"] = true;
                            ViewData["AnhWidth"] = "120px";
                            ViewData["AnhHeight"] = "120px";
                        }
                        @await Html.PartialAsync("_TheSanPham", item)
                    </div>
                }
            </div>

            @* Danh mục nghệ thuật *@
            <h4 class="mb-4 px-2 mt-5">Danh mục nghệ thuật</h4>
            <div class="d-flex justify-content-between text-center overflow-auto hide-scrollbar pb-3 mb-5 gap-3">
                @if (ViewBag.DanhMucs != null)
                {
                    foreach (var dm in ViewBag.DanhMucs)
                    {
                        string iconClass = "bi-stars";
                        string tenDM = dm.TenDanhMuc;
                        string tenDMLower = tenDM.ToLower();

                        if (tenDMLower.Contains("vỏ ốc")) iconClass = "bi-life-preserver";
                        else if (tenDMLower.Contains("chậu cây")) iconClass = "bi-flower1";
                        else if (tenDMLower.Contains("chuông gió")) iconClass = "bi-bell";
                        else if (tenDMLower.Contains("đèn")) iconClass = "bi-lightbulb";
                        else if (tenDMLower.Contains("nội thất")) iconClass = "bi-house-heart";

                        <div style="min-width: 120px;">
                            <a href="@Url.Action("DanhSach", "SanPham", new { maDanhMuc = dm.Id })" class="text-decoration-none">
                                <div class="glass-circle mx-auto mb-3" style="width: 80px; height: 80px;">
                                    <i class="bi @iconClass fs-2 opacity-85"></i>
                                </div>
                                <small class="opacity-75 d-block" style="line-height: 1.2;">@tenDM</small>
                            </a>
                        </div>
                    }
                }
            </div>

            @* Sản phẩm bán chạy *@
            <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                <h4 class="mb-0">Sản phẩm bán chạy</h4>
                <div class="d-flex gap-2">
                    <button class="glass-btn p-1" style="width: 30px; height: 30px; border-radius: 50%;"><i class="bi bi-arrow-left"></i></button>
                    <button class="glass-btn p-1" style="width: 30px; height: 30px; border-radius: 50%;"><i class="bi bi-arrow-right"></i></button>
                </div>
            </div>

            <div class="row g-4 mb-5">
                @foreach (var item in bestSellingProducts)
                {
                    <div class="col-6 col-md-3">
                        @{
                            ViewData["HienBadgeGiamGia"] = true;
                            ViewData["HienBadgeSoLuong"] = false;
                            ViewData["HienThanhTienDo"] = false;
                            ViewData["AnhRoundedCircle"] = false;
                            ViewData["AnhWidth"] = "120px";
                            ViewData["AnhHeight"] = "120px";
                        }
                        @await Html.PartialAsync("_TheSanPham", item)
                    </div>
                }
            </div>

            @* Flash Sale *@
            <div class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                    <h4 class="mb-0 d-flex align-items-center">
                        <i class="bi bi-lightning-charge-fill opacity-85 me-2"></i> Flash Sale
                    </h4>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="opacity-75 small d-none d-md-block me-2">Kết thúc trong:</span>
                        <span class="glass-card px-3 py-2" style="border-radius: 12px; padding: 5px 10px !important;" id="flash-hours">02</span>
                        <span class="opacity-75">:</span>
                        <span class="glass-card px-3 py-2" style="border-radius: 12px; padding: 5px 10px !important;" id="flash-minutes">45</span>
                        <span class="opacity-75">:</span>
                        <span class="glass-card px-3 py-2" style="border-radius: 12px; padding: 5px 10px !important;" id="flash-seconds">10</span>
                    </div>
                </div>
                <div class="row g-4 mb-5">
                    @foreach (var item in flashSaleProducts)
                    {
                        <div class="col-6 col-md-3">
                            @{
                                ViewData["HienBadgeGiamGia"] = true;
                                ViewData["HienBadgeSoLuong"] = false;
                                ViewData["HienThanhTienDo"] = false;
                                ViewData["AnhRoundedCircle"] = false;
                                ViewData["AnhWidth"] = "110px";
                                ViewData["AnhHeight"] = "110px";
                            }
                            @await Html.PartialAsync("_TheSanPham", item)
                        </div>
                    }
                </div>
            </div>

            @* Banner phụ *@
            <div class="row g-4 mb-5 mt-5">
                <div class="col-md-6">
                    <div class="glass-card p-0 overflow-hidden position-relative d-flex align-items-center" style="height: 180px;">
                        <div class="p-4 w-50 z-2">
                            <p class="opacity-75 small mb-1" style="letter-spacing: 2px;">Free Ship</p>
                            <h2 class="mb-3">20%</h2>
                            <a href="#" class="glass-btn px-4 py-2">Xem ngay</a>
                        </div>
                        <img src="/img/bien.jpg" class="position-absolute end-0 top-0 h-100 w-50 object-fit-cover opacity-75" style="-webkit-mask-image: linear-gradient(to right, transparent, black 40%);">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="glass-card p-0 overflow-hidden position-relative d-flex align-items-center" style="height: 180px;">
                        <div class="p-4 w-50 z-2">
                            <p class="opacity-75 small mb-1" style="letter-spacing: 2px;">Sản phẩm</p>
                            <h2 class="mb-3">Mới</h2>
                            <a href="#" class="glass-btn px-4 py-2">Khám phá</a>
                        </div>
                        <img src="/img/bien.jpg" class="position-absolute end-0 top-0 h-100 w-50 object-fit-cover opacity-75" style="-webkit-mask-image: linear-gradient(to right, transparent, black 40%);">
                    </div>
                </div>
            </div>

            @* Hàng mới lên kệ *@
            <div class="mb-5 mt-5">
                <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                    <h4 class="mb-0 d-flex align-items-center">
                        <i class="bi bi-stars opacity-85 me-2"></i> Hàng mới lên kệ
                    </h4>
                    <a href="#" class="text-decoration-none small" style="border-bottom: 1px solid var(--text-main); padding-bottom: 2px;">Xem tất cả</a>
                </div>
                <div class="row g-4">
                    @foreach (var item in newArrivals)
                    {
                        <div class="col-6 col-md-3">
                            @{
                                ViewData["HienBadgeGiamGia"] = true;
                                ViewData["LaSanPhamMoi"] = true;
                                ViewData["HienBadgeSoLuong"] = false;
                                ViewData["HienThanhTienDo"] = false;
                                ViewData["AnhRoundedCircle"] = true;
                                ViewData["AnhWidth"] = "120px";
                                ViewData["AnhHeight"] = "120px";
                            }
                            @await Html.PartialAsync("_TheSanPham", item)
                        </div>
                    }
                </div>
            </div>

            @* Gợi ý cho bạn (ĐÃ DỜI XUỐNG ĐÂY) *@
            <div class="mb-5 mt-5">
                <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                    <h4 class="mb-0 d-flex align-items-center">
                        <i class="bi bi-heart-fill text-danger opacity-85 me-2" style="font-size: 1.1rem;"></i> Gợi ý cho bạn
                    </h4>
                    <a href="@Url.Action("DanhSach", "SanPham")" class="text-decoration-none small" style="border-bottom: 1px solid var(--text-main); padding-bottom: 2px;">Xem thêm</a>
                </div>
                <div class="row g-4">
                    @if (bottomListProducts != null && bottomListProducts.Any())
                    {
                        foreach (var item in bottomListProducts)
                        {
                            <div class="col-6 col-md-3">
                                @{
                                    ViewData["HienBadgeGiamGia"] = true;
                                    ViewData["LaSanPhamMoi"] = false;
                                    ViewData["HienBadgeSoLuong"] = false;
                                    ViewData["HienThanhTienDo"] = false;
                                    ViewData["AnhRoundedCircle"] = true;
                                    ViewData["AnhWidth"] = "120px";
                                    ViewData["AnhHeight"] = "120px";
                                }
                                @await Html.PartialAsync("_TheSanPham", item)
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @* CỘT PHẢI: CHÍNH SÁCH & REVIEW *@
        <div class="col-lg-2 d-none d-lg-block">
            <div class="glass-card p-4 mb-4">
                <div class="d-flex flex-column align-items-center text-center mb-4">
                    <i class="bi bi-shield-check opacity-85 fs-2 mb-2"></i>
                    <h6 class="small mb-1">100% Nguyên bản</h6>
                    <small class="opacity-50" style="font-size: 0.75rem;">Không pha tạp chất</small>
                </div>
                <div class="d-flex flex-column align-items-center text-center mb-4">
                    <i class="bi bi-box-seam opacity-85 fs-2 mb-2"></i>
                    <h6 class="small mb-1">Giao hàng an toàn</h6>
                    <small class="opacity-50" style="font-size: 0.75rem;">Đóng gói tiêu chuẩn</small>
                </div>
                <div class="d-flex flex-column align-items-center text-center">
                    <i class="bi bi-arrow-repeat opacity-85 fs-2 mb-2"></i>
                    <h6 class="small mb-1">Đổi trả 7 ngày</h6>
                    <small class="opacity-50" style="font-size: 0.75rem;">Hỗ trợ tận tâm</small>
                </div>
            </div>

            <div class="glass-card p-4 mb-4 text-center">
                <span class="opacity-75 small mb-3 d-block" style="letter-spacing: 2px;">Đánh giá</span>
                @if (ViewBag.TopReview != null)
                {
                    <div class="position-relative d-inline-block mb-2">
                        <img src="/images/avatar-default.png" class="rounded-circle" style="border: 1px solid var(--border-light);" width="70" height="70">
                    </div>
                    <h6 class="mt-3 mb-1">@ViewBag.TopReview.TenKhachHang</h6>
                    <div class="opacity-85 mt-1 mb-2 small">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                    <p class="opacity-75 fst-italic mb-0 lh-base" style="font-size: 0.8rem;">"@ViewBag.TopReview.NoiDung"</p>
                    <a href="/SanPham/ChiTiet/@ViewBag.TopReview.SanPhamId?topReviewId=@ViewBag.TopReview.Id#review-section" class="small text-decoration-underline mt-3 d-block">Xem sản phẩm</a>
                }
                else
                {
                    <div class="position-relative d-inline-block mb-2">
                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100" class="rounded-circle" style="border: 1px solid var(--border-light);" width="70" height="70">
                        <span class="position-absolute bottom-0 start-50 translate-middle-x badge rounded-pill glass-effect" style="font-size: 0.6rem; white-space: nowrap; transform: translateY(30%) !important;">
                            <i class="bi bi-bag-check-fill me-1"></i>Mua thường xuyên
                        </span>
                    </div>
                    <h6 class="mt-3 mb-1">Chị Lan Hương</h6>
                    <div class="opacity-85 mt-1 mb-2 small">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                    <p class="opacity-75 fst-italic mb-0 lh-base" style="font-size: 0.8rem;">"Tuyệt tác khảm trai tỉ mỉ đến từng chi tiết nhỏ nhất."</p>
                    <a href="/SanPham/ChiTiet/1?topReviewId=1#review-section" class="small opacity-75 mt-3 d-block"><i class="bi bi-link-45deg"></i> Xem tuyệt tác</a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            let totalSeconds = (2 * 3600) + (45 * 60) + 10;
            const hoursSpan = document.getElementById("flash-hours");
            const minsSpan = document.getElementById("flash-minutes");
            const secsSpan = document.getElementById("flash-seconds");
            const timer = setInterval(function() {
                if (totalSeconds <= 0) {
                    clearInterval(timer);
                    return;
                }
                totalSeconds--;
                let h = Math.floor(totalSeconds / 3600);
                let m = Math.floor((totalSeconds % 3600) / 60);
                let s = totalSeconds % 60;
                hoursSpan.textContent = h < 10 ? "0" + h : h;
                minsSpan.textContent = m < 10 ? "0" + m : m;
                secsSpan.textContent = s < 10 ? "0" + s : s;
            }, 1000);
        });
    </script>
}