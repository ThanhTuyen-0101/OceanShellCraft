@{
    ViewData["Title"] = "Liên Hệ - OceanShellCraft";
}

<style>
    /* 1. Nền đại dương 3D toàn trang */
    .contact-wrapper {
        position: relative;
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        background: linear-gradient(to bottom, #002b4d 0%, #001220 100%);
    }

    #ocean-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    /* 2. Lớp phủ nội dung */
    .contact-content {
        position: relative;
        z-index: 2;
        padding: 60px 0;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        color: white;
    }

    /* 3. Tinh chỉnh Input cho đẹp trên nền tối */
    .form-control-custom {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        border-radius: 10px;
    }

        .form-control-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #8ce5ff;
            color: white;
            box-shadow: 0 0 10px rgba(140, 229, 255, 0.3);
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

    .contact-icon {
        width: 45px;
        height: 45px;
        background: #8ce5ff;
        color: #002b4d;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 20px;
        margin-right: 15px;
    }
</style>

<div class="contact-wrapper">
    <div id="ocean-canvas"></div>

    <div class="container contact-content">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-info">Kết Nối Với Chúng Tôi</h1>
            <p class="text-light opacity-75">OceanShellCraft luôn sẵn lòng lắng nghe ý kiến và câu hỏi từ bạn</p>
        </div>

        <div class="row g-5">
            <div class="col-lg-5">
                <div class="glass-card p-4 h-100 shadow-lg">
                    <h3 class="mb-4">Thông Tin Liên Lạc</h3>

                    <div class="d-flex align-items-center mb-4">
                        <div class="contact-icon"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h6 class="mb-0 fw-bold">Địa chỉ:</h6>
                            <p class="mb-0 opacity-75">Phường 11, TP. Vũng Tàu, Bà Rịa - Vũng Tàu</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="contact-icon"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h6 class="mb-0 fw-bold">Điện thoại:</h6>
                            <p class="mb-0 opacity-75">0123 456 789</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="contact-icon"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h6 class="mb-0 fw-bold">Email:</h6>
                            <p class="mb-0 opacity-75">support@oceanshellcraft.com</p>
                        </div>
                    </div>

                    <hr class="border-light opacity-25">

                    <h5 class="mt-4 mb-3">Theo dõi OceanShellCraft</h5>
                    <div class="d-flex gap-3">
                        <a href="#" class="btn btn-outline-info rounded-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-info rounded-circle"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-outline-info rounded-circle"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="glass-card p-4 shadow-lg">
                    <h3 class="mb-4">Gửi Lời Nhắn</h3>
                    <form action="@Url.Action("LienHe", "Home")" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ tên của bạn</label>
                                <input type="text" class="form-control form-control-custom" placeholder="Nguyễn Văn A" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email liên hệ</label>
                                <input type="email" class="form-control form-control-custom" placeholder="name@example.com" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Chủ đề</label>
                                <input type="text" class="form-control form-control-custom" placeholder="Tôi cần tư vấn về sản phẩm...">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Nội dung tin nhắn</label>
                                <textarea class="form-control form-control-custom" rows="5" placeholder="Nhập lời nhắn của bạn tại đây..."></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-info btn-lg w-100 fw-bold text-dark rounded-pill">
                                    Gửi Tin Nhắn <i class="bi bi-send-fill ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="importmap">
    {
      "imports": {
        "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
      }
    }
</script>

<script type="module">
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const container = document.getElementById('ocean-canvas');
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    container.appendChild(renderer.domElement);

    // Ánh sáng đại dương
    scene.add(new THREE.AmbientLight(0x404040, 3));
    const pointLight = new THREE.PointLight(0x0088ff, 5);
    pointLight.position.set(5, 5, 5);
    scene.add(pointLight);

    // Tạo bọt biển lấp lánh (Particles)
    const geometry = new THREE.BufferGeometry();
    const count = 800;
    const positions = new Float32Array(count * 3);
    for(let i = 0; i < count * 3; i++) {
        positions[i] = (Math.random() - 0.5) * 15;
    }
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const material = new THREE.PointsMaterial({ size: 0.03, color: 0x8ce5ff, transparent: true, opacity: 0.8 });
    const points = new THREE.Points(geometry, material);
    scene.add(points);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableZoom = false;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.3;

    function animate() {
        requestAnimationFrame(animate);
        // Hạt bọt biển chuyển động nhẹ lên trên
        const positions = points.geometry.attributes.position.array;
        for (let i = 1; i < positions.length; i += 3) {
            positions[i] += 0.005;
            if (positions[i] > 7) positions[i] = -7;
        }
        points.geometry.attributes.position.needsUpdate = true;
        controls.update();
        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
</script>