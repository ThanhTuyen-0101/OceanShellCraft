@model dynamic
@{
    ViewData["Title"] = "Artisanal heritage - OceanShellCraft";
}

<div class="gt-page-wrapper artisanal-scope py-5 px-3">
    <div class="container g-0">

        <div class="text-center mb-5 pb-3">
            <p class="small opacity-50 mb-2" style="letter-spacing: 5px;">DI SẢN VÀ NGHỆ THUẬT</p>
            <h1 class="display-4" style="letter-spacing: 2px;">Câu chuyện thương hiệu</h1>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8 d-flex flex-column gap-4">
                <div class="glass-card overflow-hidden position-relative d-flex align-items-end p-5" style="min-height: 380px;">
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: url('/img/bien.jpg') center/cover; opacity: 0.4; mix-blend-mode: overlay;"></div>
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);"></div>

                    <div class="position-relative z-1 w-100">
                        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                            <div>
                                <span class="glass-effect px-3 py-1 rounded-pill small mb-3 d-inline-block" style="letter-spacing: 3px; font-size: 0.75rem;">SINCE 2026</span>
                                <h2 class="display-3 mb-0 lh-1">Ocean Shell Craft</h2>
                            </div>
                            <p class="opacity-75 mb-1 fst-italic" style="max-width: 300px;">Nơi những vỏ ốc vô tri được thổi hồn thành kiệt tác trường tồn cùng thời gian.</p>
                        </div>
                    </div>
                </div>

                <div class="row g-4 flex-grow-1">
                    <div class="col-md-6">
                        <div class="glass-card p-4 p-xl-5 h-100 d-flex flex-column justify-content-center">
                            <div class="mb-4 pb-4" style="border-bottom: 1px dashed rgba(255,255,255,0.2);">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="glass-circle me-3" style="width: 40px; height: 40px;"><i class="bi bi-compass"></i></div>
                                    <h5 class="mb-0">Sứ mệnh</h5>
                                </div>
                                <p class="small opacity-75 lh-lg mb-0 ps-2">Kết nối vẻ đẹp nguyên sơ của đại dương với phong cách sống tinh tế và hiện đại.</p>
                            </div>
                            <div>
                                <div class="d-flex align-items-center mb-3">
                                    <div class="glass-circle me-3" style="width: 40px; height: 40px;"><i class="bi bi-eye"></i></div>
                                    <h5 class="mb-0">Tầm nhìn</h5>
                                </div>
                                <p class="small opacity-75 lh-lg mb-0 ps-2">Trở thành biểu tượng toàn cầu của ngành thủ công mỹ nghệ xà cừ bền vững.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="glass-card p-4 p-xl-5 h-100 d-flex flex-column justify-content-center">
                            <h5 class="mb-4 text-center opacity-75">Giá trị cốt lõi</h5>
                            <div class="row g-4 text-center">
                                <div class="col-6">
                                    <div class="glass-circle mx-auto mb-2"><i class="bi bi-water fs-4"></i></div>
                                    <p class="small opacity-75 mb-0" style="letter-spacing: 1px;">Tự nhiên</p>
                                </div>
                                <div class="col-6">
                                    <div class="glass-circle mx-auto mb-2"><i class="bi bi-lightbulb fs-4"></i></div>
                                    <p class="small opacity-75 mb-0" style="letter-spacing: 1px;">Sáng tạo</p>
                                </div>
                                <div class="col-6">
                                    <div class="glass-circle mx-auto mb-2"><i class="bi bi-recycle fs-4"></i></div>
                                    <p class="small opacity-75 mb-0" style="letter-spacing: 1px;">Bền vững</p>
                                </div>
                                <div class="col-6">
                                    <div class="glass-circle mx-auto mb-2"><i class="bi bi-heart fs-4"></i></div>
                                    <p class="small opacity-75 mb-0" style="letter-spacing: 1px;">Tâm huyết</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="glass-card p-5 h-100 d-flex flex-column">
                    <h3 class="display-6 mb-4 pb-3" style="border-bottom: 1px solid var(--border-light);">Hành trình<br>báu vật</h3>
                    <p class="opacity-75 lh-lg mb-4" style="font-size: 1.05rem;">OceanShellCraft ra đời từ niềm đam mê đánh thức vẻ đẹp của những "báu vật" thầm lặng. Chúng tôi bảo tồn linh hồn của biển cả qua từng lớp xà cừ tuyển chọn khắt khe nhất.</p>

                    <div class="mt-auto text-center">
                        <img src="/img/sobien.png" class="img-fluid mb-4" style="max-height: 250px; object-fit: contain; filter: drop-shadow(0 15px 25px rgba(0,0,0,0.3)); transform: rotate(-5deg);" alt="ocean treasure">
                        <div class="glass-effect p-3 rounded-4">
                            <p class="fst-italic opacity-85 small mb-0 lh-lg">"Cái đẹp thực sự bắt nguồn từ sự nguyên bản của thiên nhiên."</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="glass-card p-4 p-xl-5 text-center d-flex flex-column align-items-center justify-content-between h-100">
                    <h5 class="mb-2 w-100">Kiệt tác thủ công</h5>
                    <p class="small opacity-50 mb-4">Trải nghiệm bộ sưu tập</p>

                    <div class="glass-circle my-3" style="width: 120px; height: 120px; background: rgba(255,255,255,0.05) !important;">
                        <img src="/img/logo.png" alt="Logo" style="width: 80px; object-fit: contain; filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));" />
                    </div>

                    <a href="/san-pham" class="glass-btn w-100 py-3 mt-auto rounded-pill" style="letter-spacing: 1px;">
                        Khám phá <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="glass-card p-4 p-xl-5 h-100 d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid var(--border-light);">
                        <h3 class="mb-0">Quy trình chế tác</h3>
                        <span class="glass-effect px-3 py-1 rounded-pill small opacity-75">100% Thủ công</span>
                    </div>

                    <div class="row g-4 mt-2">
                        <div class="col-md-3 col-6 text-center text-md-start">
                            <div class="display-4 fw-bold opacity-25 mb-2">01</div>
                            <h6 class="mb-2">Tuyển chọn</h6>
                            <p class="small opacity-50 mb-0">Lựa chọn xà cừ tốt nhất từ vùng biển sâu.</p>
                        </div>
                        <div class="col-md-3 col-6 text-center text-md-start">
                            <div class="display-4 fw-bold opacity-25 mb-2">02</div>
                            <h6 class="mb-2">Xử lý</h6>
                            <p class="small opacity-50 mb-0">Áp dụng kỹ thuật ép lạnh và làm sạch tinh xảo.</p>
                        </div>
                        <div class="col-md-3 col-6 text-center text-md-start">
                            <div class="display-4 fw-bold opacity-25 mb-2">03</div>
                            <h6 class="mb-2">Chế tác</h6>
                            <p class="small opacity-50 mb-0">Tạo hình độc bản bởi bàn tay nghệ nhân.</p>
                        </div>
                        <div class="col-md-3 col-6 text-center text-md-start">
                            <div class="display-4 fw-bold opacity-25 mb-2">04</div>
                            <h6 class="mb-2">Kiểm định</h6>
                            <p class="small opacity-50 mb-0">Đánh bóng luxury và kiểm tra chất lượng.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>